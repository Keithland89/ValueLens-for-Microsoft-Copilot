	column BotFriendlyName =
			SWITCH(
			    'Agent Performance'[BotName],
			    "msdyn_copilotforemployeeselfserviceit", "IT Self-Service",
			    "msdyn_copilotforemployeeselfservicehr", "HR Self-Service",
			    "cat_adaptiveCardGallery", "Adaptive Card Gallery",
			    'Agent Performance'[BotName]
			)
		lineageTag: a7b24cb8-02ea-4d50-bce4-3e0fb02f7d7e
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column ConversationType =
			VAR FirstUser = LOWER('Agent Performance'[FirstUserMessage])
			VAR TopicCount = 'Agent Performance'[TopicCount]
			VAR TurnCount = 'Agent Performance'[TurnCount]
			
			VAR Category =
			    IF(
			        TopicCount = 0,
			        "🚫 Unengaged",
			        IF(
			            TopicCount = 1 && TurnCount <= 2,
			            "⚡ Quick Info",
			            IF(
			                TopicCount >= 3,
			                "🔀 Multi-Topic",
			                IF(
			                    TurnCount >= 5,
			                    "💬 Extended",
			                    IF(
			                        CONTAINSSTRING(FirstUser, "error") ||
			                        CONTAINSSTRING(FirstUser, "issue") ||
			                        CONTAINSSTRING(FirstUser, "problem") ||
			                        CONTAINSSTRING(FirstUser, "not working") ||
			                        CONTAINSSTRING(FirstUser, "broken"),
			                        "🔧 Troubleshooting",
			                        "❓ Standard"
			                    )
			                )
			            )
			        )
			    )
			
			RETURN Category
		lineageTag: 4d9268d0-2b8d-482b-b4b1-a458228dccdb
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	/// Character count of first user message — used by Prompt Quality Score
	column PromptLength =
			IF(
			    ISBLANK('Agent Performance'[FirstUserMessage]),
			    0,
			    LEN('Agent Performance'[FirstUserMessage])
			)
		dataType: int64
		formatString: #,0
		lineageTag: b1c2d3e4-0002-0001-0001-000000000001
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

	/// Composite score (0–100) rating user prompt quality based on outcome, efficiency, errors, and specificity
	column PromptQualityScore =
			VAR IsEngaged = 'Agent Performance'[SessionType] = "Engaged"
			VAR Outcome = 'Agent Performance'[SessionOutcome]
			VAR Turns = 'Agent Performance'[TurnCount]
			VAR Reason = 'Agent Performance'[OutcomeReason]
			VAR MsgLen = 'Agent Performance'[PromptLength]
			
			// 1. Engagement (15 pts) — did the prompt engage the bot?
			VAR EngagePts = IF(IsEngaged, 15, 0)
			
			// 2. Resolution (35 pts) — ultimate success signal
			VAR ResolvePts =
			    SWITCH(Outcome,
			        "Resolved", 35,
			        "Abandoned", 5,
			        "Escalated", 15,
			        0
			    )
			
			// 3. Turn efficiency (20 pts) — fewer turns to resolve = clearer prompt
			VAR TurnPts =
			    IF(NOT IsEngaged, 0,
			        IF(Outcome = "Resolved",
			            IF(Turns <= 3, 20, IF(Turns <= 5, 15, IF(Turns <= 8, 10, 5))),
			            IF(Turns <= 2, 5,
			                IF(Turns <= 5, 8,
			                    IF(Turns <= 8, 5, 2)))
			        )
			    )
			
			// 4. Error-free (10 pts) — no system/user errors
			VAR ErrorPts =
			    IF(Reason = "SystemError", 0,
			        IF(Reason = "UserError", 3, 10)
			    )
			
			// 5. Implied success (10 pts)
			VAR SuccessPts = IF('Agent Performance'[ImpliedSuccess] = "TRUE", 10, 0)
			
			// 6. Prompt specificity (10 pts) — based on message length
			VAR SpecPts =
			    IF(MsgLen = 0, 0,
			        IF(MsgLen < 15, 2,
			            IF(MsgLen <= 40, 5,
			                IF(MsgLen <= 100, 10, 8)
			            )
			        )
			    )
			
			VAR RawScore = EngagePts + ResolvePts + TurnPts + ErrorPts + SuccessPts + SpecPts
			
			RETURN MIN(RawScore, 100)
		dataType: int64
		formatString: #,0
		lineageTag: b1c2d3e4-0002-0001-0002-000000000001
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

	/// Numeric complexity score (0–5) for averaging at agent/group level
	column ConversationComplexity =
			SWITCH(
			    'Agent Performance'[ConversationType],
			    "🚫 Unengaged", 0,
			    "⚡ Quick Info", 1,
			    "❓ Standard", 2,
			    "🔧 Troubleshooting", 3,
			    "💬 Extended", 4,
			    "🔀 Multi-Topic", 5,
			    2
			)
		dataType: int64
		formatString: 0
		lineageTag: b1c2d3e4-0002-0002-0001-000000000001
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

	/// Higher-level grouping of PrimaryTopic for the Topic Themes treemap / slicer.
	/// Quick-win keyword bucketing — swap for a Topic Theme Mapping table when ready.
	column 'Topic Theme' =
			VAR t = LOWER('Agent Performance'[PrimaryTopic])
			RETURN
			    SWITCH(
			        TRUE(),
			        CONTAINSSTRING(t, "password") || CONTAINSSTRING(t, "mfa") || CONTAINSSTRING(t, "login") || CONTAINSSTRING(t, "access"), "IT & Access",
			        CONTAINSSTRING(t, "payroll") || CONTAINSSTRING(t, "expense") || CONTAINSSTRING(t, "pension") || CONTAINSSTRING(t, "payslip"), "Finance",
			        CONTAINSSTRING(t, "leave") || CONTAINSSTRING(t, "holiday") || CONTAINSSTRING(t, "absence") || CONTAINSSTRING(t, "onboard"), "HR & People",
			        CONTAINSSTRING(t, "policy") || CONTAINSSTRING(t, "compliance") || CONTAINSSTRING(t, "benefit"), "Policy",
			        ISBLANK(t) || t = "", "Untagged",
			        "Other"
			    )
		lineageTag: ap0topic-col0-0001-000000000001
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column 'Topic (resolved)' =
			VAR classic = 'Agent Performance'[PrimaryTopic]
			VAR lc = LOWER(classic)
			VAR isSystemClassic = CONTAINSSTRING(lc, "[system]") || lc = "logging" || lc = "greeting" || CONTAINSSTRING(lc, "conversation start")
			VAR m = LOWER(TRIM('Agent Performance'[FirstUserMessage]))
			VAR derived =
			    SWITCH(
			        TRUE(),
			        ISBLANK(m) || m = "", "🚫 No message",
			        CONTAINSSTRING(m, "have access to talk to this bot") || CONTAINSSTRING(m, "contact the owner"), "🚫 No Access (system)",
			        LEFT(m, 1) = "/", "🚫 Command",
			        m IN {"hi", "hey", "hello", "test", "ok", "thanks", "thank you"}, "🚫 Greeting",
			        CONTAINSSTRING(m, "what this agent can do") || CONTAINSSTRING(m, "what can you do") || CONTAINSSTRING(m, "example of what"), "🚫 Capability probe",
			        CONTAINSSTRING(m, "suicid") || CONTAINSSTRING(m, "harm myself") || CONTAINSSTRING(m, "kill myself"), "⚠ Safety / Wellbeing",
			        CONTAINSSTRING(m, "threat") || CONTAINSSTRING(m, "scare") || CONTAINSSTRING(m, "ignore previous") || CONTAINSSTRING(m, "pretend you"), "⚠ Misuse / Jailbreak",
			        CONTAINSSTRING(m, "is this valid") || CONTAINSSTRING(m, "is this correct"), "⚠ PII / Validation",
			        CONTAINSSTRING(m, "leave") || CONTAINSSTRING(m, "holiday") || CONTAINSSTRING(m, "absence") || CONTAINSSTRING(m, "redundancy"), "Leave & Absence",
			        CONTAINSSTRING(m, "access") || CONTAINSSTRING(m, "permission") || CONTAINSSTRING(m, "carm") || CONTAINSSTRING(m, "login") || CONTAINSSTRING(m, "password") || CONTAINSSTRING(m, "iga"), "Access & Permissions",
			        CONTAINSSTRING(m, "laptop") || CONTAINSSTRING(m, "order") || CONTAINSSTRING(m, "device") || CONTAINSSTRING(m, "phone") || CONTAINSSTRING(m, "holder"), "Device & Hardware",
			        CONTAINSSTRING(m, "licen") || CONTAINSSTRING(m, "mural") || CONTAINSSTRING(m, "vpl") || CONTAINSSTRING(m, "power bi") || CONTAINSSTRING(m, "install"), "Software & Licensing",
			        CONTAINSSTRING(m, "who is") || CONTAINSSTRING(m, "directory") || CONTAINSSTRING(m, "hidden") || CONTAINSSTRING(m, "contact number"), "People & Directory",
			        CONTAINSSTRING(m, "pay") || CONTAINSSTRING(m, "bonus") || CONTAINSSTRING(m, "expense") || CONTAINSSTRING(m, "payslip") || CONTAINSSTRING(m, "uplift") || CONTAINSSTRING(m, "amex"), "Pay & Expenses",
			        CONTAINSSTRING(m, "purchas") || CONTAINSSTRING(m, "flexpay") || CONTAINSSTRING(m, "hub") || CONTAINSSTRING(m, "parking") || CONTAINSSTRING(m, "discount"), "Purchasing & Perks",
			        CONTAINSSTRING(m, "contract") || CONTAINSSTRING(m, "policy") || CONTAINSSTRING(m, "documentation") || CONTAINSSTRING(m, "process") || CONTAINSSTRING(m, "terms"), "Policy & Process",
			        "Other"
			    )
			RETURN
			    IF(NOT isSystemClassic && NOT ISBLANK(classic) && classic <> "", classic, derived)
		lineageTag: ap0topic-col0-0001-000000000002
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	partition 'Agent Performance' = m
		mode: import
		source =
				let
				    // CT-derived agent performance, produced by the transcript parser
				    // (parse_copilot_transcripts.py / Copilot_Agent_Transcript_Parser.ipynb)
				    // alongside agent_sessions.csv etc. in the same Lakehouse folder.
				    PromotedHeaders = if Enable_Dataverse = "Include" then (try FabricTable("agent_performance") otherwise EmptyTable({"ConversationTranscriptId", "ConversationStartTime", "SchemaVersion", "BotName", "BotId", "AADTenantId", "BatchId", "SessionStartTimeUtc", "SessionEndTimeUtc", "SessionType", "SessionOutcome", "TurnCount", "OutcomeReason", "ImpliedSuccess", "LastUserIntentId", "IsDesignMode", "Locale", "UserMessageCount", "BotMessageCount", "TotalMessageCount", "FirstUserMessage", "LastUserMessage", "FirstBotMessage", "LastBotMessage", "TopicsTriggered", "TopicCount", "PrimaryTopic", "DurationSeconds", "AverageLatencyMs", "Var_ESS_UserContext_UPN", "Var_ESS_Message_Disclaimer", "Var_ESS_UserContext_RefreshInterval_Hours", "Var_ESS_UserContext_Conversation_Initialized", "AllVariables", "TotalActivityCount", "TraceActivityCount", "EventActivityCount", "StatusCode", "StateCode"})) else EmptyTable({"ConversationTranscriptId", "ConversationStartTime", "SchemaVersion", "BotName", "BotId", "AADTenantId", "BatchId", "SessionStartTimeUtc", "SessionEndTimeUtc", "SessionType", "SessionOutcome", "TurnCount", "OutcomeReason", "ImpliedSuccess", "LastUserIntentId", "IsDesignMode", "Locale", "UserMessageCount", "BotMessageCount", "TotalMessageCount", "FirstUserMessage", "LastUserMessage", "FirstBotMessage", "LastBotMessage", "TopicsTriggered", "TopicCount", "PrimaryTopic", "DurationSeconds", "AverageLatencyMs", "Var_ESS_UserContext_UPN", "Var_ESS_Message_Disclaimer", "Var_ESS_UserContext_RefreshInterval_Hours", "Var_ESS_UserContext_Conversation_Initialized", "AllVariables", "TotalActivityCount", "TraceActivityCount", "EventActivityCount", "StatusCode", "StateCode"}),
				    ChangedTypes = Table.TransformColumnTypes(
				        PromotedHeaders,
				        {
				            {"TurnCount", Int64.Type},
				            {"UserMessageCount", Int64.Type},
				            {"BotMessageCount", Int64.Type},
				            {"TotalMessageCount", Int64.Type},
				            {"TopicCount", Int64.Type},
				            {"DurationSeconds", Int64.Type},
				            {"AverageLatencyMs", Int64.Type},
				            {"TotalActivityCount", Int64.Type},
				            {"TraceActivityCount", Int64.Type},
				            {"EventActivityCount", Int64.Type},
				            {"StatusCode", Int64.Type},
				            {"StateCode", Int64.Type}
				        }
				    ),
				    FixedSessionStartTimeUtc = Table.TransformColumns(
				        ChangedTypes,
				        {{"SessionStartTimeUtc", each try DateTime.From(_) otherwise null, type nullable datetime}}
				    ),
				    AddedInteractionDate = Table.AddColumn(
				        FixedSessionStartTimeUtc,
				        "InteractionDate",
				        each if [SessionStartTimeUtc] <> null then Date.From([SessionStartTimeUtc]) else null,
				        type nullable date
				    ),
				    AddedWeekStart = Table.AddColumn(
				        AddedInteractionDate,
				        "weekstart",
				        each if [InteractionDate] <> null then Date.ToText(Date.StartOfWeek([InteractionDate]), "MM/dd/yyyy") else null,
				        type nullable text
				    )
				in
				    AddedWeekStart

	annotation PBI_NavigationStepName = Navigation

	annotation PBI_ResultType = Table

