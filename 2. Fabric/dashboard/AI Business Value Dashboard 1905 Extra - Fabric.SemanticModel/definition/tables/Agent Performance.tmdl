table 'Agent Performance'
	lineageTag: 448eb627-6701-4335-8f1e-cb626f4e7c9b

	measure 'Total Conversations' = COUNTROWS('Agent Performance')
		formatString: #,0
		displayFolder: Agent KPIs
		lineageTag: e4a91aa9-b95f-494b-8538-ec1515db44e5

	measure 'Abandonment Rate' =
			DIVIDE(
			    CALCULATE(
			        COUNTROWS('Agent Performance'),
			        'Agent Performance'[SessionOutcome] = "Abandoned"
			    ),
			    COUNTROWS('Agent Performance'),
			    0
			)
		formatString: 0.0%
		displayFolder: Agent KPIs
		lineageTag: 2464f6a3-c461-42bc-94cd-f5f828635fee

	measure 'Avg Conversation Duration' = AVERAGE('Agent Performance'[DurationSeconds])
		formatString: #,0 "sec"
		displayFolder: Agent KPIs
		lineageTag: 773d08ba-6f32-48ac-a60f-ce8f41e10b3f

	measure 'Resolution Rate' =
			DIVIDE(
			    CALCULATE(
			        COUNTROWS('Agent Performance'),
			        'Agent Performance'[SessionOutcome] = "Resolved"
			    ),
			    COUNTROWS('Agent Performance'),
			    0
			)
		formatString: 0.0%
		displayFolder: Agent KPIs
		lineageTag: e49bd491-1a0a-4114-9b19-22c4e5bb18f2

	measure 'Unique Users' = DISTINCTCOUNT('Agent Performance'[Var_ESS_UserContext_UPN])
		formatString: #,0
		displayFolder: Agent KPIs
		lineageTag: 64c70052-af52-498e-a35f-ddca55f4940a

	/// % of conversations the orchestrator flagged as impliedSuccess=TRUE. The reliable
	/// proxy-satisfaction signal when explicit thumbs are too sparse for a CSAT.
	measure 'Implied Success %' =
			DIVIDE(
			    CALCULATE(
			        COUNTROWS('Agent Performance'),
			        'Agent Performance'[ImpliedSuccess] = "TRUE"
			    ),
			    COUNTROWS('Agent Performance'),
			    0
			)
		formatString: 0.0%;-0.0%;0.0%
		displayFolder: Agent KPIs
		lineageTag: e49bd491-1a0a-4114-9b19-22c4e5bb1900

	measure 'Avg Bot Response Time' = AVERAGE('Agent Performance'[AverageLatencyMs])
		formatString: #,0 "ms"
		displayFolder: Agent Performance
		lineageTag: 9de05fa2-9b96-4379-be5d-fd41280196a7

	measure 'Escalation Rate' =
			DIVIDE(
			    CALCULATE(
			        COUNTROWS('Agent Performance'),
			        'Agent Performance'[SessionOutcome] = "Escalated"
			    ),
			    COUNTROWS('Agent Performance'),
			    0
			)
		formatString: 0.0%
		displayFolder: Agent KPIs
		lineageTag: e484b66c-978b-42ed-8f63-71488721da77

	/// Avg turns needed to resolve — lower = better prompt clarity
	measure 'Avg Turns to Resolve' =
			CALCULATE(
			    AVERAGE('Agent Performance'[TurnCount]),
			    'Agent Performance'[SessionOutcome] = "Resolved"
			)
		formatString: 0.0
		displayFolder: 🧠 Prompt Quality
		lineageTag: b1c2d3e4-0001-0001-0003-000000000001

	/// Avg Prompt Quality Score across current filter context (0–100)
	measure 'Avg Prompt Quality Score' = AVERAGE('Agent Performance'[PromptQualityScore])
		formatString: 0.0
		displayFolder: 🧠 Prompt Quality
		lineageTag: b1c2d3e4-0001-0001-0001-000000000001

	/// % of engaged conversations where the first message led to resolution in ≤ 4 turns
	measure 'Prompt Effectiveness Rate' =
			DIVIDE(
			    CALCULATE(
			        COUNTROWS('Agent Performance'),
			        'Agent Performance'[SessionOutcome] = "Resolved",
			        'Agent Performance'[TurnCount] <= 4,
			        'Agent Performance'[SessionType] = "Engaged"
			    ),
			    CALCULATE(
			        COUNTROWS('Agent Performance'),
			        'Agent Performance'[SessionType] = "Engaged"
			    ),
			    0
			)
		formatString: 0.0%
		displayFolder: 🧠 Prompt Quality
		lineageTag: b1c2d3e4-0001-0001-0002-000000000001

	measure 'Avg Topics Per Conversation' = AVERAGE('Agent Performance'[TopicCount])
		formatString: 0.0
		displayFolder: Agent KPIs
		lineageTag: b1c2d3e4-0001-0001-0006-000000000001

	/// Average conversation complexity (0–5 scale: Unengaged=0, Quick Info=1, Standard=2, Troubleshooting=3, Extended=4, Multi-Topic=5)
	measure 'Avg Conversation Complexity' = AVERAGE('Agent Performance'[ConversationComplexity])
		formatString: 0.0
		displayFolder: 🧠 Prompt Quality
		lineageTag: b1c2d3e4-0001-0002-0001-000000000001

	/// Most common conversation type for the current filter context (agent, date, etc.)
	measure 'Dominant Conversation Type' =
			VAR TypeCounts =
			    ADDCOLUMNS(
			        VALUES('Agent Performance'[ConversationType]),
			        "TypeTotal", CALCULATE(COUNTROWS('Agent Performance'))
			    )
			VAR TopType = TOPN(1, TypeCounts, [TypeTotal], DESC)
			VAR TopName = MAXX(TopType, [ConversationType])
			VAR TopTypeCount = MAXX(TopType, [TypeTotal])
			VAR Total = COUNTROWS('Agent Performance')
			RETURN
			IF(Total = 0, BLANK(),
			    TopName & " (" & FORMAT(DIVIDE(TopTypeCount, Total, 0), "0%") & ")"
			)
		displayFolder: 🧠 Prompt Quality
		lineageTag: b1c2d3e4-0001-0002-0002-000000000001

	/// Dynamic narrative: how prompt characteristics correlate with session outcomes
	measure '🧠 Agent Prompt Quality Insight' =
			VAR EngagedCount = CALCULATE(COUNTROWS('Agent Performance'), 'Agent Performance'[SessionType] = "Engaged")
			VAR ResolvedCount = CALCULATE(COUNTROWS('Agent Performance'), 'Agent Performance'[SessionOutcome] = "Resolved")
			VAR AbandonedCount = CALCULATE(COUNTROWS('Agent Performance'), 'Agent Performance'[SessionOutcome] = "Abandoned")
			VAR AvgScore = [Avg Prompt Quality Score]
			
			// Prompt length analysis
			VAR AvgLenResolved = CALCULATE(AVERAGE('Agent Performance'[PromptLength]), 'Agent Performance'[SessionOutcome] = "Resolved")
			VAR AvgLenAbandoned = CALCULATE(AVERAGE('Agent Performance'[PromptLength]), 'Agent Performance'[SessionOutcome] = "Abandoned")
			
			// Turn efficiency
			VAR AvgTurnsResolved = CALCULATE(AVERAGE('Agent Performance'[TurnCount]), 'Agent Performance'[SessionOutcome] = "Resolved")
			VAR AvgTurnsAbandoned = CALCULATE(AVERAGE('Agent Performance'[TurnCount]), 'Agent Performance'[SessionOutcome] = "Abandoned")
			
			// Quick resolution rate (resolved in ≤ 3 turns)
			VAR QuickResolve = CALCULATE(COUNTROWS('Agent Performance'), 'Agent Performance'[SessionOutcome] = "Resolved", 'Agent Performance'[TurnCount] <= 3)
			VAR QuickResolvePct = DIVIDE(QuickResolve, ResolvedCount, 0)
			
			// Score line
			VAR ScoreLine = "Avg score: " & FORMAT(AvgScore, "0.0") & "/100 across " & FORMAT(EngagedCount, "#,0") & " engaged sessions."
			
			// Prompt length insight
			VAR LengthLine =
			    IF(NOT ISBLANK(AvgLenResolved) && NOT ISBLANK(AvgLenAbandoned),
			        IF(AvgLenResolved > AvgLenAbandoned * 1.15,
			            " Resolved prompts avg " & FORMAT(AvgLenResolved, "#,0") & " chars vs " & FORMAT(AvgLenAbandoned, "#,0") & " for abandoned — more detail helps.",
			            IF(AvgLenAbandoned > AvgLenResolved * 1.15,
			                " Abandoned prompts are longer (avg " & FORMAT(AvgLenAbandoned, "#,0") & " chars) — complex queries may exceed agent capability.",
			                " Prompt length similar across outcomes (~" & FORMAT(AvgLenResolved, "#,0") & " chars)."
			            )
			        ),
			        ""
			    )
			
			// Turn insight
			VAR TurnLine =
			    IF(NOT ISBLANK(AvgTurnsResolved),
			        " Resolved sessions avg " & FORMAT(AvgTurnsResolved, "0.0") & " turns" &
			        IF(NOT ISBLANK(AvgTurnsAbandoned),
			            " vs " & FORMAT(AvgTurnsAbandoned, "0.0") & " for abandoned.", "."),
			        ""
			    )
			
			// Quick resolution insight
			VAR QuickLine =
			    IF(ResolvedCount > 0,
			        " " & FORMAT(QuickResolvePct, "0%") & " of resolutions happened within 3 turns.",
			        ""
			    )
			
			RETURN
			IF(EngagedCount = 0, "No engaged sessions in current selection.",
			    ScoreLine & LengthLine & TurnLine & QuickLine
			)
		displayFolder: 🧠 Prompt Quality
		lineageTag: b1c2d3e4-0001-0001-0004-000000000001

	/// Prompt quality broken down by conversation type — shows which categories have best/worst quality
	measure '🧠 Prompt Quality by Type' =
			VAR TypeStats =
			    ADDCOLUMNS(
			        FILTER(VALUES('Agent Performance'[ConversationType]), [ConversationType] <> "🚫 Unengaged"),
			        "AvgScore", CALCULATE(AVERAGE('Agent Performance'[PromptQualityScore])),
			        "Total", CALCULATE(COUNTROWS('Agent Performance')),
			        "ResRate", DIVIDE(
			            CALCULATE(COUNTROWS('Agent Performance'), 'Agent Performance'[SessionOutcome] = "Resolved"),
			            CALCULATE(COUNTROWS('Agent Performance')), 0)
			    )
			VAR BestType = TOPN(1, FILTER(TypeStats, [Total] >= 2), [AvgScore], DESC)
			VAR WorstType = TOPN(1, FILTER(TypeStats, [Total] >= 2), [AvgScore], ASC)
			VAR BestName = MAXX(BestType, [ConversationType])
			VAR BestScore = MAXX(BestType, [AvgScore])
			VAR WorstName = MAXX(WorstType, [ConversationType])
			VAR WorstScore = MAXX(WorstType, [AvgScore])
			RETURN
			IF(COUNTROWS(TypeStats) = 0, "No data.",
			    "Best: " & BestName & " (score " & FORMAT(BestScore, "0.0") & ") | " &
			    "Weakest: " & WorstName & " (score " & FORMAT(WorstScore, "0.0") & ")"
			)
		displayFolder: 🧠 Prompt Quality
		lineageTag: b1c2d3e4-0001-0001-0005-000000000001

	/// Average turns across all conversations (effort signal) — used on Conversation Analysis
	measure 'Avg Turns' = AVERAGE('Agent Performance'[TurnCount])
		formatString: 0.0
		displayFolder: Agent KPIs
		lineageTag: c0a1b2c3-0002-0001-0001-000000000001

	/// Dynamic narrative theming conversation topics by resolution — strongest, weakest, and most-escalated topics
	measure '🧠 Topic Resolution Insight' =
			VAR T =
			    ADDCOLUMNS(
			        FILTER(
			            VALUES('Agent Performance'[Topic (resolved)]),
			            CALCULATE([Total Conversations]) >= 5
			                && ( NOT (CONTAINSSTRING('Agent Performance'[Topic (resolved)], UNICHAR(128683))) && 'Agent Performance'[Topic (resolved)] <> "Other" )
			        ),
			        "Res", DIVIDE([Resolved Conversations], CALCULATE([Total Conversations], 'Agent Performance'[SessionType] = "Engaged")),
			        "Esc", [Escalation Rate]
			    )
			VAR Best = TOPN(1, T, [Res], DESC)
			VAR Worst = TOPN(1, T, [Res], ASC)
			VAR EscR = TOPN(1, T, [Esc], DESC)
			RETURN
			IF(
			    COUNTROWS(T) = 0, "Not enough conversations to theme topics in this selection.",
			    "✅ " & MAXX(Best, 'Agent Performance'[Topic (resolved)]) & " resolves best (" & FORMAT(MAXX(Best, [Res]), "0%") & " of engaged). " &
			    "⚠️ " & MAXX(Worst, 'Agent Performance'[Topic (resolved)]) & " is the biggest drag (" & FORMAT(MAXX(Worst, [Res]), "0%") & "). " &
			    "🔁 " & MAXX(EscR, 'Agent Performance'[Topic (resolved)]) & " escalates most (" & FORMAT(MAXX(EscR, [Esc]), "0%") & ")."
			)
		displayFolder: 🗂 Topics
		lineageTag: c0a1b2c3-0002-0001-0002-000000000001

	/// Conversations the agent resolved on its own.
	measure 'Resolved Conversations' = CALCULATE([Total Conversations], 'Agent Performance'[SessionOutcome] = "Resolved")
		formatString: #,0
		displayFolder: 🗂 Topics
		lineageTag: ap0topic-meas-0001-000000000001

	/// Conversations handed off to a human.
	measure 'Escalated Conversations' = CALCULATE([Total Conversations], 'Agent Performance'[SessionOutcome] = "Escalated")
		formatString: #,0
		displayFolder: 🗂 Topics
		lineageTag: ap0topic-meas-0001-000000000002

	/// Conversations the user dropped without a resolution.
	measure 'Abandoned Conversations' = CALCULATE([Total Conversations], 'Agent Performance'[SessionOutcome] = "Abandoned")
		formatString: #,0
		displayFolder: 🗂 Topics
		lineageTag: ap0topic-meas-0001-000000000003

	/// Of conversations that reached a clear outcome (resolved OR escalated to a
	/// human), the share the agent contained itself. Drives "Best Self-Served Topics".
	measure 'Deflection Rate' = DIVIDE([Resolved Conversations], [Resolved Conversations] + [Escalated Conversations])
		formatString: 0.0%;-0.0%;0.0%
		displayFolder: 🗂 Topics
		lineageTag: ap0topic-meas-0001-000000000004

	/// Share of resolved conversations the agent closed within 3 turns (fast wins).
	measure 'Quick-Resolve Rate (<=3 turns)' =
			DIVIDE(
			    CALCULATE([Total Conversations],
			        'Agent Performance'[SessionOutcome] = "Resolved",
			        'Agent Performance'[TurnCount] <= 3),
			    [Resolved Conversations])
		formatString: 0.0%;-0.0%;0.0%
		displayFolder: 🗂 Topics
		lineageTag: ap0topic-meas-0001-000000000005

	measure '🧠 Conversation Summary' =
			VAR Total = [Total Conversations]
			VAR Engaged = CALCULATE([Total Conversations], 'Agent Performance'[SessionType] = "Engaged")
			VAR EngPct = DIVIDE(Engaged, Total)
			VAR ResEng = DIVIDE([Resolved Conversations], Engaged)
			VAR AbnEng = DIVIDE([Abandoned Conversations], Engaged)
			VAR T =
			    ADDCOLUMNS(
			        FILTER(
			            VALUES('Agent Performance'[Topic (resolved)]),
			            ( NOT (CONTAINSSTRING('Agent Performance'[Topic (resolved)], UNICHAR(128683))) && 'Agent Performance'[Topic (resolved)] <> "Other" )
			        ),
			        "V", [Total Conversations],
			        "A", [Abandonment Rate]
			    )
			VAR TopTopic = MAXX(TOPN(1, T, [V], DESC), 'Agent Performance'[Topic (resolved)])
			VAR TopVol = MAXX(TOPN(1, T, [V], DESC), [V])
			VAR WorstTopic = MAXX(TOPN(1, FILTER(T, [V] >= 5), [A], DESC), 'Agent Performance'[Topic (resolved)])
			RETURN
			IF(
			    Total = 0, "No conversations in this selection.",
			    FORMAT(Total, "#,0") & " conversations, " & FORMAT(EngPct, "0%") & " engaged. " &
			    "Among engaged: " & FORMAT(ResEng, "0%") & " resolved, " & FORMAT(AbnEng, "0%") & " abandoned. " &
			    "Busiest topic: " & TopTopic & " (" & FORMAT(TopVol, "#,0") & " convs). " &
			    "Most abandoned: " & WorstTopic & "."
			)
		displayFolder: 🗂 Topics
		lineageTag: ap0topic-meas-0001-000000000010

	measure 'Top Topic per Agent' = ```
			
			VAR T =
			    ADDCOLUMNS (
			        FILTER (
			            VALUES ( 'Agent Performance'[Topic (resolved)] ),
			            ( NOT ( CONTAINSSTRING ( 'Agent Performance'[Topic (resolved)], UNICHAR ( 128683 ) ) ) && 'Agent Performance'[Topic (resolved)] <> "Other" )
			        ),
			        "@Convs", CALCULATE ( [Total Conversations] )
			    )
			VAR Best = TOPN ( 1, T, [@Convs], DESC )
			RETURN
			    IF (
			        ISBLANK ( MAXX ( Best, [@Convs] ) ), "—",
			        MAXX ( Best, 'Agent Performance'[Topic (resolved)] )
			            & " (" & FORMAT ( MAXX ( Best, [@Convs] ), "#,0" ) & ")"
			    )
			
			```
		displayFolder: Agent KPIs
		lineageTag: c851f690-a816-4de3-8825-39de1f33a702

	/// The topic this agent RESOLVES most (by resolved-conversation count), excluding noise buckets.
	measure 'Top Resolved Topic' = ```
			
			VAR T =
			    ADDCOLUMNS (
			        FILTER (
			            VALUES ( 'Agent Performance'[Topic (resolved)] ),
			            ( NOT ( CONTAINSSTRING ( 'Agent Performance'[Topic (resolved)], UNICHAR ( 128683 ) ) ) && 'Agent Performance'[Topic (resolved)] <> "Other" )
			        ),
			        "@N", CALCULATE ( [Resolved Conversations] )
			    )
			VAR Best = TOPN ( 1, T, [@N], DESC )
			RETURN
			    IF (
			        ISBLANK ( MAXX ( Best, [@N] ) ) || MAXX ( Best, [@N] ) = 0, "—",
			        MAXX ( Best, 'Agent Performance'[Topic (resolved)] )
			            & " (" & FORMAT ( MAXX ( Best, [@N] ), "#,0" ) & ")"
			    )
			
			```
		displayFolder: Agent KPIs
		lineageTag: ap0topic-meas-topres-000000000001

	/// The topic this agent sees ABANDONED most (user dropped, no resolution), excluding noise buckets.
	measure 'Top Abandoned Topic' = ```
			
			VAR T =
			    ADDCOLUMNS (
			        FILTER (
			            VALUES ( 'Agent Performance'[Topic (resolved)] ),
			            ( NOT ( CONTAINSSTRING ( 'Agent Performance'[Topic (resolved)], UNICHAR ( 128683 ) ) ) && 'Agent Performance'[Topic (resolved)] <> "Other" )
			        ),
			        "@N", CALCULATE ( [Abandoned Conversations] )
			    )
			VAR Best = TOPN ( 1, T, [@N], DESC )
			RETURN
			    IF (
			        ISBLANK ( MAXX ( Best, [@N] ) ) || MAXX ( Best, [@N] ) = 0, "—",
			        MAXX ( Best, 'Agent Performance'[Topic (resolved)] )
			            & " (" & FORMAT ( MAXX ( Best, [@N] ), "#,0" ) & ")"
			    )
			
			```
		displayFolder: Agent KPIs
		lineageTag: ap0topic-meas-topabn-000000000002

	/// The topic this agent ESCALATES to a human most, excluding noise buckets.
	measure 'Top Escalated Topic' = ```
			
			VAR T =
			    ADDCOLUMNS (
			        FILTER (
			            VALUES ( 'Agent Performance'[Topic (resolved)] ),
			            ( NOT ( CONTAINSSTRING ( 'Agent Performance'[Topic (resolved)], UNICHAR ( 128683 ) ) ) && 'Agent Performance'[Topic (resolved)] <> "Other" )
			        ),
			        "@N", CALCULATE ( [Escalated Conversations] )
			    )
			VAR Best = TOPN ( 1, T, [@N], DESC )
			RETURN
			    IF (
			        ISBLANK ( MAXX ( Best, [@N] ) ) || MAXX ( Best, [@N] ) = 0, "—",
			        MAXX ( Best, 'Agent Performance'[Topic (resolved)] )
			            & " (" & FORMAT ( MAXX ( Best, [@N] ), "#,0" ) & ")"
			    )
			
			```
		displayFolder: Agent KPIs
		lineageTag: ap0topic-meas-topesc-000000000003

