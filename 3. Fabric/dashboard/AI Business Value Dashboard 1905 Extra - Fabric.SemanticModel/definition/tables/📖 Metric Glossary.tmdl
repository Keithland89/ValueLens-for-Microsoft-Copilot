/// Searchable metric glossary aligned to dashboard pages. Zero performance impact — pure metadata calculated table.
table '📖 Metric Glossary'
	lineageTag: 8b71f88c-7524-4ba0-a81d-f7ca7ef45b64

	/// Number of metrics catalogued in the current filter context.
	measure 'Total Metrics' = COUNTROWS('📖 Metric Glossary')
		formatString: #,##0
		lineageTag: c1d2e3f4-a5b6-4c7d-8e9f-0a1b2c3d4e51

	measure 'Page Description (Selected)' = ```
			
			VAR _SelectedPage = SELECTEDVALUE('📖 Metric Glossary'[Page])
			VAR _Description = 
			    CALCULATE(
			        SELECTEDVALUE('📖 Metric Glossary'[PageDescription]),
			        ALLEXCEPT('📖 Metric Glossary', '📖 Metric Glossary'[Page])
			    )
			RETURN
			    IF(
			        HASONEVALUE('📖 Metric Glossary'[Page]),
			        _Description,
			        "👈 Select a page from the slicer to see what it does."
			    )
			```
		lineageTag: 290ae66c-5cf7-406d-ae1b-41fbe8393a8a

	column Page
		lineageTag: e5f8ce4e-0260-4641-b767-9074c969a5be
		summarizeBy: none
		isNameInferred
		sourceColumn: [Page]
		sortByColumn: PageOrder

		annotation SummarizationSetBy = Automatic

	column Metric
		lineageTag: aefccd57-48ba-41be-8726-4e7171c5fae7
		summarizeBy: none
		isNameInferred
		sourceColumn: [Metric]
		sortByColumn: MetricOrder

		annotation SummarizationSetBy = Automatic

	column Description
		lineageTag: c360df21-ff12-4418-a672-1f2b7becde62
		summarizeBy: none
		isNameInferred
		sourceColumn: [Description]

		annotation SummarizationSetBy = Automatic

	column PageOrder
		isHidden
		formatString: 0
		lineageTag: a7c1d2e3-f4b5-4c6d-8e9f-0a1b2c3d4e5f
		summarizeBy: sum
		isNameInferred
		sourceColumn: [PageOrder]

		annotation SummarizationSetBy = Automatic

	column MetricOrder
		isHidden
		formatString: 0
		lineageTag: e643cc8e-fde1-4c40-83bd-5bfad861217c
		summarizeBy: sum
		isNameInferred
		sourceColumn: [MetricOrder]

		annotation SummarizationSetBy = Automatic

	column PageDescription
		lineageTag: 36f3a1a8-1da5-4ab4-9ede-55378ad9ee06
		summarizeBy: none
		isNameInferred
		sourceColumn: [PageDescription]

		annotation SummarizationSetBy = Automatic

	partition '📖 Metric Glossary' = calculated
		mode: import
		source =
				
				DATATABLE(
				    "Page", STRING,
				    "PageDescription", STRING,
				    "Metric", STRING,
				    "Description", STRING,
				    "PageOrder", INTEGER,
				    "MetricOrder", INTEGER,
				    {
				        // === Topics & Conversations ===
				        {"🤖 Topics & Conversations", "What users actually ask Copilot Studio agents and how well it is handled. Topics are resolved from the user's first message because generative agents rarely fire classic topics; system and noise messages are routed to filtered buckets. Outcomes split Resolved / Abandoned / Escalated, best read among engaged sessions. Use it to see demand, self-service (deflection) and where the agent struggles.", "Topic (resolved)", "Derived conversation topic: the classic Copilot Studio topic when present, otherwise classified from the user's first message. System and noise messages (no-access replies, greetings, commands) are routed to filtered buckets; safety, misuse and PII are flagged.", 20, 2001},
				        {"🤖 Topics & Conversations", "What users actually ask Copilot Studio agents and how well it is handled. Topics are resolved from the user's first message because generative agents rarely fire classic topics; system and noise messages are routed to filtered buckets. Outcomes split Resolved / Abandoned / Escalated, best read among engaged sessions. Use it to see demand, self-service (deflection) and where the agent struggles.", "Topic Theme", "Higher-level grouping of topics (IT & Access, Finance, HR & People, Policy) used by the Topic Themes treemap.", 20, 2002},
				        {"🤖 Topics & Conversations", "What users actually ask Copilot Studio agents and how well it is handled. Topics are resolved from the user's first message because generative agents rarely fire classic topics; system and noise messages are routed to filtered buckets. Outcomes split Resolved / Abandoned / Escalated, best read among engaged sessions. Use it to see demand, self-service (deflection) and where the agent struggles.", "Most Asked Topics", "Top topics by conversation volume - what users come to the agent for most.", 20, 2003},
				        {"🤖 Topics & Conversations", "What users actually ask Copilot Studio agents and how well it is handled. Topics are resolved from the user's first message because generative agents rarely fire classic topics; system and noise messages are routed to filtered buckets. Outcomes split Resolved / Abandoned / Escalated, best read among engaged sessions. Use it to see demand, self-service (deflection) and where the agent struggles.", "Hardest Topics", "Topics with the highest abandonment (minimum 5 conversations) - where the agent struggles most.", 20, 2004},
				        {"🤖 Topics & Conversations", "What users actually ask Copilot Studio agents and how well it is handled. Topics are resolved from the user's first message because generative agents rarely fire classic topics; system and noise messages are routed to filtered buckets. Outcomes split Resolved / Abandoned / Escalated, best read among engaged sessions. Use it to see demand, self-service (deflection) and where the agent struggles.", "Best Self-Served Topics", "Topics with the highest deflection - handled end to end without escalating to a human.", 20, 2005},
				        {"🤖 Topics & Conversations", "What users actually ask Copilot Studio agents and how well it is handled. Topics are resolved from the user's first message because generative agents rarely fire classic topics; system and noise messages are routed to filtered buckets. Outcomes split Resolved / Abandoned / Escalated, best read among engaged sessions. Use it to see demand, self-service (deflection) and where the agent struggles.", "Total Conversations", "Count of conversation transcripts in scope. Every time the agent was opened or triggered, including unengaged opens.", 20, 2006},
				        {"🤖 Topics & Conversations", "What users actually ask Copilot Studio agents and how well it is handled. Topics are resolved from the user's first message because generative agents rarely fire classic topics; system and noise messages are routed to filtered buckets. Outcomes split Resolved / Abandoned / Escalated, best read among engaged sessions. Use it to see demand, self-service (deflection) and where the agent struggles.", "Engaged Sessions", "Conversations where the user meaningfully interacted (SessionType = Engaged). The honest denominator for quality metrics; unengaged opens are excluded.", 20, 2007},
				        {"🤖 Topics & Conversations", "What users actually ask Copilot Studio agents and how well it is handled. Topics are resolved from the user's first message because generative agents rarely fire classic topics; system and noise messages are routed to filtered buckets. Outcomes split Resolved / Abandoned / Escalated, best read among engaged sessions. Use it to see demand, self-service (deflection) and where the agent struggles.", "Resolution Rate", "Share of conversations the agent resolved. Divides by all conversations; use the engaged-based insight for true quality.", 20, 2008},
				        {"🤖 Topics & Conversations", "What users actually ask Copilot Studio agents and how well it is handled. Topics are resolved from the user's first message because generative agents rarely fire classic topics; system and noise messages are routed to filtered buckets. Outcomes split Resolved / Abandoned / Escalated, best read among engaged sessions. Use it to see demand, self-service (deflection) and where the agent struggles.", "Abandonment Rate", "Share of conversations the user dropped without a resolution.", 20, 2009},
				        {"🤖 Topics & Conversations", "What users actually ask Copilot Studio agents and how well it is handled. Topics are resolved from the user's first message because generative agents rarely fire classic topics; system and noise messages are routed to filtered buckets. Outcomes split Resolved / Abandoned / Escalated, best read among engaged sessions. Use it to see demand, self-service (deflection) and where the agent struggles.", "Escalation Rate", "Share of conversations handed off to a human.", 20, 2010},
				        {"🤖 Topics & Conversations", "What users actually ask Copilot Studio agents and how well it is handled. Topics are resolved from the user's first message because generative agents rarely fire classic topics; system and noise messages are routed to filtered buckets. Outcomes split Resolved / Abandoned / Escalated, best read among engaged sessions. Use it to see demand, self-service (deflection) and where the agent struggles.", "Deflection Rate", "Resolved divided by Resolved plus Escalated: of conversations reaching a clear outcome, the share the agent contained itself. The self-service and cost-avoidance signal.", 20, 2011},
				        {"🤖 Topics & Conversations", "What users actually ask Copilot Studio agents and how well it is handled. Topics are resolved from the user's first message because generative agents rarely fire classic topics; system and noise messages are routed to filtered buckets. Outcomes split Resolved / Abandoned / Escalated, best read among engaged sessions. Use it to see demand, self-service (deflection) and where the agent struggles.", "Quick-Resolve Rate (3 turns)", "Share of resolved conversations closed within 3 turns - fast wins.", 20, 2012},
				        {"🤖 Topics & Conversations", "What users actually ask Copilot Studio agents and how well it is handled. Topics are resolved from the user's first message because generative agents rarely fire classic topics; system and noise messages are routed to filtered buckets. Outcomes split Resolved / Abandoned / Escalated, best read among engaged sessions. Use it to see demand, self-service (deflection) and where the agent struggles.", "Session Error Rate", "Share of conversations that logged at least one runtime or system error (ErrorTraceData, for example SystemError).", 20, 2013},
				        {"🤖 Topics & Conversations", "What users actually ask Copilot Studio agents and how well it is handled. Topics are resolved from the user's first message because generative agents rarely fire classic topics; system and noise messages are routed to filtered buckets. Outcomes split Resolved / Abandoned / Escalated, best read among engaged sessions. Use it to see demand, self-service (deflection) and where the agent struggles.", "Avg Bot Response Time", "Average execution time per generative Dynamic-Plan step, in milliseconds, averaged across conversations. Generative agents only.", 20, 2014},
				        {"🤖 Topics & Conversations", "What users actually ask Copilot Studio agents and how well it is handled. Topics are resolved from the user's first message because generative agents rarely fire classic topics; system and noise messages are routed to filtered buckets. Outcomes split Resolved / Abandoned / Escalated, best read among engaged sessions. Use it to see demand, self-service (deflection) and where the agent struggles.", "Implied Success %", "Share of conversations the orchestrator flagged as impliedSuccess = TRUE. A reliable proxy for satisfaction when explicit thumbs are sparse.", 20, 2015},
				        {"🤖 Topics & Conversations", "What users actually ask Copilot Studio agents and how well it is handled. Topics are resolved from the user's first message because generative agents rarely fire classic topics; system and noise messages are routed to filtered buckets. Outcomes split Resolved / Abandoned / Escalated, best read among engaged sessions. Use it to see demand, self-service (deflection) and where the agent struggles.", "Total Cost Units", "In-product credit cost summed from displayedCost on generative plan steps. Diagnostic per agent and conversation; distinct from billed credits.", 20, 2016},
				        {"🤖 Topics & Conversations", "What users actually ask Copilot Studio agents and how well it is handled. Topics are resolved from the user's first message because generative agents rarely fire classic topics; system and noise messages are routed to filtered buckets. Outcomes split Resolved / Abandoned / Escalated, best read among engaged sessions. Use it to see demand, self-service (deflection) and where the agent struggles.", "Conversation Summary", "Narrative overview: volume, percent engaged, resolution and abandonment among engaged, busiest and most-abandoned topic. No prompt scoring.", 20, 2017},
				        {"🤖 Topics & Conversations", "What users actually ask Copilot Studio agents and how well it is handled. Topics are resolved from the user's first message because generative agents rarely fire classic topics; system and noise messages are routed to filtered buckets. Outcomes split Resolved / Abandoned / Escalated, best read among engaged sessions. Use it to see demand, self-service (deflection) and where the agent struggles.", "Topic Resolution Insight", "Narrative: the best and worst topic by resolution among engaged sessions (minimum 5 conversations) and the topic that escalates to a human most often.", 20, 2018},
				        // === Credit Consumption (Billing) ===
				        {"💳 Credit Consumption (Billing)", "Finance-grade credit consumption from the Power Platform entitlement exports (prepaid versus pay-as-you-go) by agent, user and environment. Complements the transcript-native Total Cost Units: this is what you were billed, that is where generative cost happened. Optional source, enabled by the Enable_Consumption toggle.", "Total Billed Credits", "Credits the customer is charged for, summed across agents.", 21, 2101},
				        {"💳 Credit Consumption (Billing)", "Finance-grade credit consumption from the Power Platform entitlement exports (prepaid versus pay-as-you-go) by agent, user and environment. Complements the transcript-native Total Cost Units: this is what you were billed, that is where generative cost happened. Optional source, enabled by the Enable_Consumption toggle.", "Total Non-Billed Credits", "Credits consumed within entitlement and not charged.", 21, 2102},
				        {"💳 Credit Consumption (Billing)", "Finance-grade credit consumption from the Power Platform entitlement exports (prepaid versus pay-as-you-go) by agent, user and environment. Complements the transcript-native Total Cost Units: this is what you were billed, that is where generative cost happened. Optional source, enabled by the Enable_Consumption toggle.", "Total Consumed Credits", "Billed plus non-billed credits.", 21, 2103},
				        {"💳 Credit Consumption (Billing)", "Finance-grade credit consumption from the Power Platform entitlement exports (prepaid versus pay-as-you-go) by agent, user and environment. Complements the transcript-native Total Cost Units: this is what you were billed, that is where generative cost happened. Optional source, enabled by the Enable_Consumption toggle.", "Billing vs Transcript Gap", "Billed actuals minus the transcript displayedCost - the cost the transcript view does not capture (classic answers, tools, non-generative turns).", 21, 2104},
				        {"💳 Credit Consumption (Billing)", "Finance-grade credit consumption from the Power Platform entitlement exports (prepaid versus pay-as-you-go) by agent, user and environment. Complements the transcript-native Total Cost Units: this is what you were billed, that is where generative cost happened. Optional source, enabled by the Enable_Consumption toggle.", "Total Credits Used (Billing)", "Credits used across users, from the per-user billing report.", 21, 2105},
				        {"💳 Credit Consumption (Billing)", "Finance-grade credit consumption from the Power Platform entitlement exports (prepaid versus pay-as-you-go) by agent, user and environment. Complements the transcript-native Total Cost Units: this is what you were billed, that is where generative cost happened. Optional source, enabled by the Enable_Consumption toggle.", "Billing Active Users", "Distinct users who consumed at least one credit.", 21, 2106},
				        {"💳 Credit Consumption (Billing)", "Finance-grade credit consumption from the Power Platform entitlement exports (prepaid versus pay-as-you-go) by agent, user and environment. Complements the transcript-native Total Cost Units: this is what you were billed, that is where generative cost happened. Optional source, enabled by the Enable_Consumption toggle.", "Prepaid Consumed", "Prepaid (committed capacity) message credits consumed, by environment.", 21, 2107},
				        {"💳 Credit Consumption (Billing)", "Finance-grade credit consumption from the Power Platform entitlement exports (prepaid versus pay-as-you-go) by agent, user and environment. Complements the transcript-native Total Cost Units: this is what you were billed, that is where generative cost happened. Optional source, enabled by the Enable_Consumption toggle.", "PAYG Consumed", "Pay-as-you-go credits consumed, the overage billed to Azure.", 21, 2108},
				        {"💳 Credit Consumption (Billing)", "Finance-grade credit consumption from the Power Platform entitlement exports (prepaid versus pay-as-you-go) by agent, user and environment. Complements the transcript-native Total Cost Units: this is what you were billed, that is where generative cost happened. Optional source, enabled by the Enable_Consumption toggle.", "Entitled Capacity", "Purchased message capacity.", 21, 2109},
				        {"💳 Credit Consumption (Billing)", "Finance-grade credit consumption from the Power Platform entitlement exports (prepaid versus pay-as-you-go) by agent, user and environment. Complements the transcript-native Total Cost Units: this is what you were billed, that is where generative cost happened. Optional source, enabled by the Enable_Consumption toggle.", "Prepaid Utilisation %", "Prepaid consumed divided by entitled capacity. Above 100 percent means pay-as-you-go overage is in play.", 21, 2110},
				        // === Agent Feedback (Transcript) ===
				        {"💬 Agent Feedback (Transcript)", "Voice of the user for Copilot Studio agents, derived from the conversation transcripts rather than the survey export. It leads with proxy satisfaction (Implied Success, Resolution, Abandonment, errors) because explicit thumbs are sparse, and surfaces explicit thumbs and verbatims when present.", "Transcript CSAT Score", "Submitted thumbs-up divided by all submitted verdicts, transcript-native. Lights up automatically as thumbs accumulate.", 22, 2201},
				        {"💬 Agent Feedback (Transcript)", "Voice of the user for Copilot Studio agents, derived from the conversation transcripts rather than the survey export. It leads with proxy satisfaction (Implied Success, Resolution, Abandonment, errors) because explicit thumbs are sparse, and surfaces explicit thumbs and verbatims when present.", "Transcript Thumbs Up", "Conversations with a submitted positive reaction.", 22, 2202},
				        {"💬 Agent Feedback (Transcript)", "Voice of the user for Copilot Studio agents, derived from the conversation transcripts rather than the survey export. It leads with proxy satisfaction (Implied Success, Resolution, Abandonment, errors) because explicit thumbs are sparse, and surfaces explicit thumbs and verbatims when present.", "Transcript Thumbs Down", "Conversations with a submitted negative reaction.", 22, 2203},
				        {"💬 Agent Feedback (Transcript)", "Voice of the user for Copilot Studio agents, derived from the conversation transcripts rather than the survey export. It leads with proxy satisfaction (Implied Success, Resolution, Abandonment, errors) because explicit thumbs are sparse, and surfaces explicit thumbs and verbatims when present.", "Feedback Prompt Rate", "Share of conversations shown a feedback card - the offered signal, not a verdict.", 22, 2204},
				        {"💬 Agent Feedback (Transcript)", "Voice of the user for Copilot Studio agents, derived from the conversation transcripts rather than the survey export. It leads with proxy satisfaction (Implied Success, Resolution, Abandonment, errors) because explicit thumbs are sparse, and surfaces explicit thumbs and verbatims when present.", "Feedback Submission Rate", "Share of prompted users who actually submitted a verdict - the completion rate.", 22, 2205},
				        // === User Feedback (Product) ===
				        {"💬 User Feedback (Product)", "Microsoft 365 product feedback (OCV) across all Copilot surfaces, not just agents. Use the Surface / Agent field to view satisfaction by Copilot Chat, Copilot in apps (Teams, Word, Outlook) and individual Copilot Studio agents together. Optional source, enabled by the Enable_ProductFeedback toggle.", "Surface / Agent", "One field combining Copilot surface and agent: shows the agent name for Copilot Studio feedback, otherwise the app or surface (M365 Chat, Teams, Word, Outlook).", 23, 2301},
				        {"💬 User Feedback (Product)", "Microsoft 365 product feedback (OCV) across all Copilot surfaces, not just agents. Use the Surface / Agent field to view satisfaction by Copilot Chat, Copilot in apps (Teams, Word, Outlook) and individual Copilot Studio agents together. Optional source, enabled by the Enable_ProductFeedback toggle.", "App", "The Copilot surface the feedback was about (M365 Chat, Teams, Word, Excel, Outlook, SharePoint, Copilot Studio).", 23, 2302},
				        {"💬 User Feedback (Product)", "Microsoft 365 product feedback (OCV) across all Copilot surfaces, not just agents. Use the Surface / Agent field to view satisfaction by Copilot Chat, Copilot in apps (Teams, Word, Outlook) and individual Copilot Studio agents together. Optional source, enabled by the Enable_ProductFeedback toggle.", "CopilotType", "Higher-level grouping of the Copilot surface, for example Copilot Chat, Copilot in Apps or Agent.", 23, 2303},
				        {"💬 User Feedback (Product)", "Microsoft 365 product feedback (OCV) across all Copilot surfaces, not just agents. Use the Surface / Agent field to view satisfaction by Copilot Chat, Copilot in apps (Teams, Word, Outlook) and individual Copilot Studio agents together. Optional source, enabled by the Enable_ProductFeedback toggle.", "Satisfaction Rate", "Share of feedback that is positive (thumbs up or smile) out of all feedback.", 23, 2304},
				        {"💬 User Feedback (Product)", "Microsoft 365 product feedback (OCV) across all Copilot surfaces, not just agents. Use the Surface / Agent field to view satisfaction by Copilot Chat, Copilot in apps (Teams, Word, Outlook) and individual Copilot Studio agents together. Optional source, enabled by the Enable_ProductFeedback toggle.", "Total Feedback", "Count of feedback items in scope.", 23, 2305},
				        // ═══ 1. ◆ Overview ═══
				        {"◆ Overview", "Single-page executive snapshot of the entire AI adoption story. Three headline narratives (hours saved, work created, expertise unlocked) frame the rest of the report. Use the Stage breakdown to see how mature your user base is, and the Productive Capacity card to anchor the conversation in concrete hours-per-week. Driven by aggregated AI Tasks and Usage Mode Share rolled up across all environments.", "Executive Headline", "Dynamic headline summarising the report's three top value stories: hours saved, work created, expertise unlocked.", 1, 101},
				        {"◆ Overview", "Single-page executive snapshot of the entire AI adoption story. Three headline narratives (hours saved, work created, expertise unlocked) frame the rest of the report. Use the Stage breakdown to see how mature your user base is, and the Productive Capacity card to anchor the conversation in concrete hours-per-week. Driven by aggregated AI Tasks and Usage Mode Share rolled up across all environments.", "Maturity Specialist Headline", "Top specialist role users are delegating to (e.g. Data Analyst, Compliance Specialist).", 1, 102},
				        {"◆ Overview", "Single-page executive snapshot of the entire AI adoption story. Three headline narratives (hours saved, work created, expertise unlocked) frame the rest of the report. Use the Stage breakdown to see how mature your user base is, and the Productive Capacity card to anchor the conversation in concrete hours-per-week. Driven by aggregated AI Tasks and Usage Mode Share rolled up across all environments.", "Maturity Task Breakdown Headline", "Headline on what kind of tasks dominate (Asking/Consuming/Finding/Producing/Delegating).", 1, 103},
				        {"◆ Overview", "Single-page executive snapshot of the entire AI adoption story. Three headline narratives (hours saved, work created, expertise unlocked) frame the rest of the report. Use the Stage breakdown to see how mature your user base is, and the Productive Capacity card to anchor the conversation in concrete hours-per-week. Driven by aggregated AI Tasks and Usage Mode Share rolled up across all environments.", "Maturity By Org Headline", "Which org has the most mature AI usage profile.", 1, 104},
				        {"◆ Overview", "Single-page executive snapshot of the entire AI adoption story. Three headline narratives (hours saved, work created, expertise unlocked) frame the rest of the report. Use the Stage breakdown to see how mature your user base is, and the Productive Capacity card to anchor the conversation in concrete hours-per-week. Driven by aggregated AI Tasks and Usage Mode Share rolled up across all environments.", "Usage Mode Share", "% breakdown of interactions across 5 AI Usage Modes (Asking/Consuming/Finding/Producing/Delegating).", 1, 105},
				        {"◆ Overview", "Single-page executive snapshot of the entire AI adoption story. Three headline narratives (hours saved, work created, expertise unlocked) frame the rest of the report. Use the Stage breakdown to see how mature your user base is, and the Productive Capacity card to anchor the conversation in concrete hours-per-week. Driven by aggregated AI Tasks and Usage Mode Share rolled up across all environments.", "Productive Capacity - Hours Per Week", "Hours of human-equivalent productive capacity AI is producing per week.", 1, 106},
				        {"◆ Overview", "Single-page executive snapshot of the entire AI adoption story. Three headline narratives (hours saved, work created, expertise unlocked) frame the rest of the report. Use the Stage breakdown to see how mature your user base is, and the Productive Capacity card to anchor the conversation in concrete hours-per-week. Driven by aggregated AI Tasks and Usage Mode Share rolled up across all environments.", "Licensed Utilisation %", "% of licensed users actively using Copilot. Target >60%. <40% = many licences unused.", 1, 107},
				        {"◆ Overview", "Single-page executive snapshot of the entire AI adoption story. Three headline narratives (hours saved, work created, expertise unlocked) frame the rest of the report. Use the Stage breakdown to see how mature your user base is, and the Productive Capacity card to anchor the conversation in concrete hours-per-week. Driven by aggregated AI Tasks and Usage Mode Share rolled up across all environments.", "AI Tasks", "Total AI tasks completed (resource-level). The primary 'what AI did' metric.", 1, 108},
				        {"◆ Overview", "Single-page executive snapshot of the entire AI adoption story. Three headline narratives (hours saved, work created, expertise unlocked) frame the rest of the report. Use the Stage breakdown to see how mature your user base is, and the Productive Capacity card to anchor the conversation in concrete hours-per-week. Driven by aggregated AI Tasks and Usage Mode Share rolled up across all environments.", "% of Users in Stage", "% of users at each maturity stage (Beginner/Developing/Habitual/Power).", 1, 109},
				        {"◆ Overview", "Single-page executive snapshot of the entire AI adoption story. Three headline narratives (hours saved, work created, expertise unlocked) frame the rest of the report. Use the Stage breakdown to see how mature your user base is, and the Productive Capacity card to anchor the conversation in concrete hours-per-week. Driven by aggregated AI Tasks and Usage Mode Share rolled up across all environments.", "Stage Top Org", "Organisation with the most users at the currently filtered maturity stage.", 1, 110},
				        {"◆ Overview", "Single-page executive snapshot of the entire AI adoption story. Three headline narratives (hours saved, work created, expertise unlocked) frame the rest of the report. Use the Stage breakdown to see how mature your user base is, and the Productive Capacity card to anchor the conversation in concrete hours-per-week. Driven by aggregated AI Tasks and Usage Mode Share rolled up across all environments.", "New Expertise - Roles", "Distinct specialist roles AI is filling (Data Analyst, Compliance Specialist, etc.).", 1, 111},
				        {"◆ Overview", "Single-page executive snapshot of the entire AI adoption story. Three headline narratives (hours saved, work created, expertise unlocked) frame the rest of the report. Use the Stage breakdown to see how mature your user base is, and the Productive Capacity card to anchor the conversation in concrete hours-per-week. Driven by aggregated AI Tasks and Usage Mode Share rolled up across all environments.", "New Expertise - Jobs", "Volume of specialist-grade tasks AI is performing.", 1, 112},
				
				        // ═══ 2. 🧬 Signal > Behavior > Value ═══
				        {"🧬 Signal > Behavior > Value", "Traceability page showing the full pipeline from a raw audit Signal (e.g. an Outlook+Read event) → enriched Behavior (Email Summarising) → mapped Value Outcome (Time Saved – Email). Use this when stakeholders ask 'what does the dashboard actually measure?' — every row is auditable back to the source event. Underpinned by the Behavior Value Map dimension and the Behavior_Enriched_Full calculated column on the audit table.", "AI Tasks", "Total AI tasks completed — broken down by Signal → Behavior → Value Outcome flow.", 2, 201},
				        {"🧬 Signal > Behavior > Value", "Traceability page showing the full pipeline from a raw audit Signal (e.g. an Outlook+Read event) → enriched Behavior (Email Summarising) → mapped Value Outcome (Time Saved – Email). Use this when stakeholders ask 'what does the dashboard actually measure?' — every row is auditable back to the source event. Underpinned by the Behavior Value Map dimension and the Behavior_Enriched_Full calculated column on the audit table.", "Behavior_Enriched_Full", "Most accurate behavior classification, using Agent description and capabilities to resolve 'Agent: General Purpose' into specific agent types.", 2, 202},
				        {"🧬 Signal > Behavior > Value", "Traceability page showing the full pipeline from a raw audit Signal (e.g. an Outlook+Read event) → enriched Behavior (Email Summarising) → mapped Value Outcome (Time Saved – Email). Use this when stakeholders ask 'what does the dashboard actually measure?' — every row is auditable back to the source event. Underpinned by the Behavior Value Map dimension and the Behavior_Enriched_Full calculated column on the audit table.", "Value Outcome", "The business outcome each behavior maps to (Time Saved, Content Output, Search Time Saved, etc.).", 2, 203},
				
				        // ═══ 3. ◆ Activation ═══
				        {"◆ Activation", "Top-of-funnel diagnostics: who's actually using AI vs who has access. Splits users into licensed-active, unlicensed-active, agent-active, and inactive — letting you spot wasted licences and pinpoint cohorts to push to the next stage. The 'Using Copilot / Not Using Agents' visual is the practical action prompt: those users are your shortest path to broadening agent adoption.", "Activation Overall Headline", "Headline summarising overall activation across licensed/unlicensed/agents.", 3, 301},
				        {"◆ Activation", "Top-of-funnel diagnostics: who's actually using AI vs who has access. Splits users into licensed-active, unlicensed-active, agent-active, and inactive — letting you spot wasted licences and pinpoint cohorts to push to the next stage. The 'Using Copilot / Not Using Agents' visual is the practical action prompt: those users are your shortest path to broadening agent adoption.", "Activation Licensed Headline", "Licensed Copilot activation rate vs total licenses.", 3, 302},
				        {"◆ Activation", "Top-of-funnel diagnostics: who's actually using AI vs who has access. Splits users into licensed-active, unlicensed-active, agent-active, and inactive — letting you spot wasted licences and pinpoint cohorts to push to the next stage. The 'Using Copilot / Not Using Agents' visual is the practical action prompt: those users are your shortest path to broadening agent adoption.", "Activation Unlicensed Headline", "Unlicensed Chat activation — organic demand signal.", 3, 303},
				        {"◆ Activation", "Top-of-funnel diagnostics: who's actually using AI vs who has access. Splits users into licensed-active, unlicensed-active, agent-active, and inactive — letting you spot wasted licences and pinpoint cohorts to push to the next stage. The 'Using Copilot / Not Using Agents' visual is the practical action prompt: those users are your shortest path to broadening agent adoption.", "Activation Agents Headline", "Agent activation — % of users engaging with at least one agent.", 3, 304},
				        {"◆ Activation", "Top-of-funnel diagnostics: who's actually using AI vs who has access. Splits users into licensed-active, unlicensed-active, agent-active, and inactive — letting you spot wasted licences and pinpoint cohorts to push to the next stage. The 'Using Copilot / Not Using Agents' visual is the practical action prompt: those users are your shortest path to broadening agent adoption.", "All Active Users", "Distinct count of users with any AI activity in the period.", 3, 305},
				        {"◆ Activation", "Top-of-funnel diagnostics: who's actually using AI vs who has access. Splits users into licensed-active, unlicensed-active, agent-active, and inactive — letting you spot wasted licences and pinpoint cohorts to push to the next stage. The 'Using Copilot / Not Using Agents' visual is the practical action prompt: those users are your shortest path to broadening agent adoption.", "Active Licensed Users", "Licensed users with any activity. Numerator for licence ROI.", 3, 306},
				        {"◆ Activation", "Top-of-funnel diagnostics: who's actually using AI vs who has access. Splits users into licensed-active, unlicensed-active, agent-active, and inactive — letting you spot wasted licences and pinpoint cohorts to push to the next stage. The 'Using Copilot / Not Using Agents' visual is the practical action prompt: those users are your shortest path to broadening agent adoption.", "Active Unlicensed Users", "Unlicensed users actively using Copilot Chat — organic demand.", 3, 307},
				        {"◆ Activation", "Top-of-funnel diagnostics: who's actually using AI vs who has access. Splits users into licensed-active, unlicensed-active, agent-active, and inactive — letting you spot wasted licences and pinpoint cohorts to push to the next stage. The 'Using Copilot / Not Using Agents' visual is the practical action prompt: those users are your shortest path to broadening agent adoption.", "Active Agent Users", "Distinct users who interacted with at least one agent.", 3, 308},
				        {"◆ Activation", "Top-of-funnel diagnostics: who's actually using AI vs who has access. Splits users into licensed-active, unlicensed-active, agent-active, and inactive — letting you spot wasted licences and pinpoint cohorts to push to the next stage. The 'Using Copilot / Not Using Agents' visual is the practical action prompt: those users are your shortest path to broadening agent adoption.", "Inactive Users", "Licensed but zero activity in the period. Reclamation candidates.", 3, 309},
				        {"◆ Activation", "Top-of-funnel diagnostics: who's actually using AI vs who has access. Splits users into licensed-active, unlicensed-active, agent-active, and inactive — letting you spot wasted licences and pinpoint cohorts to push to the next stage. The 'Using Copilot / Not Using Agents' visual is the practical action prompt: those users are your shortest path to broadening agent adoption.", "Total Licensed Users", "Total licences provisioned (denominator for utilisation).", 3, 310},
				        {"◆ Activation", "Top-of-funnel diagnostics: who's actually using AI vs who has access. Splits users into licensed-active, unlicensed-active, agent-active, and inactive — letting you spot wasted licences and pinpoint cohorts to push to the next stage. The 'Using Copilot / Not Using Agents' visual is the practical action prompt: those users are your shortest path to broadening agent adoption.", "% Active Users (of Total)", "% of all enabled users (licensed + unlicensed) actively using AI.", 3, 311},
				        {"◆ Activation", "Top-of-funnel diagnostics: who's actually using AI vs who has access. Splits users into licensed-active, unlicensed-active, agent-active, and inactive — letting you spot wasted licences and pinpoint cohorts to push to the next stage. The 'Using Copilot / Not Using Agents' visual is the practical action prompt: those users are your shortest path to broadening agent adoption.", "% Active Licensed Users", "% of licensed users actively using Copilot. Target >60%.", 3, 312},
				        {"◆ Activation", "Top-of-funnel diagnostics: who's actually using AI vs who has access. Splits users into licensed-active, unlicensed-active, agent-active, and inactive — letting you spot wasted licences and pinpoint cohorts to push to the next stage. The 'Using Copilot / Not Using Agents' visual is the practical action prompt: those users are your shortest path to broadening agent adoption.", "% Active Unlicensed Users", "% of unlicensed users with chat activity. Organic demand signal.", 3, 313},
				        {"◆ Activation", "Top-of-funnel diagnostics: who's actually using AI vs who has access. Splits users into licensed-active, unlicensed-active, agent-active, and inactive — letting you spot wasted licences and pinpoint cohorts to push to the next stage. The 'Using Copilot / Not Using Agents' visual is the practical action prompt: those users are your shortest path to broadening agent adoption.", "% Active Users Using Agents", "% of active users also using at least one agent.", 3, 314},
				        {"◆ Activation", "Top-of-funnel diagnostics: who's actually using AI vs who has access. Splits users into licensed-active, unlicensed-active, agent-active, and inactive — letting you spot wasted licences and pinpoint cohorts to push to the next stage. The 'Using Copilot / Not Using Agents' visual is the practical action prompt: those users are your shortest path to broadening agent adoption.", "Using Copilot / Not Using Agents", "Active Copilot users who haven't tried any agent. Pipeline for agent rollout.", 3, 315},
				
				        // ═══ 4. 📡 Adoption & Reach ═══
				        {"📡 Adoption & Reach", "Volume and breadth view. AI Tasks are sliced three ways (Copilot, Unlicensed, Agents) and indexed per-user-per-week so growth in active users doesn't mask shrinking depth. The agent metrics (Return Rate, Most Popular, Most Versatile, Top Creator) tell you whether your agent portfolio is delivering value at scale or whether interest is concentrated in just one or two breakout agents.", "Copilot AI Tasks", "AI tasks from licensed M365 Copilot users.", 4, 401},
				        {"📡 Adoption & Reach", "Volume and breadth view. AI Tasks are sliced three ways (Copilot, Unlicensed, Agents) and indexed per-user-per-week so growth in active users doesn't mask shrinking depth. The agent metrics (Return Rate, Most Popular, Most Versatile, Top Creator) tell you whether your agent portfolio is delivering value at scale or whether interest is concentrated in just one or two breakout agents.", "Copilot AI Tasks Per User Per Week", "Weekly task rate per licensed user. Density signal.", 4, 402},
				        {"📡 Adoption & Reach", "Volume and breadth view. AI Tasks are sliced three ways (Copilot, Unlicensed, Agents) and indexed per-user-per-week so growth in active users doesn't mask shrinking depth. The agent metrics (Return Rate, Most Popular, Most Versatile, Top Creator) tell you whether your agent portfolio is delivering value at scale or whether interest is concentrated in just one or two breakout agents.", "Unlicensed AI Tasks Per User Per Week", "Weekly task rate per unlicensed user.", 4, 403},
				        {"📡 Adoption & Reach", "Volume and breadth view. AI Tasks are sliced three ways (Copilot, Unlicensed, Agents) and indexed per-user-per-week so growth in active users doesn't mask shrinking depth. The agent metrics (Return Rate, Most Popular, Most Versatile, Top Creator) tell you whether your agent portfolio is delivering value at scale or whether interest is concentrated in just one or two breakout agents.", "Agent AI Tasks Per User Per Week", "Weekly task rate per agent user.", 4, 404},
				        {"📡 Adoption & Reach", "Volume and breadth view. AI Tasks are sliced three ways (Copilot, Unlicensed, Agents) and indexed per-user-per-week so growth in active users doesn't mask shrinking depth. The agent metrics (Return Rate, Most Popular, Most Versatile, Top Creator) tell you whether your agent portfolio is delivering value at scale or whether interest is concentrated in just one or two breakout agents.", "Agent Users", "Distinct users who used any agent. Target >20% of total users.", 4, 405},
				        {"📡 Adoption & Reach", "Volume and breadth view. AI Tasks are sliced three ways (Copilot, Unlicensed, Agents) and indexed per-user-per-week so growth in active users doesn't mask shrinking depth. The agent metrics (Return Rate, Most Popular, Most Versatile, Top Creator) tell you whether your agent portfolio is delivering value at scale or whether interest is concentrated in just one or two breakout agents.", "Agent Return Rate", "% of users who return to an agent 2+ times. Target >50%.", 4, 406},
				        {"📡 Adoption & Reach", "Volume and breadth view. AI Tasks are sliced three ways (Copilot, Unlicensed, Agents) and indexed per-user-per-week so growth in active users doesn't mask shrinking depth. The agent metrics (Return Rate, Most Popular, Most Versatile, Top Creator) tell you whether your agent portfolio is delivering value at scale or whether interest is concentrated in just one or two breakout agents.", "Most Popular Agent", "Agent with the highest session count.", 4, 407},
				        {"📡 Adoption & Reach", "Volume and breadth view. AI Tasks are sliced three ways (Copilot, Unlicensed, Agents) and indexed per-user-per-week so growth in active users doesn't mask shrinking depth. The agent metrics (Return Rate, Most Popular, Most Versatile, Top Creator) tell you whether your agent portfolio is delivering value at scale or whether interest is concentrated in just one or two breakout agents.", "Top Value Outcome", "Value outcome with the most users (excluding General AI Assistance).", 4, 408},
				        {"📡 Adoption & Reach", "Volume and breadth view. AI Tasks are sliced three ways (Copilot, Unlicensed, Agents) and indexed per-user-per-week so growth in active users doesn't mask shrinking depth. The agent metrics (Return Rate, Most Popular, Most Versatile, Top Creator) tell you whether your agent portfolio is delivering value at scale or whether interest is concentrated in just one or two breakout agents.", "Efficiency - Hours Per Week", "Total efficiency hours saved per week.", 4, 409},
				
				        // ═══ 5. 🔮 Activity & Value ═══
				        {"🔮 Activity & Value", "The money page. Translates raw usage into dollars using a transparent formula: Human Equivalent Hours × Hourly Value × Penalty Factor. Adjustable slicers let you stress-test ROI assumptions in front of a CFO. Net ROI compares AI-assisted value against the licence investment so the conversation moves from 'are people using it' to 'is it paying for itself'.", "Executive Headline", "Dynamic executive summary text.", 5, 501},
				        {"🔮 Activity & Value", "The money page. Translates raw usage into dollars using a transparent formula: Human Equivalent Hours × Hourly Value × Penalty Factor. Adjustable slicers let you stress-test ROI assumptions in front of a CFO. Net ROI compares AI-assisted value against the licence investment so the conversation moves from 'are people using it' to 'is it paying for itself'.", "AI Assisted Value", "Dollar value of AI work: Hours × Hourly Value × Penalty Factor.", 5, 502},
				        {"🔮 Activity & Value", "The money page. Translates raw usage into dollars using a transparent formula: Human Equivalent Hours × Hourly Value × Penalty Factor. Adjustable slicers let you stress-test ROI assumptions in front of a CFO. Net ROI compares AI-assisted value against the licence investment so the conversation moves from 'are people using it' to 'is it paying for itself'.", "AI Assisted Value Per Week", "Weekly run rate of AI-assisted dollar value.", 5, 503},
				        {"🔮 Activity & Value", "The money page. Translates raw usage into dollars using a transparent formula: Human Equivalent Hours × Hourly Value × Penalty Factor. Adjustable slicers let you stress-test ROI assumptions in front of a CFO. Net ROI compares AI-assisted value against the licence investment so the conversation moves from 'are people using it' to 'is it paying for itself'.", "Projected Annualised Value", "Annualised projection of AI-assisted value.", 5, 504},
				        {"🔮 Activity & Value", "The money page. Translates raw usage into dollars using a transparent formula: Human Equivalent Hours × Hourly Value × Penalty Factor. Adjustable slicers let you stress-test ROI assumptions in front of a CFO. Net ROI compares AI-assisted value against the licence investment so the conversation moves from 'are people using it' to 'is it paying for itself'.", "Net ROI ($)", "AI Assisted Value minus Copilot License Investment.", 5, 505},
				        {"🔮 Activity & Value", "The money page. Translates raw usage into dollars using a transparent formula: Human Equivalent Hours × Hourly Value × Penalty Factor. Adjustable slicers let you stress-test ROI assumptions in front of a CFO. Net ROI compares AI-assisted value against the licence investment so the conversation moves from 'are people using it' to 'is it paying for itself'.", "Copilot License Investment", "Total spend on Copilot licences (input to ROI).", 5, 506},
				        {"🔮 Activity & Value", "The money page. Translates raw usage into dollars using a transparent formula: Human Equivalent Hours × Hourly Value × Penalty Factor. Adjustable slicers let you stress-test ROI assumptions in front of a CFO. Net ROI compares AI-assisted value against the licence investment so the conversation moves from 'are people using it' to 'is it paying for itself'.", "Efficiency - Hours Saved", "Cumulative hours saved across all behaviors.", 5, 507},
				        {"🔮 Activity & Value", "The money page. Translates raw usage into dollars using a transparent formula: Human Equivalent Hours × Hourly Value × Penalty Factor. Adjustable slicers let you stress-test ROI assumptions in front of a CFO. Net ROI compares AI-assisted value against the licence investment so the conversation moves from 'are people using it' to 'is it paying for itself'.", "Skills Headline", "Top specialist role being delegated to.", 5, 508},
				
				        // ═══ 6. 🌱 Usage Maturity ═══
				        {"🌱 Usage Maturity", "The cohort progression view. Users are bucketed by depth (active days) AND breadth (distinct enriched behaviours) into 5 stages: Inactive → Beginner → Developing → Habitual → Power. Watch Habitual + Power % over time — that's the cleanest signal of whether your training and enablement programmes are working. Stage logic is computed in UserMonthMetrics on a rolling 4-week window.", "Beginner Users", "Users with 1-2 active days in rolling 4-week window. On-ramp tier.", 6, 601},
				        {"🌱 Usage Maturity", "The cohort progression view. Users are bucketed by depth (active days) AND breadth (distinct enriched behaviours) into 5 stages: Inactive → Beginner → Developing → Habitual → Power. Watch Habitual + Power % over time — that's the cleanest signal of whether your training and enablement programmes are working. Stage logic is computed in UserMonthMetrics on a rolling 4-week window.", "Developing Users", "3-7 active days AND 3+ enriched behaviours. Multi-workflow learners.", 6, 602},
				        {"🌱 Usage Maturity", "The cohort progression view. Users are bucketed by depth (active days) AND breadth (distinct enriched behaviours) into 5 stages: Inactive → Beginner → Developing → Habitual → Power. Watch Habitual + Power % over time — that's the cleanest signal of whether your training and enablement programmes are working. Stage logic is computed in UserMonthMetrics on a rolling 4-week window.", "Habitual Users", "8-14 active days AND 5+ enriched behaviours. Daily routine users.", 6, 603},
				        {"🌱 Usage Maturity", "The cohort progression view. Users are bucketed by depth (active days) AND breadth (distinct enriched behaviours) into 5 stages: Inactive → Beginner → Developing → Habitual → Power. Watch Habitual + Power % over time — that's the cleanest signal of whether your training and enablement programmes are working. Stage logic is computed in UserMonthMetrics on a rolling 4-week window.", "Power Users", "15+ days OR (10+ days AND 30%+ Producing/Delegating AND uses Agent). Champions.", 6, 604},
				        {"🌱 Usage Maturity", "The cohort progression view. Users are bucketed by depth (active days) AND breadth (distinct enriched behaviours) into 5 stages: Inactive → Beginner → Developing → Habitual → Power. Watch Habitual + Power % over time — that's the cleanest signal of whether your training and enablement programmes are working. Stage logic is computed in UserMonthMetrics on a rolling 4-week window.", "Inactive Users", "Licensed but zero activity in window. Reclamation candidates.", 6, 605},
				        {"🌱 Usage Maturity", "The cohort progression view. Users are bucketed by depth (active days) AND breadth (distinct enriched behaviours) into 5 stages: Inactive → Beginner → Developing → Habitual → Power. Watch Habitual + Power % over time — that's the cleanest signal of whether your training and enablement programmes are working. Stage logic is computed in UserMonthMetrics on a rolling 4-week window.", "Habitual + Power % (Latest)", "% at top 2 maturity tiers. Most stable maturity metric.", 6, 606},
				        {"🌱 Usage Maturity", "The cohort progression view. Users are bucketed by depth (active days) AND breadth (distinct enriched behaviours) into 5 stages: Inactive → Beginner → Developing → Habitual → Power. Watch Habitual + Power % over time — that's the cleanest signal of whether your training and enablement programmes are working. Stage logic is computed in UserMonthMetrics on a rolling 4-week window.", "Agent-Assisted Mix %", "% of activity that's agent-assisted (vs raw Copilot).", 6, 607},
				        {"🌱 Usage Maturity", "The cohort progression view. Users are bucketed by depth (active days) AND breadth (distinct enriched behaviours) into 5 stages: Inactive → Beginner → Developing → Habitual → Power. Watch Habitual + Power % over time — that's the cleanest signal of whether your training and enablement programmes are working. Stage logic is computed in UserMonthMetrics on a rolling 4-week window.", "Usage Mode Share", "% across AI Usage Modes (Asking/Consuming/Finding/Producing/Delegating).", 6, 608},
				
				        // ═══ 7. 🎯 License Readiness ═══
				        {"🎯 License Readiness", "Decision-support page for the licence allocation conversation. Ranks every unlicensed user by a transparent priority score (60% weighted on weekly AI tasks, 40% on weekly active days). Filter by department to find your top candidates in any specific team. Use License Priority Tier rather than raw score for action — the tier already factors in confidence and minimum activity thresholds.", "License Priority Headline", "Top licence-allocation recommendation text.", 7, 701},
				        {"🎯 License Readiness", "Decision-support page for the licence allocation conversation. Ranks every unlicensed user by a transparent priority score (60% weighted on weekly AI tasks, 40% on weekly active days). Filter by department to find your top candidates in any specific team. Use License Priority Tier rather than raw score for action — the tier already factors in confidence and minimum activity thresholds.", "License Priority Rank (Dynamic)", "Dense ranking of unlicensed users by priority score.", 7, 702},
				        {"🎯 License Readiness", "Decision-support page for the licence allocation conversation. Ranks every unlicensed user by a transparent priority score (60% weighted on weekly AI tasks, 40% on weekly active days). Filter by department to find your top candidates in any specific team. Use License Priority Tier rather than raw score for action — the tier already factors in confidence and minimum activity thresholds.", "Average Active Days (Unlicensed)", "Avg active days for unlicensed users — consistency signal.", 7, 703},
				        {"🎯 License Readiness", "Decision-support page for the licence allocation conversation. Ranks every unlicensed user by a transparent priority score (60% weighted on weekly AI tasks, 40% on weekly active days). Filter by department to find your top candidates in any specific team. Use License Priority Tier rather than raw score for action — the tier already factors in confidence and minimum activity thresholds.", "Median Chat + Agent Active Days Per User Per Week (Unlicensed)", "Median weekly active days for unlicensed users — score input.", 7, 704},
				        {"🎯 License Readiness", "Decision-support page for the licence allocation conversation. Ranks every unlicensed user by a transparent priority score (60% weighted on weekly AI tasks, 40% on weekly active days). Filter by department to find your top candidates in any specific team. Use License Priority Tier rather than raw score for action — the tier already factors in confidence and minimum activity thresholds.", "Unlicensed AI Tasks Per User Per Week", "Weekly task rate per unlicensed user.", 7, 705},
				        {"🎯 License Readiness", "Decision-support page for the licence allocation conversation. Ranks every unlicensed user by a transparent priority score (60% weighted on weekly AI tasks, 40% on weekly active days). Filter by department to find your top candidates in any specific team. Use License Priority Tier rather than raw score for action — the tier already factors in confidence and minimum activity thresholds.", "NoOfActiveChatUsers (Unlicensed)", "Total addressable unlicensed users for licence allocation.", 7, 706},
				
				        // ═══ 8. 📈 Heatmap Trend ═══
				        {"📈 Heatmap Trend", "Time-series diagnostic page. The heatmap shows when activity spikes across weeks/months — useful for spotting seasonality, training-campaign effects, and quiet periods. MoM % changes flag whether trends are accelerating or stalling. Use the Heatmap Toggle slicer to flip between metrics (sessions, users, hours, tasks) without leaving the page.", "AI Tasks", "Total AI tasks completed.", 8, 801},
				        {"📈 Heatmap Trend", "Time-series diagnostic page. The heatmap shows when activity spikes across weeks/months — useful for spotting seasonality, training-campaign effects, and quiet periods. MoM % changes flag whether trends are accelerating or stalling. Use the Heatmap Toggle slicer to flip between metrics (sessions, users, hours, tasks) without leaving the page.", "Licensed Sessions MoM %", "MoM % change for licensed sessions.", 8, 802},
				        {"📈 Heatmap Trend", "Time-series diagnostic page. The heatmap shows when activity spikes across weeks/months — useful for spotting seasonality, training-campaign effects, and quiet periods. MoM % changes flag whether trends are accelerating or stalling. Use the Heatmap Toggle slicer to flip between metrics (sessions, users, hours, tasks) without leaving the page.", "Unlicensed Sessions MoM %", "MoM % change for unlicensed sessions.", 8, 803},
				        {"📈 Heatmap Trend", "Time-series diagnostic page. The heatmap shows when activity spikes across weeks/months — useful for spotting seasonality, training-campaign effects, and quiet periods. MoM % changes flag whether trends are accelerating or stalling. Use the Heatmap Toggle slicer to flip between metrics (sessions, users, hours, tasks) without leaving the page.", "Average Active Days Per User (Chat + Agents)", "Avg active days combining chat + agent activity.", 8, 804},
				        {"📈 Heatmap Trend", "Time-series diagnostic page. The heatmap shows when activity spikes across weeks/months — useful for spotting seasonality, training-campaign effects, and quiet periods. MoM % changes flag whether trends are accelerating or stalling. Use the Heatmap Toggle slicer to flip between metrics (sessions, users, hours, tasks) without leaving the page.", "Average Sessions Per User Per Week (Licensed)", "Weekly avg sessions for licensed users.", 8, 805},
				        {"📈 Heatmap Trend", "Time-series diagnostic page. The heatmap shows when activity spikes across weeks/months — useful for spotting seasonality, training-campaign effects, and quiet periods. MoM % changes flag whether trends are accelerating or stalling. Use the Heatmap Toggle slicer to flip between metrics (sessions, users, hours, tasks) without leaving the page.", "Avg Skills Per User", "Avg distinct skill categories per user. Breadth signal.", 8, 806},
				        {"📈 Heatmap Trend", "Time-series diagnostic page. The heatmap shows when activity spikes across weeks/months — useful for spotting seasonality, training-campaign effects, and quiet periods. MoM % changes flag whether trends are accelerating or stalling. Use the Heatmap Toggle slicer to flip between metrics (sessions, users, hours, tasks) without leaving the page.", "Efficiency - Hours Per User Per Week", "Hours saved per user per week.", 8, 807},
				        {"📈 Heatmap Trend", "Time-series diagnostic page. The heatmap shows when activity spikes across weeks/months — useful for spotting seasonality, training-campaign effects, and quiet periods. MoM % changes flag whether trends are accelerating or stalling. Use the Heatmap Toggle slicer to flip between metrics (sessions, users, hours, tasks) without leaving the page.", "Hours Saved Per User", "Cumulative hours saved per user.", 8, 808},
				
				        // ═══ 9. 🛡 Agent Governance ═══
				        {"🛡 Agent Governance", "Portfolio management view for your agent inventory. Identifies agents to keep (high impact, growing), agents to retire (dormant, never used), and agents to review (modest usage). The Agent Review (Resilient) verdict combines activity, user count, and org spread per agent — and works even when the Agents 365 metadata feed is empty, falling back to audit data. Use this monthly to keep the agent estate healthy.", "Most Popular Agent", "Agent with the most sessions. Study for replication patterns.", 9, 901},
				        {"🛡 Agent Governance", "Portfolio management view for your agent inventory. Identifies agents to keep (high impact, growing), agents to retire (dormant, never used), and agents to review (modest usage). The Agent Review (Resilient) verdict combines activity, user count, and org spread per agent — and works even when the Agents 365 metadata feed is empty, falling back to audit data. Use this monthly to keep the agent estate healthy.", "Most Versatile Agent", "Agent used by the most unique users. Breadth signal.", 9, 902},
				        {"🛡 Agent Governance", "Portfolio management view for your agent inventory. Identifies agents to keep (high impact, growing), agents to retire (dormant, never used), and agents to review (modest usage). The Agent Review (Resilient) verdict combines activity, user count, and org spread per agent — and works even when the Agents 365 metadata feed is empty, falling back to audit data. Use this monthly to keep the agent estate healthy.", "Most Popular Agent Creator (Shared - Agent Builder)", "Top creator by user reach across Agent Builder agents.", 9, 903},
				        {"🛡 Agent Governance", "Portfolio management view for your agent inventory. Identifies agents to keep (high impact, growing), agents to retire (dormant, never used), and agents to review (modest usage). The Agent Review (Resilient) verdict combines activity, user count, and org spread per agent — and works even when the Agents 365 metadata feed is empty, falling back to audit data. Use this monthly to keep the agent estate healthy.", "Agent Return Rate", "% of users returning to an agent 2+ times. Quality signal. Target >50%.", 9, 904},
				        {"🛡 Agent Governance", "Portfolio management view for your agent inventory. Identifies agents to keep (high impact, growing), agents to retire (dormant, never used), and agents to review (modest usage). The Agent Review (Resilient) verdict combines activity, user count, and org spread per agent — and works even when the Agents 365 metadata feed is empty, falling back to audit data. Use this monthly to keep the agent estate healthy.", "Agent Review (Resilient)", "Verdict: 🔥 High Impact / ✅ Keep / ⚠ Review / 💤 Dormant / ❌ Never Used / 🆕 New.", 9, 905},
				        {"🛡 Agent Governance", "Portfolio management view for your agent inventory. Identifies agents to keep (high impact, growing), agents to retire (dormant, never used), and agents to review (modest usage). The Agent Review (Resilient) verdict combines activity, user count, and org spread per agent — and works even when the Agents 365 metadata feed is empty, falling back to audit data. Use this monthly to keep the agent estate healthy.", "Agent AI Tasks", "AI tasks from agent interactions.", 9, 906},
				        {"🛡 Agent Governance", "Portfolio management view for your agent inventory. Identifies agents to keep (high impact, growing), agents to retire (dormant, never used), and agents to review (modest usage). The Agent Review (Resilient) verdict combines activity, user count, and org spread per agent — and works even when the Agents 365 metadata feed is empty, falling back to audit data. Use this monthly to keep the agent estate healthy.", "UsersInteractingWithAgents", "Distinct users interacting with agents.", 9, 907},
				        {"🛡 Agent Governance", "Portfolio management view for your agent inventory. Identifies agents to keep (high impact, growing), agents to retire (dormant, never used), and agents to review (modest usage). The Agent Review (Resilient) verdict combines activity, user count, and org spread per agent — and works even when the Agents 365 metadata feed is empty, falling back to audit data. Use this monthly to keep the agent estate healthy.", "AI Assisted Value", "Dollar value of agent-assisted work.", 9, 908},
				
				        // ═══ 10. 📘 Glossary & Guide ═══
				        {"📘 Glossary & Guide", "The page you're on. Searchable catalogue of every metric and page in the report — clicking the ? button on any page brings you here filtered to that page's context. Use the Page slicer to navigate, the Metric search box to find a specific KPI, and the description paragraph at the top of each page to understand the analytical intent before diving into the numbers.", "Total Metrics", "Count of catalogued metrics in current filter context.", 10, 1001},
				        {"📘 Glossary & Guide", "The page you're on. Searchable catalogue of every metric and page in the report — clicking the ? button on any page brings you here filtered to that page's context. Use the Page slicer to navigate, the Metric search box to find a specific KPI, and the description paragraph at the top of each page to understand the analytical intent before diving into the numbers.", "Agent Return Rate (Table)", "Per-agent return-rate breakdown — used as an example metric.", 10, 1002},
				        {"📘 Glossary & Guide", "The page you're on. Searchable catalogue of every metric and page in the report — clicking the ? button on any page brings you here filtered to that page's context. Use the Page slicer to navigate, the Metric search box to find a specific KPI, and the description paragraph at the top of each page to understand the analytical intent before diving into the numbers.", "Average Agent Sessions Per Active Agent User", "Avg agent sessions per active agent user.", 10, 1003},
				
				        // ═══ 11. 🏅 Leaderboards ═══
				        {"🏅 Leaderboards", "Per-user ranking page (hidden from view mode — accessed via drill-through). Shows the top users by Copilot tasks, unlicensed tasks, agent tasks, and value-equivalent hours. Useful for identifying champions to feature in case studies, and for spotting outlier accounts whose usage might be skewing department-level averages. Drill from any department on Adoption & Reach or License Readiness to land here filtered.", "Copilot AI Tasks Per User Per Week", "Weekly task rate per Copilot user.", 11, 1101},
				        {"🏅 Leaderboards", "Per-user ranking page (hidden from view mode — accessed via drill-through). Shows the top users by Copilot tasks, unlicensed tasks, agent tasks, and value-equivalent hours. Useful for identifying champions to feature in case studies, and for spotting outlier accounts whose usage might be skewing department-level averages. Drill from any department on Adoption & Reach or License Readiness to land here filtered.", "Unlicensed AI Tasks Per User Per Week", "Weekly task rate per unlicensed user.", 11, 1102},
