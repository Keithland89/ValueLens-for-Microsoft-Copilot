	/// First day of the feedback's month — for a clean month-grained trend x-axis.
	column MonthStart =
			IF(
			    ISBLANK('ProductFeedback'[FeedbackDate]),
			    BLANK(),
			    DATE(YEAR('ProductFeedback'[FeedbackDate]), MONTH('ProductFeedback'[FeedbackDate]), 1)
			)
		dataType: dateTime
		formatString: mmm yyyy
		lineageTag: ae4ffe2b-c0a1-0002-0001-000000000003
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

		annotation UnderlyingDateTimeDataType = Date

	partition ProductFeedback-Partition = m
		mode: import
		source =
				let
				    // Sourced from the Fabric Lakehouse Delta table user_feedback (parser output).
				    Headers = if Enable_ProductFeedback then (try FabricTable("user_feedback") otherwise EmptyTable({"Feedback Id", "Comment", "Translated Comment", "Comment Language", "Date Submitted UTC", "Feedback Type", "Microsoft Response Status", "App", "App Language", "Platform", "Source Type", "Logs, Attachments", "User Id", "User Email", "Browser", "Browser Version", "AI Context Prompt", "AI Context Response Message", "Survey Question", "Survey Response Option", "Additional Metadata", "Date Submitted Date", "Sentiment"})) else EmptyTable({"Feedback Id", "Comment", "Translated Comment", "Comment Language", "Date Submitted UTC", "Feedback Type", "Microsoft Response Status", "App", "App Language", "Platform", "Source Type", "Logs, Attachments", "User Id", "User Email", "Browser", "Browser Version", "AI Context Prompt", "AI Context Response Message", "Survey Question", "Survey Response Option", "Additional Metadata", "Date Submitted Date", "Sentiment"}),
				    Renamed = Table.RenameColumns(Headers, {
				        {"Feedback Id", "FeedbackId"},
				        {"Translated Comment", "TranslatedComment"},
				        {"Comment Language", "CommentLanguage"},
				        {"Date Submitted UTC", "DateSubmittedUTC"},
				        {"Feedback Type", "FeedbackType"},
				        {"Microsoft Response Status", "ResponseStatus"},
				        {"App Language", "AppLanguage"},
				        {"Source Type", "SourceType"},
				        {"Logs, Attachments", "HasLogsAttachments"},
				        {"User Id", "UserId"},
				        {"User Email", "UserEmail"},
				        {"Browser Version", "BrowserVersion"},
				        {"AI Context Prompt", "AIContextPrompt"},
				        {"AI Context Response Message", "AIContextResponse"},
				        {"Survey Question", "SurveyQuestion"},
				        {"Survey Response Option", "SurveyResponseOption"},
				        {"Additional Metadata", "AdditionalMetadata"}
				    }, MissingField.Ignore),
				    Typed = Table.TransformColumnTypes(Renamed, {
				        {"DateSubmittedUTC", type datetime}
				    }, "en-US"),
				    AddDate = Table.AddColumn(Typed, "FeedbackDate", each try DateTime.Date([DateSubmittedUTC]) otherwise null, type date),
				    AddHasComment = Table.AddColumn(AddDate, "HasComment", each if [Comment] <> null and [Comment] <> "" then 1 else 0, Int64.Type),
				    AddPromptLen = Table.AddColumn(AddHasComment, "PromptLength", each if [AIContextPrompt] <> null then Text.Length([AIContextPrompt]) else 0, Int64.Type),
				    // --- Helper function: extract a JSON string value by key ---
				    // Searches for "key":"value" and returns value, or null if not found
				    fnExtract = (jsonText as nullable text, key as text) as nullable text =>
				        let
				            searchFor = """" & key & """:""",
				            keyLen = Text.Length(searchFor),
				            pos = if jsonText <> null and jsonText <> "" then Text.PositionOf(jsonText, searchFor) else -1,
				            result = if pos >= 0 then
				                let
				                    afterKey = Text.Middle(jsonText, pos + keyLen),
				                    endQuote = Text.PositionOf(afterKey, """")
				                in if endQuote > 0 then Text.Start(afterKey, endQuote) else null
				            else null
				        in result,
				    // --- Clean metadata: unescape double-encoded JSON rows ---
				    AddCleanMeta = Table.AddColumn(AddPromptLen, "CleanMeta", each
				        try
				            let
				                raw = Text.Trim([AdditionalMetadata]),
				                cleaned = if raw = null or raw = "" then null
				                    else if Text.StartsWith(raw, """") then
				                        Text.Replace(Text.Replace(Text.TrimEnd(Text.TrimStart(raw, """"), """"), "\""", """"), "\\", "\")
				                    else raw
				            in cleaned
				        otherwise null, type text),
				    // --- Extract agent fields using the helper function ---
				    AddEssAgentId = Table.AddColumn(AddCleanMeta, "EssAgentId", each try fnExtract([CleanMeta], "essAgentId") otherwise null, type text),
				    AddAiAgentName = Table.AddColumn(AddEssAgentId, "AiAgentName", each
				        try (if [CleanMeta] <> null and Text.Contains([CleanMeta], "aiAgents") then fnExtract([CleanMeta], "Name") else null) otherwise null, type text),
				    AddAiAgentType = Table.AddColumn(AddAiAgentName, "AiAgentType", each
				        try (if [CleanMeta] <> null and Text.Contains([CleanMeta], "aiAgents") then fnExtract([CleanMeta], "Type") else null) otherwise null, type text),
				    AddCopilotType = Table.AddColumn(AddAiAgentType, "CopilotType", each try fnExtract([CleanMeta], "copilotType") otherwise null, type text),
				    AddUiHost = Table.AddColumn(AddCopilotType, "UiHost", each try fnExtract([CleanMeta], "UiHost") otherwise null, type text),
				    // --- Derive: IsAgentInteraction (boolean) and AgentName (text) ---
				    AddIsAgent = Table.AddColumn(AddUiHost, "IsAgentInteraction", each
				        try (([EssAgentId] <> null) or ([AiAgentName] <> null) or ([CopilotType] <> null and [CopilotType] = "custom")) otherwise false, type logical),
				    AddAgentName = Table.AddColumn(AddIsAgent, "AgentName", each
				        try (if [AiAgentName] <> null then [AiAgentName]
				        else if [EssAgentId] <> null then [EssAgentId]
				        else if [CopilotType] = "custom" then "Custom Agent"
				        else null) otherwise null, type text),
				    Selected = Table.SelectColumns(AddAgentName, {"FeedbackId", "Comment", "TranslatedComment", "CommentLanguage", "DateSubmittedUTC", "FeedbackType", "ResponseStatus", "App", "AppLanguage", "Platform", "SourceType", "HasLogsAttachments", "UserId", "UserEmail", "Browser", "BrowserVersion", "AIContextPrompt", "AIContextResponse", "SurveyQuestion", "SurveyResponseOption", "FeedbackDate", "HasComment", "PromptLength", "IsAgentInteraction", "AgentName", "UiHost", "CopilotType", "AiAgentType"})
				in
				    Selected

	annotation PBI_NavigationStepName = Navigation

	annotation PBI_ResultType = Table

