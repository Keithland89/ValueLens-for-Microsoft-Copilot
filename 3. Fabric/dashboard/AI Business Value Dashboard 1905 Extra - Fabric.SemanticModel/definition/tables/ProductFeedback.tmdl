table ProductFeedback
	lineageTag: ae4ffe2b-b5f0-4f3f-a016-54252c132081

	measure 'Total Feedback' = COUNTROWS('ProductFeedback')
		formatString: #,0
		displayFolder: 📊 Product Feedback
		lineageTag: 90516dc6-9385-4933-8b70-473b4a05ac15

	/// Compatibility alias for the prior page binding (= Satisfaction Rate / thumbs-up share).
	measure 'Positive Feedback %' =
			DIVIDE(
			    CALCULATE(COUNTROWS('ProductFeedback'), 'ProductFeedback'[FeedbackType] = "Thumbs Up"),
			    COUNTROWS('ProductFeedback')
			)
		formatString: 0.0%;-0.0%;0.0%
		displayFolder: 💬 Compat
		lineageTag: ae4ffe2b-c0a1-0001-0001-000000000001

	/// Compatibility alias for the prior page binding (thumbs-down share).
	measure 'Negative Feedback %' =
			DIVIDE(
			    CALCULATE(COUNTROWS('ProductFeedback'), 'ProductFeedback'[FeedbackType] = "Thumbs Down"),
			    COUNTROWS('ProductFeedback')
			)
		formatString: 0.0%;-0.0%;0.0%
		displayFolder: 💬 Compat
		lineageTag: ae4ffe2b-c0a1-0001-0001-000000000002

	/// CSAT = thumbs up / (thumbs up + thumbs down).
	measure 'CSAT Score' =
			DIVIDE(
			    CALCULATE(COUNTROWS('ProductFeedback'), 'ProductFeedback'[FeedbackType] = "Thumbs Up"),
			    CALCULATE(COUNTROWS('ProductFeedback'), 'ProductFeedback'[FeedbackType] IN {"Thumbs Up", "Thumbs Down"})
			)
		formatString: 0.0%;-0.0%;0.0%
		displayFolder: 💬 Compat
		lineageTag: ae4ffe2b-c0a1-0001-0001-000000000003

	/// Compatibility alias for the prior page binding (= Comment Rate).
	measure 'Feedback with Comment %' =
			DIVIDE(
			    SUM('ProductFeedback'[HasComment]),
			    COUNTROWS('ProductFeedback')
			)
		formatString: 0.0%;-0.0%;0.0%
		displayFolder: 💬 Compat
		lineageTag: ae4ffe2b-c0a1-0001-0001-000000000004

	/// Compatibility alias (= Thumbs Up Count).
	measure 'Thumbs Up' = CALCULATE(COUNTROWS('ProductFeedback'), 'ProductFeedback'[FeedbackType] = "Thumbs Up")
		formatString: #,0
		displayFolder: 💬 Compat
		lineageTag: ae4ffe2b-c0a1-0001-0001-000000000005

	/// Compatibility alias (= Thumbs Down Count).
	measure 'Thumbs Down' = CALCULATE(COUNTROWS('ProductFeedback'), 'ProductFeedback'[FeedbackType] = "Thumbs Down")
		formatString: #,0
		displayFolder: 💬 Compat
		lineageTag: ae4ffe2b-c0a1-0001-0001-000000000006

	/// Compatibility alias (= Distinct Agents with Feedback).
	measure 'Agents with Feedback' =
			CALCULATE(
			    DISTINCTCOUNT('ProductFeedback'[AgentName]),
			    'ProductFeedback'[IsAgentInteraction] = TRUE
			)
		formatString: #,0
		displayFolder: 💬 Compat
		lineageTag: ae4ffe2b-c0a1-0001-0001-000000000007

	measure 'Thumbs Up Count' =
			CALCULATE(
			    COUNTROWS('ProductFeedback'),
			    'ProductFeedback'[FeedbackType] = "Thumbs Up"
			)
		formatString: #,0
		displayFolder: 📊 Product Feedback
		lineageTag: aac9112a-bea8-40c7-ac11-1c464f2f92c4

	measure 'Thumbs Down Count' =
			CALCULATE(
			    COUNTROWS('ProductFeedback'),
			    'ProductFeedback'[FeedbackType] = "Thumbs Down"
			)
		formatString: #,0
		displayFolder: 📊 Product Feedback
		lineageTag: 0f887cc4-cb1c-4047-9690-2d75aabcaeef

	measure 'Satisfaction Rate' =
			DIVIDE(
			    CALCULATE(
			        COUNTROWS('ProductFeedback'),
			        'ProductFeedback'[FeedbackType] = "Thumbs Up"
			    ),
			    COUNTROWS('ProductFeedback'),
			    0
			)
		formatString: 0.0%
		displayFolder: 📊 Product Feedback
		lineageTag: a6f0e143-1042-4c78-a0c4-594a8a878ef9

	measure 'Feedback Users' = DISTINCTCOUNT('ProductFeedback'[UserId])
		formatString: #,0
		displayFolder: 📊 Product Feedback
		lineageTag: 1b57ae86-2b3e-4cf2-8286-7eaaa78b453f

	measure 'Comment Rate' =
			DIVIDE(
			    SUM('ProductFeedback'[HasComment]),
			    COUNTROWS('ProductFeedback'),
			    0
			)
		formatString: 0.0%
		displayFolder: 📊 Product Feedback
		lineageTag: e9c5a705-38ff-4b92-9af5-26625fefa2ce

	measure 'Agent Satisfaction Rate' =
			DIVIDE(
			    CALCULATE(
			        COUNTROWS('ProductFeedback'),
			        'ProductFeedback'[FeedbackType] = "Thumbs Up",
			        'ProductFeedback'[IsAgentInteraction] = TRUE
			    ),
			    CALCULATE(
			        COUNTROWS('ProductFeedback'),
			        'ProductFeedback'[IsAgentInteraction] = TRUE
			    ),
			    0
			)
		formatString: 0.0%
		displayFolder: 🤖 Agent Feedback
		lineageTag: a1b2c3d4-0002-0001-0003-000000000001

	measure 'Distinct Agents with Feedback' =
			CALCULATE(
			    DISTINCTCOUNT('ProductFeedback'[AgentName]),
			    'ProductFeedback'[IsAgentInteraction] = TRUE
			)
		formatString: #,0
		displayFolder: 🤖 Agent Feedback
		lineageTag: a1b2c3d4-0002-0001-0005-000000000001

	/// Top pain point: category with the lowest satisfaction — dynamic with filters
	measure '⚠️ Top Pain Point' =
			VAR CatTable =
			    ADDCOLUMNS(
			        VALUES('ProductFeedback'[FeedbackCategory]),
			        "SatRate", DIVIDE(
			            CALCULATE(COUNTROWS('ProductFeedback'), 'ProductFeedback'[FeedbackType] = "Thumbs Up"),
			            COUNTROWS('ProductFeedback'), 0
			        ),
			        "Total", COUNTROWS('ProductFeedback')
			    )
			VAR FilteredCats = FILTER(CatTable, [Total] >= 2 && [FeedbackCategory] <> "🧪 Testing" && [FeedbackCategory] <> "❓ Uncategorized")
			VAR WorstCat = TOPN(1, FilteredCats, [SatRate], ASC)
			RETURN
			IF(
			    COUNTROWS(FilteredCats) > 0,
			    MAXX(WorstCat, [FeedbackCategory]) & " — " & FORMAT(MAXX(WorstCat, [SatRate]), "0%") & " satisfaction (" & FORMAT(MAXX(WorstCat, [Total]), "#,0") & " feedback items)",
			    "Not enough data to identify pain points"
			)
		displayFolder: 📂 Feedback Categories
		lineageTag: a1b2c3d4-0003-0002-0004-000000000001

	/// Best performing category — dynamic with filters
	measure '✅ Top Strength' =
			VAR CatTable =
			    ADDCOLUMNS(
			        VALUES('ProductFeedback'[FeedbackCategory]),
			        "SatRate", DIVIDE(
			            CALCULATE(COUNTROWS('ProductFeedback'), 'ProductFeedback'[FeedbackType] = "Thumbs Up"),
			            COUNTROWS('ProductFeedback'), 0
			        ),
			        "Total", COUNTROWS('ProductFeedback')
			    )
			VAR FilteredCats = FILTER(CatTable, [Total] >= 2 && [FeedbackCategory] <> "🧪 Testing" && [FeedbackCategory] <> "❓ Uncategorized")
			VAR BestCat = TOPN(1, FilteredCats, [SatRate], DESC)
			RETURN
			IF(
			    COUNTROWS(FilteredCats) > 0,
			    MAXX(BestCat, [FeedbackCategory]) & " — " & FORMAT(MAXX(BestCat, [SatRate]), "0%") & " satisfaction (" & FORMAT(MAXX(BestCat, [Total]), "#,0") & " feedback items)",
			    "Not enough data to identify strengths"
			)
		displayFolder: 📂 Feedback Categories
		lineageTag: a1b2c3d4-0003-0002-0005-000000000001

	/// Dynamic narrative: summarises the top themes driving positive and negative feedback in current filter context
	measure '📊 Feedback Theme Summary' =
			VAR TotalFB = COUNTROWS('ProductFeedback')
			VAR TotalDown = CALCULATE(COUNTROWS('ProductFeedback'), 'ProductFeedback'[FeedbackType] = "Thumbs Down")
			VAR TotalUp = CALCULATE(COUNTROWS('ProductFeedback'), 'ProductFeedback'[FeedbackType] = "Thumbs Up")
			VAR CatStats =
			    ADDCOLUMNS(
			        FILTER(VALUES('ProductFeedback'[FeedbackCategory]),
			            [FeedbackCategory] <> "🧪 Testing" && [FeedbackCategory] <> "❓ Uncategorized"),
			        "CatTotal", CALCULATE(COUNTROWS('ProductFeedback')),
			        "CatUp", CALCULATE(COUNTROWS('ProductFeedback'), 'ProductFeedback'[FeedbackType] = "Thumbs Up"),
			        "CatDown", CALCULATE(COUNTROWS('ProductFeedback'), 'ProductFeedback'[FeedbackType] = "Thumbs Down"),
			        "CatSat", DIVIDE(
			            CALCULATE(COUNTROWS('ProductFeedback'), 'ProductFeedback'[FeedbackType] = "Thumbs Up"),
			            CALCULATE(COUNTROWS('ProductFeedback')), 0)
			    )
			VAR NegCats = FILTER(CatStats, [CatDown] > 0)
			VAR WorstCat = TOPN(1, NegCats, [CatDown], DESC)
			VAR WorstName = MAXX(WorstCat, [FeedbackCategory])
			VAR WorstDown = MAXX(WorstCat, [CatDown])
			VAR WorstSat = MAXX(WorstCat, [CatSat])
			VAR SecondWorst = TOPN(1, FILTER(NegCats, [FeedbackCategory] <> WorstName), [CatDown], DESC)
			VAR SecondName = MAXX(SecondWorst, [FeedbackCategory])
			VAR SecondDown = MAXX(SecondWorst, [CatDown])
			VAR PosCats = FILTER(CatStats, [CatUp] > 0)
			VAR BestCat = TOPN(1, PosCats, [CatSat], DESC)
			VAR BestName = MAXX(BestCat, [FeedbackCategory])
			VAR BestSat = MAXX(BestCat, [CatSat])
			VAR BestTotal = MAXX(BestCat, [CatTotal])
			VAR NegLine =
			    IF(COUNTROWS(NegCats) > 0,
			        "Most negative feedback is in " & WorstName & " (" & FORMAT(WorstDown, "#,0") & " thumbs down, " & FORMAT(WorstSat, "0%") & " sat.)" &
			        IF(COUNTROWS(SecondWorst) > 0,
			            ", followed by " & SecondName & " (" & FORMAT(SecondDown, "#,0") & " thumbs down).", "."),
			        "")
			VAR PosLine =
			    IF(COUNTROWS(PosCats) > 0,
			        "Strongest theme is " & BestName & " at " & FORMAT(BestSat, "0%") & " satisfaction (" & FORMAT(BestTotal, "#,0") & " items).",
			        "")
			VAR OverallLine = FORMAT(TotalFB, "#,0") & " feedback items across " & FORMAT(COUNTROWS(CatStats), "#,0") & " topics: " & FORMAT(DIVIDE(TotalUp, TotalFB, 0), "0%") & " overall satisfaction."
			RETURN
			IF(TotalFB > 0,
			    OverallLine & " " & PosLine & " " & NegLine,
			    "No feedback data in current selection.")
		displayFolder: 📂 Feedback Categories
		lineageTag: a1b2c3d4-0003-0003-0001-000000000001

	/// Emoji representation of FeedbackType for compact visuals
	column FeedbackEmoji =
			SWITCH(
			    'ProductFeedback'[FeedbackType],
			    "Thumbs Up", "👍",
			    "Thumbs Down", "👎",
			    "Smile", "😊",
			    'ProductFeedback'[FeedbackType]
			)
		lineageTag: a1b2c3d4-e5f6-7890-abcd-ef1234567890
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	/// Categorize feedback by topic based on the user prompt and comment content
	column FeedbackCategory =
			VAR PromptText = LOWER('ProductFeedback'[AIContextPrompt])
			VAR CommentText = LOWER('ProductFeedback'[Comment])
			VAR Combined = PromptText & " " & CommentText
			RETURN
			SWITCH(
			    TRUE(),
			    CONTAINSSTRING(Combined, "leave") || CONTAINSSTRING(Combined, "time off") || CONTAINSSTRING(Combined, "vacation") || CONTAINSSTRING(Combined, "请假"),
			        "🏖️ Leave & Time Off",
			    CONTAINSSTRING(Combined, "wellness") || CONTAINSSTRING(Combined, "wellbeing") || CONTAINSSTRING(Combined, "benefits") || CONTAINSSTRING(Combined, "health"),
			        "💚 Wellness & Benefits",
			    CONTAINSSTRING(Combined, "troubleshoot") || CONTAINSSTRING(Combined, "diagnostic") || CONTAINSSTRING(Combined, "not working") || CONTAINSSTRING(Combined, "won't turn on") || CONTAINSSTRING(Combined, "cache") || CONTAINSSTRING(Combined, "setup") || CONTAINSSTRING(Combined, "freezing"),
			        "🔧 Troubleshooting",
			    CONTAINSSTRING(Combined, "ticket") || CONTAINSSTRING(Combined, "incident") || CONTAINSSTRING(Combined, "support") || CONTAINSSTRING(Combined, "contact"),
			        "🎫 Support & Tickets",
			    CONTAINSSTRING(Combined, "outlook") || CONTAINSSTRING(Combined, "out of office") || CONTAINSSTRING(Combined, "email"),
			        "📧 Outlook & Email",
			    CONTAINSSTRING(Combined, "teams") || CONTAINSSTRING(Combined, "remote") || CONTAINSSTRING(Combined, "hybrid"),
			        "💬 Teams & Remote Work",
			    CONTAINSSTRING(Combined, "device") || CONTAINSSTRING(Combined, "laptop") || CONTAINSSTRING(Combined, "tablet") || CONTAINSSTRING(Combined, "mobile") || CONTAINSSTRING(Combined, "pc") || CONTAINSSTRING(Combined, "camera") || CONTAINSSTRING(Combined, "windows") || CONTAINSSTRING(Combined, "provision"),
			        "💻 Devices & Hardware",
			    CONTAINSSTRING(Combined, "excel") || CONTAINSSTRING(Combined, "power platform") || CONTAINSSTRING(Combined, "copilot") || CONTAINSSTRING(Combined, "coda") || CONTAINSSTRING(Combined, "onedrive") || CONTAINSSTRING(Combined, "sharepoint"),
			        "📱 Apps & Productivity",
			    CONTAINSSTRING(Combined, "project") || CONTAINSSTRING(Combined, "updates") || CONTAINSSTRING(Combined, "workspace"),
			        "📋 Projects & Search",
			    CONTAINSSTRING(Combined, "prompt") || CONTAINSSTRING(Combined, "generate"),
			        "✨ Prompt Crafting",
			    CONTAINSSTRING(Combined, "security") || CONTAINSSTRING(Combined, "password") || CONTAINSSTRING(Combined, "mfa") || CONTAINSSTRING(Combined, "permission") || CONTAINSSTRING(Combined, "access denied") || CONTAINSSTRING(Combined, "authentication") || CONTAINSSTRING(Combined, "locked out"),
			        "🔒 Security & Access",
			    CONTAINSSTRING(Combined, "training") || CONTAINSSTRING(Combined, "onboarding") || CONTAINSSTRING(Combined, "how do i") || CONTAINSSTRING(Combined, "how to") || CONTAINSSTRING(Combined, "tutorial") || CONTAINSSTRING(Combined, "learn"),
			        "📚 Training & Onboarding",
			    CONTAINSSTRING(Combined, "hallucin") || CONTAINSSTRING(Combined, "incorrect") || CONTAINSSTRING(Combined, "inaccurate") || CONTAINSSTRING(Combined, "wrong answer") || CONTAINSSTRING(Combined, "made up") || CONTAINSSTRING(Combined, "fabricat") || CONTAINSSTRING(Combined, "misleading"),
			        "🎯 AI Accuracy",
			    CONTAINSSTRING(Combined, "slow") || CONTAINSSTRING(Combined, "loading") || CONTAINSSTRING(Combined, "timeout") || CONTAINSSTRING(Combined, "lag") || CONTAINSSTRING(Combined, "performance") || CONTAINSSTRING(Combined, "error") || CONTAINSSTRING(Combined, "crash"),
			        "⚡ Performance & Errors",
			    CONTAINSSTRING(Combined, "network") || CONTAINSSTRING(Combined, "vpn") || CONTAINSSTRING(Combined, "wifi") || CONTAINSSTRING(Combined, "internet") || CONTAINSSTRING(Combined, "connectivity") || CONTAINSSTRING(Combined, "bandwidth"),
			        "🌐 Network & Connectivity",
			    CONTAINSSTRING(Combined, "report") || CONTAINSSTRING(Combined, "dashboard") || CONTAINSSTRING(Combined, "analytics") || CONTAINSSTRING(Combined, "power bi") || CONTAINSSTRING(Combined, "chart") || CONTAINSSTRING(Combined, "data"),
			        "📊 Data & Reporting",
			    CONTAINSSTRING(Combined, "test") || CONTAINSSTRING(Combined, "like test") || CONTAINSSTRING(Combined, "dislike"),
			        "🧪 Testing",
			    ISBLANK(PromptText) && (ISBLANK(CommentText) || LEN(CommentText) <= 5),
			        "❓ Uncategorized",
			    LEN(Combined) <= 10,
			        "❓ Uncategorized",
			    "📝 General"
			)
		lineageTag: a1b2c3d4-0003-0001-0001-000000000001
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

