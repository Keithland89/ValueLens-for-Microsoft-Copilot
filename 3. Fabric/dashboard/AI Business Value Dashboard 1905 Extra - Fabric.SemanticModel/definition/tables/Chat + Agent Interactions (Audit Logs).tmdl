	/// 29 May 2026 — Row-level delegation event identifier.
	/// One row = one delegated act of work. Aggregated by [Delegation Events]
	/// (DISTINCTCOUNT) to give a behavioural count of "AI did work on my behalf"
	/// rather than the inflated event-row count from the audit feed.
	/// Composite of user + day + agent/workflow/host so that repeated triggers
	/// of the same workflow on the same day for the same user collapse to one.
	column Delegation_Event_Key =
			'Chat + Agent Interactions (Audit Logs)'[Audit_UserId] & "|" &
			FORMAT('Chat + Agent Interactions (Audit Logs)'[InteractionDate], "yyyy-mm-dd") & "|" &
			COALESCE(
			    'Chat + Agent Interactions (Audit Logs)'[AgentName],
			    'Chat + Agent Interactions (Audit Logs)'[Workflow_Action],
			    'Chat + Agent Interactions (Audit Logs)'[AppHost],
			    "unknown-workflow"
			)
		dataType: string
		isHidden
		lineageTag: 79b4407c-bb2b-4fee-a270-ce9d1e72b60f
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	hierarchy 'Value_Outcome Hierarchy'
