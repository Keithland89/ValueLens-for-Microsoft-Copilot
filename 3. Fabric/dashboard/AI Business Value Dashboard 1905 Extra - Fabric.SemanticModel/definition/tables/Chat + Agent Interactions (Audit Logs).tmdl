	/// Dynamic ranking with current filters
	/// 📊 Updates with your selections
	/// 💡 Drill to see specific cohorts
	measure 'License Priority Rank (Dynamic)' =
			
			VAR CurrentScore = [License Priority Score (User)]
			VAR IsUserLevel = ISINSCOPE('Chat + Agent Interactions (Audit Logs)'[Audit_UserId])
			
			RETURN
			IF(
			    ISBLANK(CurrentScore),
			    BLANK(),
			    IF(
			        IsUserLevel,
			        // Rank users - ONLY those with unlicensed activity
			        RANKX(
			            FILTER(
			                ALLSELECTED('Chat + Agent Interactions (Audit Logs)'[Audit_UserId]),
			                CALCULATE(
			                    COUNTROWS('Chat + Agent Interactions (Audit Logs)'),
			                    'Chat + Agent Interactions (Audit Logs)'[License Status] = "Unlicensed"
			                ) > 0
			                && NOT(ISBLANK([License Priority Score (User)]))
			            ),
			            [License Priority Score (User)],
			            ,
			            DESC,
			            DENSE
			        ),
			        // Rank organizations - ONLY those with unlicensed users
			        RANKX(
			            FILTER(
			                ALLSELECTED('Chat + Agent Org Data'[Organization]),
			                CALCULATE(
			                    COUNTROWS('Chat + Agent Interactions (Audit Logs)'),
			                    'Chat + Agent Interactions (Audit Logs)'[License Status] = "Unlicensed"
			                ) > 0
			                && NOT(ISBLANK([License Priority Score (User)]))
			            ),
			            [License Priority Score (User)],
			            ,
			            DESC,
			            DENSE
			        )
			    )
			)
		formatString: 0
		lineageTag: d45ae6e2-c85c-41ff-99dc-7c4e4065c514

	/// Month-over-month % change in licensed user sessions. Positive = growth, negative = decline.
	measure 'Licensed Sessions MoM %' = ```
			VAR _Current = [Sessions (Licensed Users Only)]
			VAR _Previous = 
			    CALCULATE(
			        [Sessions (Licensed Users Only)],
			        DATEADD(Calendar[Date], -1, MONTH)
			    )
			RETURN
			    DIVIDE(_Current - _Previous, _Previous, BLANK())
			```
		formatString: +0.0%;-0.0%;0.0%
		displayFolder: 📈 Session Trends
		lineageTag: 52b866ef-cc4d-4c97-b0aa-d984f39a386c

	/// Month-over-month % change in unlicensed user sessions. Positive = growth, negative = decline.
	measure 'Unlicensed Sessions MoM %' = ```
			VAR _Current = [Sessions (Unlicensed Users Only)]
			VAR _Previous = 
			    CALCULATE(
			        [Sessions (Unlicensed Users Only)],
			        DATEADD(Calendar[Date], -1, MONTH)
			    )
			RETURN
			    DIVIDE(_Current - _Previous, _Previous, BLANK())
			```
		formatString: +0.0%;-0.0%;0.0%
		displayFolder: 📈 Session Trends
		lineageTag: da95b48f-ffc5-4cac-aebd-7eef5c686591

	/// User-facing AI task count: prompt rows only (excludes bot replies, traces,
	/// system events). What end-users would call "an AI interaction" — the input
	/// they sent. Used by Executive Headline and the Heatmap Toggle slicer label.
	measure 'AI Tasks' =
			CALCULATE(
			    COUNTROWS('Chat + Agent Interactions (Audit Logs)'),
			    'Chat + Agent Interactions (Audit Logs)'[Message_isPrompt] = "TRUE"
			)
		formatString: #,##0
		displayFolder: AI Fluency\Value Types
		lineageTag: ff030001-0001-0001-0001-000000000047

	/// Agent users
	measure 'Agent Users' = CALCULATE(DISTINCTCOUNT('Chat + Agent Interactions (Audit Logs)'[Audit_UserId]), NOT(ISBLANK('Chat + Agent Interactions (Audit Logs)'[AgentId])))
		formatString: #,##0
		displayFolder: AI Fluency\Agents - Value
		lineageTag: ff030001-0001-0001-0001-000000000153

	/// All Active Users: Every unique user who has used Copilot or Agents (licensed + unlicensed)
	measure 'All Active Users' = DISTINCTCOUNT('Chat + Agent Interactions (Audit Logs)'[Audit_UserId])
		formatString: #,##0
		displayFolder: AI Fluency\Adoption Funnel
		lineageTag: ff020001-0001-0001-0001-000000000204

	/// =============================================================================
	/// 5-STAGE MATURITY LADDER (Live, period-context — respects whatever date / org slicer
	/// is in effect). Replaces the legacy 3-stage Beginner/Developing/Proficient family.
	/// 16 May 2026 — upgraded for tighter thresholds + Inactive + Power cohorts.
	/// 
	/// 1 - Beginner   : 1-2 active days
	/// 2 - Developing : 3-7 active days AND ≥3 distinct enriched behaviours
	/// 3 - Habitual   : 8-14 active days AND ≥5 distinct enriched behaviours
	/// 4 - Power      : ≥15 active days, OR (≥10 days AND ≥30% Producing+Delegating AND uses an Agent)
	/// 0 - Inactive   : licensed but ZERO activity (handled by separate measure — see Inactive Users (Weekly))
	/// 
	/// Breadth uses Behavior_Enriched_Full (~40 categories) for sharper signal than
	/// Behavior_Category (~20). Power gate adds value-focus + agent-adoption to
	/// distinguish champions from steady daily users.
	/// =============================================================================
	/// Beginner Users: 1-2 active days in the latest rolling 4-week window
	/// (28 days ending at MAX(WeekStart) within the current filter context).
	/// On a card with no time axis this is the last 4 weeks in the data.
	/// On a weekly trend axis, each week shows its own 4-week look-back.
	measure 'Beginner Users' =
			VAR CurrentWeek = MAX('Chat + Agent Interactions (Audit Logs)'[WeekStart])
			VAR WindowStart = CurrentWeek - 21
			VAR UserStats =
			    ADDCOLUMNS(
			        CALCULATETABLE(
			            VALUES('Chat + Agent Interactions (Audit Logs)'[Audit_UserId]),
			            REMOVEFILTERS('Calendar'),
			            'Chat + Agent Interactions (Audit Logs)'[WeekStart] >= WindowStart,
			            'Chat + Agent Interactions (Audit Logs)'[WeekStart] <= CurrentWeek
			        ),
			        "Behaviors",  CALCULATE(DISTINCTCOUNT('Chat + Agent Interactions (Audit Logs)'[Behavior_Enriched_Full]), REMOVEFILTERS('Calendar'), 'Chat + Agent Interactions (Audit Logs)'[WeekStart] >= WindowStart, 'Chat + Agent Interactions (Audit Logs)'[WeekStart] <= CurrentWeek),
			        "ActiveDays", CALCULATE(DISTINCTCOUNT('Chat + Agent Interactions (Audit Logs)'[InteractionDate]),         REMOVEFILTERS('Calendar'), 'Chat + Agent Interactions (Audit Logs)'[WeekStart] >= WindowStart, 'Chat + Agent Interactions (Audit Logs)'[WeekStart] <= CurrentWeek)
			    )
			RETURN COUNTROWS(FILTER(UserStats, [ActiveDays] >= 1 && [ActiveDays] <= 2))
		formatString: #,##0
		displayFolder: AI Fluency\User Stages
		lineageTag: ff020001-0001-0001-0001-000000000301

	/// Developing Users: 3-7 active days AND ≥3 enriched behaviours in the latest
	/// rolling 4-week window. Multi-workflow learner.
	measure 'Developing Users' =
			VAR CurrentWeek = MAX('Chat + Agent Interactions (Audit Logs)'[WeekStart])
			VAR WindowStart = CurrentWeek - 21
			VAR UserStats =
			    ADDCOLUMNS(
			        CALCULATETABLE(
			            VALUES('Chat + Agent Interactions (Audit Logs)'[Audit_UserId]),
			            REMOVEFILTERS('Calendar'),
			            'Chat + Agent Interactions (Audit Logs)'[WeekStart] >= WindowStart,
			            'Chat + Agent Interactions (Audit Logs)'[WeekStart] <= CurrentWeek
			        ),
			        "Behaviors",  CALCULATE(DISTINCTCOUNT('Chat + Agent Interactions (Audit Logs)'[Behavior_Enriched_Full]), REMOVEFILTERS('Calendar'), 'Chat + Agent Interactions (Audit Logs)'[WeekStart] >= WindowStart, 'Chat + Agent Interactions (Audit Logs)'[WeekStart] <= CurrentWeek),
			        "ActiveDays", CALCULATE(DISTINCTCOUNT('Chat + Agent Interactions (Audit Logs)'[InteractionDate]),         REMOVEFILTERS('Calendar'), 'Chat + Agent Interactions (Audit Logs)'[WeekStart] >= WindowStart, 'Chat + Agent Interactions (Audit Logs)'[WeekStart] <= CurrentWeek)
			    )
			RETURN COUNTROWS(FILTER(UserStats, [ActiveDays] >= 3 && [ActiveDays] <= 7 && [Behaviors] >= 3))
		formatString: #,##0
		displayFolder: AI Fluency\User Stages
		lineageTag: ff020001-0001-0001-0001-000000000302

	/// =============================================================================
	/// 4-WEEK ROLLING STAGE COUNTS — for each week, looks back 28 days and assigns
	/// stage per user based on that window. Used by the User Maturity tracker chart.
	/// =============================================================================
	/// Alias of [Beginner Users] kept for visuals built before the default was
	/// changed to a rolling 4-week window. Use [Beginner Users] in new visuals.
	measure '4W Beginner Users' = [Beginner Users]
		formatString: #,##0
		displayFolder: AI Fluency\User Stages (4-Week Rolling)
		lineageTag: ff020001-0001-0001-0001-000000000501

	/// Alias of [Developing Users]. Same as the default since rolling 4-week
	/// became the default semantics on 16 May 2026.
	measure '4W Developing Users' = [Developing Users]
		formatString: #,##0
		displayFolder: AI Fluency\User Stages (4-Week Rolling)
		lineageTag: ff020001-0001-0001-0001-000000000502

	/// =============================================================================
	/// Stage Profile: Top org for current stage context
	measure 'Stage Top Org' =
			VAR OrgTable =
			    ADDCOLUMNS(
			        VALUES('Chat + Agent Org Data'[Organization]),
			        "UserCount",
			        CALCULATE(DISTINCTCOUNT('Chat + Agent Interactions (Audit Logs)'[Audit_UserId]))
			    )
			VAR TopRow = TOPN(1, OrgTable, [UserCount], DESC)
			RETURN MAXX(TopRow, 'Chat + Agent Org Data'[Organization])
		displayFolder: AI Fluency\Stage Profiles
		lineageTag: ff020001-0001-0001-0001-000000000602

	/// Total human-equivalent hours: what AI is handling that humans would otherwise do
	/// Sources: McKinsey 2023, NBER (Brynjolfsson/Noy&Zhang), BCG/Harvard, Forrester TEI 2024
	measure 'Human Equivalent Hours' =
			SUMX(
			    FILTER(
			        'Chat + Agent Interactions (Audit Logs)',
			        'Chat + Agent Interactions (Audit Logs)'[Message_isPrompt] = "TRUE"
			    ),
			    DIVIDE(
			        RELATED('Human Time Estimates'[Human Baseline (min)]),
			        60,
			        0
			    )
			)
		formatString: #,##0.0
		displayFolder: AI Fluency\Time Savings
		lineageTag: ff060001-0001-0001-0001-000000000010

	/// Estimated hours saved (30% efficiency gain — Noy & Zhang, Science 2023)
	measure 'Estimated Hours Saved' = [Human Equivalent Hours] * 0.70
		formatString: #,##0.0
		displayFolder: AI Fluency\Time Savings
		lineageTag: ff060001-0001-0001-0001-000000000011

	/// Average augmented skills per user
	measure 'Avg Skills Per User' = ```
			
			    AVERAGEX(
			        VALUES('Chat + Agent Interactions (Audit Logs)'[Audit_UserId]),
			        CALCULATE(
			            DISTINCTCOUNT('Chat + Agent Interactions (Audit Logs)'[Behavior_Category]),
			            'Chat + Agent Interactions (Audit Logs)'[Message_isPrompt] = "TRUE"
			        )
			    )
			```
		formatString: #,##0.0
		displayFolder: AI Fluency\Augmented Skills
		lineageTag: ff080001-0001-0001-0001-000000000014

	measure 'Hours Saved Per User' = ```
			
			    DIVIDE(
			        [Estimated Hours Saved],
			        DISTINCTCOUNT('Chat + Agent Interactions (Audit Logs)'[Audit_UserId]),
			        0
			    )
			```
		displayFolder: AI Fluency\Time Savings
		lineageTag: f6e1f84b-1a34-4bc7-b296-c5a585fba0ad

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	/// Productive AI Rate: % of interactions that are Creating + Executing + Orchestrating
	measure 'Productive AI Rate' =
			VAR ProductiveCount =
			    CALCULATE(
			        COUNTROWS('Chat + Agent Interactions (Audit Logs)'),
			        'Chat + Agent Interactions (Audit Logs)'[Message_isPrompt] = "TRUE",
			        'Chat + Agent Interactions (Audit Logs)'[Usage_Mode] IN {"4 - Producing"}
			    )
			VAR TotalCount =
			    CALCULATE(
			        COUNTROWS('Chat + Agent Interactions (Audit Logs)'),
			        'Chat + Agent Interactions (Audit Logs)'[Message_isPrompt] = "TRUE"
			    )
			RETURN DIVIDE(ProductiveCount, TotalCount, 0)
		formatString: 0%;-0%;0%
		displayFolder: AI Fluency\Usage Modes
		lineageTag: ff030001-0001-0001-0001-000000000022

	measure 'Usage Mode Share' = ```
			
			    DIVIDE(
			        CALCULATE(
			            COUNTROWS('Chat + Agent Interactions (Audit Logs)'),
			            'Chat + Agent Interactions (Audit Logs)'[Message_isPrompt] = "TRUE"
			        ),
			        CALCULATE(
			            COUNTROWS('Chat + Agent Interactions (Audit Logs)'),
			            'Chat + Agent Interactions (Audit Logs)'[Message_isPrompt] = "TRUE",
			            REMOVEFILTERS('Chat + Agent Interactions (Audit Logs)'[Usage_Mode])
			        ),
			        0
			    )
			```
		formatString: 0.00%;-0.00%;0.00%
		displayFolder: AI Fluency\Usage Modes
		lineageTag: 31b0953a-8e21-43c7-9609-9bd33c63ec8a

	/// % of users in current stage leveraging this Usage Mode, Behavior, or Breakdown (works at all drill levels)
	measure '% of Users in Stage' = ```
			
			    VAR UsersInContext =
			        CALCULATE(
			            DISTINCTCOUNT('Chat + Agent Interactions (Audit Logs)'[Audit_UserId]),
			            'Chat + Agent Interactions (Audit Logs)'[Message_isPrompt] = "TRUE"
			        )
			    VAR TotalUsersInStage =
			        CALCULATE(
			            DISTINCTCOUNT('Chat + Agent Interactions (Audit Logs)'[Audit_UserId]),
			            'Chat + Agent Interactions (Audit Logs)'[Message_isPrompt] = "TRUE",
			            REMOVEFILTERS('Chat + Agent Interactions (Audit Logs)'[Usage_Mode]),
			            REMOVEFILTERS('Chat + Agent Interactions (Audit Logs)'[Behavior_Enriched_Full]),
			            REMOVEFILTERS('Chat + Agent Interactions (Audit Logs)'[Behavior_Category]),
			            REMOVEFILTERS('Chat + Agent Interactions (Audit Logs)'[Value_Outcome]),
			            REMOVEFILTERS('Chat + Agent Interactions (Audit Logs)'[Efficiency_Breakdown]),
			            REMOVEFILTERS('Chat + Agent Interactions (Audit Logs)'[Expertise_Role])
			        )
			    RETURN DIVIDE(UsersInContext, TotalUsersInStage, 0)
			```
		formatString: 0.0%;-0.0%;0.0%
		displayFolder: AI Fluency\Usage Modes
		lineageTag: ff030001-0001-0001-0001-000000000029

	/// Specialist jobs performed
	measure 'New Expertise - Jobs' =
			CALCULATE(
			    COUNTROWS('Chat + Agent Interactions (Audit Logs)'),
			    'Chat + Agent Interactions (Audit Logs)'[Message_isPrompt] = "TRUE",
			    NOT(ISBLANK('Chat + Agent Interactions (Audit Logs)'[Expertise_Role]))
			)
		formatString: #,##0
		displayFolder: AI Fluency\4 - New Expertise
		lineageTag: ff030001-0001-0001-0001-000000000113

	/// Users accessing specialist capabilities
	measure 'New Expertise - Users' =
			CALCULATE(
			    DISTINCTCOUNT('Chat + Agent Interactions (Audit Logs)'[Audit_UserId]),
			    'Chat + Agent Interactions (Audit Logs)'[Message_isPrompt] = "TRUE",
			    NOT(ISBLANK('Chat + Agent Interactions (Audit Logs)'[Expertise_Role]))
			)
		formatString: #,##0
		displayFolder: AI Fluency\4 - New Expertise
		lineageTag: ff030001-0001-0001-0001-000000000115

	/// Expert hours delivered per week (org total)
	measure 'New Expertise - Hours Per Week' =
			isHidden
				VAR TotalHrs = CALCULATE([Human Equivalent Hours], NOT(ISBLANK('Chat + Agent Interactions (Audit Logs)'[Expertise_Role])))
				VAR Weeks = DISTINCTCOUNT('Chat + Agent Interactions (Audit Logs)'[WeekStart])
				RETURN DIVIDE(TotalHrs, Weeks, 0)
			formatString: #,##0.0
			displayFolder: AI Fluency\4 - New Expertise
			lineageTag: ff030001-0001-0001-0001-000000000116
		lineageTag: 21a2a7b3-7c0e-43a3-bf8f-9cd40a9ada61

	/// ════════════════════════════════════════════
	/// VALUE STORY 1: TIME SAVED (all interactions — everything saves time)
	/// "How much faster are we?" — universal metric across every interaction
	/// ════════════════════════════════════════════
	/// Total hours saved across ALL interactions
	measure 'Efficiency - Hours Saved' = [Human Equivalent Hours]
		formatString: #,##0.0
		displayFolder: AI Fluency\1 - Efficiency
		lineageTag: ff030001-0001-0001-0001-000000000100

	/// Hours saved per active user per active week
	measure 'Efficiency - Hours Per User Per Week' =
			AVERAGEX(
			    VALUES('Chat + Agent Interactions (Audit Logs)'[WeekStart]),
			    DIVIDE([Human Equivalent Hours], DISTINCTCOUNT('Chat + Agent Interactions (Audit Logs)'[Audit_UserId]), 0)
			)
		formatString: #,##0.0
		displayFolder: AI Fluency\1 - Efficiency
		lineageTag: ff030001-0001-0001-0001-000000000101

	/// Hours saved per week (org total)
	measure 'Efficiency - Hours Per Week' = DIVIDE([Human Equivalent Hours], DISTINCTCOUNT('Chat + Agent Interactions (Audit Logs)'[WeekStart]), 0)
		formatString: 0.00
		displayFolder: AI Fluency\1 - Efficiency
		lineageTag: ff030001-0001-0001-0001-000000000102

	/// Hours saved label "Xh Ym"
	measure 'Efficiency - Label' =
			VAR Hrs = [Efficiency - Hours Per User Per Week]
			VAR WholeHours = INT(Hrs)
			VAR Mins = ROUND((Hrs - WholeHours) * 60, 0)
			RETURN IF(WholeHours > 0, FORMAT(WholeHours, "0") & "h " & FORMAT(Mins, "0") & "m", FORMAT(Mins, "0") & "m")
		displayFolder: AI Fluency\1 - Efficiency
		lineageTag: ff030001-0001-0001-0001-000000000103

	/// Work items created per week (org total)
	measure 'Work Created - Per Week' =
			DIVIDE(
			    CALCULATE(COUNTROWS('Chat + Agent Interactions (Audit Logs)'), 'Chat + Agent Interactions (Audit Logs)'[Usage_Mode] IN {"4 - Producing"}),
			    DISTINCTCOUNT('Chat + Agent Interactions (Audit Logs)'[WeekStart]),
			    0
			)
		formatString: #,##0
		displayFolder: AI Fluency\2 - Work Created
		lineageTag: ff030001-0001-0001-0001-000000000106

	/// Specialist roles active
	measure 'New Expertise - Roles' =
			CALCULATE(
			    DISTINCTCOUNT('Chat + Agent Interactions (Audit Logs)'[Expertise_Role]),
			    'Chat + Agent Interactions (Audit Logs)'[Message_isPrompt] = "TRUE",
			    NOT(ISBLANK('Chat + Agent Interactions (Audit Logs)'[Expertise_Role]))
			)
		formatString: #,##0
		displayFolder: AI Fluency\4 - New Expertise
		lineageTag: ff030001-0001-0001-0001-000000000114

	/// 5-stage maturity ladder (Inactive → Beginner → Developing → Habitual → Power).
	/// The (Weekly) measures are aliases of the rolling-4-week defaults. When placed
	/// on a chart with WeekStart on the X-axis, each column shows the rolling 4-week
	/// count ending at that week (i.e. each user is classified by their activity in
	/// the 28 days ending at that week). Kept as aliases so existing visuals work.
	measure 'Beginner Users (Weekly)' = [Beginner Users]
		formatString: #,##0
		displayFolder: AI Fluency\Maturity Score
		lineageTag: ff030001-0001-0001-0001-000000000131

	/// Alias of [Developing Users].
	measure 'Developing Users (Weekly)' = [Developing Users]
		formatString: #,##0
		displayFolder: AI Fluency\Maturity Score
		lineageTag: ff030001-0001-0001-0001-000000000132

	/// Total AI actions performed by agents (Agent Value Tracker — no Environment filter needed)
	measure 'Agent AI Tasks' = CALCULATE(COUNTROWS('Chat + Agent Interactions (Audit Logs)'), NOT(ISBLANK('Chat + Agent Interactions (Audit Logs)'[AgentId])))
		formatString: #,##0
		displayFolder: AI Fluency\Agents - Value
		lineageTag: ff030001-0001-0001-0001-000000000139

	/// Agent AI actions per user per week (both sides filtered to agent rows)
	measure 'Agent AI Tasks Per User Per Week' =
			AVERAGEX(
			    CALCULATETABLE(VALUES('Chat + Agent Interactions (Audit Logs)'[WeekStart]), NOT(ISBLANK('Chat + Agent Interactions (Audit Logs)'[AgentId]))),
			    DIVIDE(
			        CALCULATE(COUNTROWS('Chat + Agent Interactions (Audit Logs)'), NOT(ISBLANK('Chat + Agent Interactions (Audit Logs)'[AgentId]))),
			        CALCULATE(DISTINCTCOUNT('Chat + Agent Interactions (Audit Logs)'[Audit_UserId]), NOT(ISBLANK('Chat + Agent Interactions (Audit Logs)'[AgentId]))),
			        0
			    )
			)
		formatString: #,##0.0
		displayFolder: AI Fluency\Agents - Value
		lineageTag: ff030001-0001-0001-0001-000000000140

	/// Total Copilot AI actions (Copilot Value Tracker — no Environment filter needed)
	measure 'Copilot AI Tasks' = CALCULATE(COUNTROWS('Chat + Agent Interactions (Audit Logs)'), 'Chat + Agent Interactions (Audit Logs)'[Environment] = "Licensed")
		formatString: #,##0
		displayFolder: AI Fluency\Copilot - Value
		lineageTag: ff030001-0001-0001-0001-000000000154

	/// Copilot AI actions per user per week
	measure 'Copilot AI Tasks Per User Per Week' =
			AVERAGEX(
			    CALCULATETABLE(VALUES('Chat + Agent Interactions (Audit Logs)'[WeekStart]), 'Chat + Agent Interactions (Audit Logs)'[Environment] = "Licensed"),
			    DIVIDE(
			        CALCULATE(COUNTROWS('Chat + Agent Interactions (Audit Logs)'), 'Chat + Agent Interactions (Audit Logs)'[Environment] = "Licensed"),
			        CALCULATE(DISTINCTCOUNT('Chat + Agent Interactions (Audit Logs)'[Audit_UserId]), 'Chat + Agent Interactions (Audit Logs)'[Environment] = "Licensed"),
			        0
			    )
			)
		formatString: #,##0.0
		displayFolder: AI Fluency\Copilot - Value
		lineageTag: ff030001-0001-0001-0001-000000000155

	/// Copilot users (licensed)
	measure 'Copilot Users' = CALCULATE(DISTINCTCOUNT('Chat + Agent Interactions (Audit Logs)'[Audit_UserId]), 'Chat + Agent Interactions (Audit Logs)'[Environment] = "Licensed")
		formatString: #,##0
		displayFolder: AI Fluency\Copilot - Value
		lineageTag: ff030001-0001-0001-0001-000000000160

	/// Copilot tasks per active Copilot user (entire period)
	measure 'Copilot AI Tasks Per User' =
			DIVIDE(
			    [Copilot AI Tasks],
			    [Copilot Users],
			    0
			)
		formatString: #,##0.0
		displayFolder: AI Fluency\Copilot - Value
		lineageTag: ff030001-0001-0001-0001-000000000162

	/// Agent tasks per active agent user (entire period)
	measure 'Agent AI Tasks Per User' =
			DIVIDE(
			    [Agent AI Tasks],
			    [Agent Users],
			    0
			)
		formatString: #,##0.0
		displayFolder: AI Fluency\Agents - Value
		lineageTag: ff030001-0001-0001-0001-000000000163

	/// Total AI tasks by unlicensed chat users (Unlicensed Value Tracker — no Environment filter needed)
	measure 'Unlicensed AI Tasks' = CALCULATE(COUNTROWS('Chat + Agent Interactions (Audit Logs)'), 'Chat + Agent Interactions (Audit Logs)'[Environment] = "Unlicensed")
		formatString: #,##0
		displayFolder: AI Fluency\Unlicensed - Value
		lineageTag: ff030001-0001-0001-0001-000000000164

	/// Unlicensed AI tasks per user per week (only active unlicensed users)
	measure 'Unlicensed AI Tasks Per User Per Week' =
			AVERAGEX(
			    CALCULATETABLE(VALUES('Chat + Agent Interactions (Audit Logs)'[WeekStart]), 'Chat + Agent Interactions (Audit Logs)'[Environment] = "Unlicensed"),
			    DIVIDE(
			        CALCULATE(COUNTROWS('Chat + Agent Interactions (Audit Logs)'), 'Chat + Agent Interactions (Audit Logs)'[Environment] = "Unlicensed"),
			        CALCULATE(DISTINCTCOUNT('Chat + Agent Interactions (Audit Logs)'[Audit_UserId]), 'Chat + Agent Interactions (Audit Logs)'[Environment] = "Unlicensed"),
			        0
			    )
			)
		formatString: #,##0.0
		displayFolder: AI Fluency\Unlicensed - Value
		lineageTag: ff030001-0001-0001-0001-000000000165

	/// Unlicensed tasks per active user (entire period)
	measure 'Unlicensed AI Tasks Per User' =
			DIVIDE(
			    [Unlicensed AI Tasks],
			    CALCULATE(DISTINCTCOUNT('Chat + Agent Interactions (Audit Logs)'[Audit_UserId]), 'Chat + Agent Interactions (Audit Logs)'[Environment] = "Unlicensed"),
			    0
			)
		formatString: #,##0.0
		displayFolder: AI Fluency\Unlicensed - Value
		lineageTag: ff030001-0001-0001-0001-000000000167

	/// AI Assisted Value: Hours x Hourly Value x Penalty Factor (all adjustable via slicers).
	/// Returns BLANK when the Hourly Value box is left empty (no default rate is assumed).
	measure 'AI Assisted Value' = ```
			
			    IF(
			        ISBLANK(SELECTEDVALUE('Hourly Value'[Hourly Value])),
			        BLANK(),
			        [Human Equivalent Hours]
			        * [Reinvestment Rate (Forrester TEI)]
			        * [Hourly Value Value]
			        * [Penalty Factor Value]
			    )
			
			```
		formatString: $#,##0
		displayFolder: AI Fluency\ROI
		lineageTag: ff0b0001-0001-0001-0001-000000000020

	/// Copilot License Investment: PPUPM x Licensed Users x Months (fixed cost regardless of filter)
	measure 'Copilot License Investment' =
			SUMX(
			    VALUES('Chat + Agent Interactions (Audit Logs)'[MonthStart]),
			    [AI PPUPM Value] *
			    CALCULATE(
			        DISTINCTCOUNT('Chat + Agent Interactions (Audit Logs)'[Audit_UserId]),
			        'Chat + Agent Interactions (Audit Logs)'[License Status] = "M365 Copilot Licensed"
			    )
			)
		formatString: $#,##0
		displayFolder: AI Fluency\ROI
		lineageTag: ff0b0001-0001-0001-0001-000000000022

	/// Top Value Outcome by hours saved (dynamic to filters)
	measure 'Top Value Outcome' =
			MAXX(
			    TOPN(1,
			        ADDCOLUMNS(
			            VALUES('Chat + Agent Interactions (Audit Logs)'[Value_Outcome]),
			            "@Hrs", [Human Equivalent Hours]
			        ),
			        [@Hrs], DESC
			    ),
			    'Chat + Agent Interactions (Audit Logs)'[Value_Outcome]
			)
		displayFolder: AI Fluency\1 - Efficiency
		lineageTag: ff030001-0001-0001-0001-000000000175

	measure 'AI Assisted Value Per Week' =
			
			IF(
			    ISBLANK([AI Assisted Value]),
			    BLANK(),
			    DIVIDE(
			        [AI Assisted Value],
			        DISTINCTCOUNT('Chat + Agent Interactions (Audit Logs)'[WeekStart]),
			        0
			    )
			)
		formatString: $#,##0
		displayFolder: AI Fluency\ROI
		lineageTag: 2769b48a-57a1-4acb-8a8b-6e3d70626ad7

		annotation PBI_FormatHint = {"isCustom":true}

	/// Projected annualised value at current adoption (observed value scaled from visible weeks to 52)
	measure 'Projected Annualised Value' =
			VAR WeeksInView = DISTINCTCOUNT('Chat + Agent Interactions (Audit Logs)'[WeekStart])
			VAR AnnualFactor = DIVIDE(52, MAX(WeeksInView, 1), 0)
			RETURN [AI Assisted Value] * AnnualFactor
		formatString: $#,##0
		displayFolder: AI Fluency\Functional Value
		lineageTag: ff0c0001-0001-0001-0001-000000000044

	/// Autonomy Mix: % of hours saved where humans worked alongside an agent (Pattern 2 - Human uses agent, reviews & approves).
	/// Any agent activity except Cowork (Cowork is reported separately in Pattern 3).
	/// 17 May 2026 — denominator and numerator both REMOVEFILTERS the Environment slicer so the mix is
	/// reported relative to ALL activity (Licensed + Unlicensed). Without this the percentage would
	/// swing wildly with the cohort slicer and undercount agent reach when a viewer clicks Unlicensed.
	measure 'Agent-Assisted Mix %' =
			VAR Numerator =
			    CALCULATE(
			        [Human Equivalent Hours],
			        REMOVEFILTERS('Chat + Agent Interactions (Audit Logs)'[Environment]),
			        'Chat + Agent Interactions (Audit Logs)'[Is_Agent_Activity] = TRUE(),
			        'Chat + Agent Interactions (Audit Logs)'[Environment] <> "Cowork"
			    )
			VAR Denominator =
			    CALCULATE(
			        [Human Equivalent Hours],
			        REMOVEFILTERS('Chat + Agent Interactions (Audit Logs)'[Environment])
			    )
			RETURN DIVIDE(Numerator, Denominator, 0)
		formatString: 0.0%
		displayFolder: AI Fluency\Autonomy Mix
		lineageTag: ff0d0001-0001-0001-0001-000000000002

	/// Net ROI ($): AI Assisted Value minus Copilot License Investment (dollar benefit after cost)
	measure 'Net ROI ($)' = [AI Assisted Value] - [Copilot License Investment]
		formatString: $#,##0
		displayFolder: AI Fluency\ROI
		lineageTag: ff0b0001-0001-0001-0001-000000000031

	/// Activity Share: this prompt count ÷ all prompts in the current OUTSIDE filter
	/// context (Date, Org, License, Agent slicers etc.) but ignoring whatever
	/// dimension is being charted inside the visual.
	/// 
	/// Uses ALLSELECTED('Chat + Agent Interactions (Audit Logs)') so it is robust
	/// when ANY column from that table is dropped onto a visual's Axis, Legend or
	/// Detail bucket — including Behavior_Enriched_Full, Workflow_Action,
	/// Usage_Mode, Value_Outcome, Expertise_Role, Efficiency_Breakdown, etc.
	/// 
	/// Previously hand-maintained REMOVEFILTERS column list silently broke when
	/// a new dimension (e.g., Workflow_Action) was added as a treemap Detail —
	/// the denominator was no longer the global total, causing parent rectangles
	/// to double in size. ALLSELECTED removes the maintenance burden.
	measure 'Activity Share' = ```
			
			    DIVIDE(
			        CALCULATE(
			            COUNTROWS('Chat + Agent Interactions (Audit Logs)'),
			            'Chat + Agent Interactions (Audit Logs)'[Message_isPrompt] = "TRUE"
			        ),
			        CALCULATE(
			            COUNTROWS('Chat + Agent Interactions (Audit Logs)'),
			            'Chat + Agent Interactions (Audit Logs)'[Message_isPrompt] = "TRUE",
			            ALLSELECTED('Chat + Agent Interactions (Audit Logs)')
			        ),
			        0
			    )
			```
		formatString: 0.00%;-0.00%;0.00%
		lineageTag: be5a75f5-b45a-4db7-a70f-8f67dd6ba89f

