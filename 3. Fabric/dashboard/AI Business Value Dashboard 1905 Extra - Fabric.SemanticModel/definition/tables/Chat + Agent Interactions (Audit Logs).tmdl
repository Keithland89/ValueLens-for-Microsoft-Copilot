	/// =============================================================================
	/// LICENSE PRIORITY v2 (17 May 2026)
	/// 
	/// Simple 2-signal score for ranking unlicensed users as Copilot license
	/// candidates. Each signal is normalised to a clear benchmark, capped at 1,
	/// then weighted to a 0-100 scale that maps cleanly onto action tiers.
	/// 
	/// How much (60%) — Median Unlicensed AI Tasks per User per Week
	/// (full marks = 30 tasks/week, i.e. ~6 per workday)
	/// How often (40%) — Median Active Days per User per Week (Unlicensed)
	/// (full marks = 5 days/week, i.e. every working day)
	/// 
	/// Score ≥ 70 → 🟢 Ready Now      | 50–69 → 🟡 Strong Candidate
	/// Score 30–49 → 🟠 Watch         | <30   → 🔴 Not Ready
	/// 
	/// Confidence flag (High / Medium / Low) reflects weeks of data behind the
	/// score — stops one-good-week wonders outranking steady users.
	/// 
	/// Previous sessions-based formula preserved as License Priority Score
	/// (User) [v1 Legacy] for back-compat with pre-existing visuals/bookmarks.
	/// =============================================================================
	/// License recommendation score (0-100). Higher = stronger license candidate.
	measure 'License Priority Score (User)' =
			VAR TasksPW = [Median Unlicensed AI Tasks Per User Per Week]
			VAR DaysPW  = [Median Chat + Agent Active Days Per User Per Week (Unlicensed)]
			VAR VolumeScore = MIN(DIVIDE(TasksPW, 30, 0), 1)
			VAR DaysScore   = MIN(DIVIDE(DaysPW,  5, 0), 1)
			RETURN
			    IF(
			        TasksPW <= 0 || DaysPW <= 0,
			        BLANK(),
			        ROUND(60 * VolumeScore + 40 * DaysScore, 0)
			    )
		formatString: 0
		displayFolder: License Readiness
		lineageTag: ce411199-5b7e-4555-bdaf-dd5d6c00aa3e

		annotation PBI_FormatHint = {"isGeneralNumber":true}

