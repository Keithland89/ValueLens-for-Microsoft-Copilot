	column Behavior_Plausible = ```
			
			    VAR lic = 'Chat + Agent Interactions (Audit Logs)'[License Status]
			    VAR beh = 'Chat + Agent Interactions (Audit Logs)'[Behavior_Category]
			    VAR UnlicensedPlausible = {
			        "General Chat",
			        "Web Searching",
			        "PDF Analysis",
			        "Document Summarising",
			        "Image / Media Analysis",
			        "Image Generation",
			        "Code Analysis",
			        "Translation"
			    }
			    RETURN
			        IF(
			            lic = "M365 Copilot Licensed" || beh IN UnlicensedPlausible,
			            beh,
			            SWITCH(
			                TRUE(),
			                beh IN {"Email Summarising", "Email Drafting"},                 "Free Chat Workaround (pasting Email)",
			                beh IN {"Excel Assistance", "Spreadsheet Review", "Data Querying"}, "Free Chat Workaround (pasting Spreadsheet/Data)",
			                beh IN {"Meeting Prep", "Meeting Scheduling"},                  "Free Chat Workaround (pasting Meeting info)",
			                beh = "Teams Messaging",                                        "Free Chat Workaround (pasting Teams content)",
			                beh IN {"Enterprise Searching", "People Lookup"},               "Free Chat Workaround (pasting Enterprise data)",
			                beh IN {"Running a Workflow", "Task Management"},               "Free Chat Workaround (pasting Workflow)",
			                beh = "Real-time Collaboration",                                "Free Chat Workaround (pasting Loop content)",
			                beh = "Code Writing",                                           "Free Chat Workaround (pasting Code)",
			                beh = "Video Summarising",                                      "Free Chat Workaround (uploading Video)",
			                "Free Chat Workaround (Other)"
			            )
			        )
			
			```
		lineageTag: 4fd75001-ae51-4382-861f-12ca79d07d41
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	/// Drill-down for "Running a Workflow" rows — what is the workflow actually doing?
	/// BLANK for all non-workflow rows. Categorises the AccessedResource_Action verb
	/// into 7 buckets so the Agents cohort can be broken down by workflow purpose
	/// (Sending, Creating, Invoking, Updating, Reading, Deleting, or Other).
	/// AppHost is used as a last-resort splitter when no action verb is logged.
	column Workflow_Action =
			VAR behavior  = 'Chat + Agent Interactions (Audit Logs)'[Behavior_Enriched_Full]
			VAR resAction = LOWER('Chat + Agent Interactions (Audit Logs)'[AccessedResource_Action])
			VAR appHost   = LOWER('Chat + Agent Interactions (Audit Logs)'[AppHost])
			RETURN
			    IF(behavior <> "Running a Workflow", "",
			    IF(CONTAINSSTRING(resAction, "send")   || CONTAINSSTRING(resAction, "post")    || CONTAINSSTRING(resAction, "notify"),  "Sending / Notifying",
			    IF(CONTAINSSTRING(resAction, "create") || CONTAINSSTRING(resAction, "draft")   || CONTAINSSTRING(resAction, "write")   || CONTAINSSTRING(resAction, "add"),    "Creating Content",
			    IF(CONTAINSSTRING(resAction, "invoke") || CONTAINSSTRING(resAction, "execute") || CONTAINSSTRING(resAction, "trigger") || CONTAINSSTRING(resAction, "run"),    "Invoking / Triggering",
			    IF(CONTAINSSTRING(resAction, "update") || CONTAINSSTRING(resAction, "patch")   || CONTAINSSTRING(resAction, "modify")  || CONTAINSSTRING(resAction, "set"),    "Updating Records",
			    IF(CONTAINSSTRING(resAction, "read")   || CONTAINSSTRING(resAction, "get")    || CONTAINSSTRING(resAction, "list")    || CONTAINSSTRING(resAction, "fetch"),  "Reading Data",
			    IF(CONTAINSSTRING(resAction, "delete") || CONTAINSSTRING(resAction, "remove"),                                                                                "Deleting / Removing",
			    IF(appHost = "autonomous",                                                                                                                                    "Autonomous Run (no action logged)",
			    IF(appHost = "logic app",                                                                                                                                     "Logic App Run (no action logged)",
			    "Workflow (other)")))))))))
		dataType: string
		lineageTag: ff030001-0001-0001-0001-000000000202
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	/// Is_Agent_Activity — TRUE for any agent / autonomous / workflow audit row,
	/// regardless of who ran it. Lets the Agents cohort overlap with Licensed / Unlicensed
	/// in slicers and measures (a licensed user's workflow run is BOTH Licensed AND Agent).
	/// 
	/// TRUE when ANY of:
	/// - AgentName is populated, OR
	/// - AgentId is populated, OR
	/// - AppHost IN {autonomous, logic app}, OR
	/// - AccessedResource_Type IN {flow, connector}
	/// 
	/// Note: Cowork rows have AgentName containing "cowork", so Is_Agent_Activity is also
	/// TRUE for Cowork rows (Cowork ⊂ Agents conceptually).
	column Is_Agent_Activity = ```
			
			    VAR hasAgent     = NOT(ISBLANK('Chat + Agent Interactions (Audit Logs)'[AgentName])) && TRIM('Chat + Agent Interactions (Audit Logs)'[AgentName]) <> ""
			    VAR hasAgentId   = NOT(ISBLANK('Chat + Agent Interactions (Audit Logs)'[AgentId]))   && TRIM('Chat + Agent Interactions (Audit Logs)'[AgentId])   <> ""
			    VAR appHost      = LOWER('Chat + Agent Interactions (Audit Logs)'[AppHost])
			    VAR resType      = LOWER('Chat + Agent Interactions (Audit Logs)'[AccessedResource_Type])
			    VAR isAutonomous = appHost IN {"autonomous", "logic app"} || resType IN {"flow", "connector"}
			    RETURN IF(hasAgent || hasAgentId || isAutonomous, TRUE(), FALSE())
			
			```
		dataType: boolean
		formatString: """TRUE"";""TRUE"";""FALSE"""
		lineageTag: ff030001-0001-0001-0001-000000000005
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	/// Agent Filter — slicer-friendly label derived from Is_Agent_Activity.
	/// Returns "Agents" for any agent / autonomous / workflow / cowork row, BLANK otherwise.
	/// Use as the binding column for a single-tile "Agents" slicer on report pages.
	/// BLANK rows are hidden by Power BI by default in slicers, so a tile-style slicer
	/// shows exactly one button labelled "Agents".
	column 'Agent Filter' = IF('Chat + Agent Interactions (Audit Logs)'[Is_Agent_Activity] = TRUE(), "Agents", BLANK())
		dataType: string
		lineageTag: ff030001-0001-0001-0001-000000000a07
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	/// Agent Publish Status — strict published-agent classification using AUDIT LOGS ONLY.
	/// Use in the filter pane to include / exclude unpublished agents on agent-focused pages.
	/// 17 May 2026 — rebuilt from scratch. No A365 dependency. No activity gate.
	/// 
	/// Rule (intentionally simple and audit-log only):
	/// 1. AgentId must be populated  (the row IS an agent invocation, not chat / workflow / autonomous flow)
	/// 2. AgentName must NOT contain "draft as 1p"  (excludes Copilot Studio "Draft as 1P Agent" preview runs)
	/// 
	/// Why this works:
	/// • AgentId is the strongest "this row is an agent" signal in the audit log — chat rows,
	/// workflow rows, and autonomous flow rows leave it blank.
	/// • "Draft as 1P Agent" is Copilot Studio's preview-as-1P feature. The preview session
	/// gets an AgentId AND a populated Agent_TitleID, so the old Title-ID-based rule
	/// couldn't see it. The agent's NAME is the only unique tell, so we exclude by name.
	/// 
	/// Returns one of three values per audit row:
	/// "Published"        — AgentId populated AND AgentName <> "Draft as 1P Agent" (live, real agent)
	/// "Unpublished"      — AgentId populated AND AgentName CONTAINS "draft as 1p" (preview / draft)
	/// "Not an Agent Row" — AgentId blank (chat, workflow trigger, autonomous flow, or other non-agent row)
	/// 
	/// Default behaviour: all three are visible. To hide unpublished agents on a page,
	/// add this column to the filter pane → untick "Unpublished" (leave "Published" and
	/// "Not an Agent Row" ticked so chat activity is not accidentally hidden).
	/// 
	/// If you discover other draft / preview agent name patterns in your tenant, extend the
	/// `isDraft` CONTAINSSTRING check below (one substring per OR clause).
	column 'Agent Publish Status' =
			VAR agentId   = 'Chat + Agent Interactions (Audit Logs)'[AgentId]
			VAR agentName = LOWER(TRIM('Chat + Agent Interactions (Audit Logs)'[AgentName]))
			VAR hasAgentId = NOT(ISBLANK(agentId)) && TRIM(agentId) <> ""
			VAR isDraft   = CONTAINSSTRING(agentName, "draft as 1p")
			RETURN
			    SWITCH(
			        TRUE(),
			        NOT(hasAgentId),  "Not an Agent Row",
			        isDraft,          "Unpublished",
			        "Published"
			    )
		dataType: string
		lineageTag: ff030001-0001-0001-0001-000000000a08
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

