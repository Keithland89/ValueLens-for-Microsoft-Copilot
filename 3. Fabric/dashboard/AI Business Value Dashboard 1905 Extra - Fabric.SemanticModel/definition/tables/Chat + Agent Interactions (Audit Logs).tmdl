	/// Habitual Users: 8-14 active days AND ≥5 enriched behaviours in the latest
	/// rolling 4-week window. Embedded across the week.
	measure 'Habitual Users' =
			VAR CurrentWeek = MAX('Chat + Agent Interactions (Audit Logs)'[WeekStart])
			VAR WindowStart = CurrentWeek - 21
			VAR UserStats =
			    ADDCOLUMNS(
			        CALCULATETABLE(
			            VALUES('Chat + Agent Interactions (Audit Logs)'[Audit_UserId]),
			            REMOVEFILTERS('Calendar'),
			            'Chat + Agent Interactions (Audit Logs)'[WeekStart] >= WindowStart,
			            'Chat + Agent Interactions (Audit Logs)'[WeekStart] <= CurrentWeek
			        ),
			        "Behaviors",  CALCULATE(DISTINCTCOUNT('Chat + Agent Interactions (Audit Logs)'[Behavior_Enriched_Full]), REMOVEFILTERS('Calendar'), 'Chat + Agent Interactions (Audit Logs)'[WeekStart] >= WindowStart, 'Chat + Agent Interactions (Audit Logs)'[WeekStart] <= CurrentWeek),
			        "ActiveDays", CALCULATE(DISTINCTCOUNT('Chat + Agent Interactions (Audit Logs)'[InteractionDate]),         REMOVEFILTERS('Calendar'), 'Chat + Agent Interactions (Audit Logs)'[WeekStart] >= WindowStart, 'Chat + Agent Interactions (Audit Logs)'[WeekStart] <= CurrentWeek)
			    )
			RETURN COUNTROWS(FILTER(UserStats, [ActiveDays] >= 8 && [ActiveDays] <= 14 && [Behaviors] >= 5))
		formatString: #,##0
		displayFolder: AI Fluency\User Stages
		lineageTag: ff020001-0001-0001-0001-000000000303

	/// Power Users: ≥15 active days, OR (≥10 days AND ≥30% Producing+Delegating AND uses an Agent)
	/// — all measured over the latest rolling 4-week window. Champion cohort.
	measure 'Power Users' =
			VAR CurrentWeek = MAX('Chat + Agent Interactions (Audit Logs)'[WeekStart])
			VAR WindowStart = CurrentWeek - 21
			VAR UserStats =
			    ADDCOLUMNS(
			        CALCULATETABLE(
			            VALUES('Chat + Agent Interactions (Audit Logs)'[Audit_UserId]),
			            REMOVEFILTERS('Calendar'),
			            'Chat + Agent Interactions (Audit Logs)'[WeekStart] >= WindowStart,
			            'Chat + Agent Interactions (Audit Logs)'[WeekStart] <= CurrentWeek
			        ),
			        "ActiveDays", CALCULATE(DISTINCTCOUNT('Chat + Agent Interactions (Audit Logs)'[InteractionDate]),         REMOVEFILTERS('Calendar'), 'Chat + Agent Interactions (Audit Logs)'[WeekStart] >= WindowStart, 'Chat + Agent Interactions (Audit Logs)'[WeekStart] <= CurrentWeek),
			        "ValueShare", DIVIDE(
			            CALCULATE(COUNTROWS('Chat + Agent Interactions (Audit Logs)'), REMOVEFILTERS('Calendar'), 'Chat + Agent Interactions (Audit Logs)'[Usage_Mode] IN {"4 - Producing","5 - Delegating"}, 'Chat + Agent Interactions (Audit Logs)'[WeekStart] >= WindowStart, 'Chat + Agent Interactions (Audit Logs)'[WeekStart] <= CurrentWeek),
			            CALCULATE(COUNTROWS('Chat + Agent Interactions (Audit Logs)'), REMOVEFILTERS('Calendar'), 'Chat + Agent Interactions (Audit Logs)'[WeekStart] >= WindowStart, 'Chat + Agent Interactions (Audit Logs)'[WeekStart] <= CurrentWeek),
			            0
			        ),
			        "HasAgent",   CALCULATE(COUNTROWS(FILTER('Chat + Agent Interactions (Audit Logs)', NOT(ISBLANK('Chat + Agent Interactions (Audit Logs)'[AgentName])) && 'Chat + Agent Interactions (Audit Logs)'[AgentName] <> "")), REMOVEFILTERS('Calendar'), 'Chat + Agent Interactions (Audit Logs)'[WeekStart] >= WindowStart, 'Chat + Agent Interactions (Audit Logs)'[WeekStart] <= CurrentWeek) > 0
			    )
			RETURN COUNTROWS(FILTER(UserStats,
			    [ActiveDays] >= 15
			    || ([ActiveDays] >= 10 && [ValueShare] >= 0.30 && [HasAgent])
			))
		formatString: #,##0
		displayFolder: AI Fluency\User Stages
		lineageTag: ff020001-0001-0001-0001-000000000304

	/// Power Users % (of all active users) — quick maturity indicator for comparing groups
	measure 'Power Users %' = DIVIDE([Power Users], [All Active Users], 0)
		formatString: 0.0%;-0.0%;0.0%
		isHidden
		displayFolder: AI Fluency\User Stages
		lineageTag: ff020001-0001-0001-0001-000000000308

	/// Habit + Power combined % — % of active users at the top 2 maturity stages
	measure 'Habitual + Power %' = DIVIDE([Habitual Users] + [Power Users], [All Active Users], 0)
		formatString: 0.0%;-0.0%;0.0%
		displayFolder: AI Fluency\User Stages
		lineageTag: ff020001-0001-0001-0001-000000000311

	/// Inactive Users: licensed users with ZERO activity in the latest rolling 4-week
	/// window. Computed as Licensed-in-scope minus Active-Licensed-in-scope in that
	/// window. The most actionable cohort — license-reclamation candidates.
	/// 
	/// ORG-AWARE: uses TREATAS to push the Org filter through to Copilot Licensed
	/// via PersonId == UPN_Normalized. Without this, an org slicer would only
	/// filter the Active side, leaving Licensed at the company-wide total and
	/// producing nonsense Inactive counts (e.g., 671 inactive in an org of 664).
	measure 'Inactive Users' =
			VAR CurrentWeek = MAX('Chat + Agent Interactions (Audit Logs)'[WeekStart])
			VAR WindowStart = CurrentWeek - 21
			VAR LicensedInScope =
			    CALCULATE(
			        [Total Licensed Users],
			        TREATAS(VALUES('Chat + Agent Org Data'[PersonId]), 'Copilot Licensed'[UPN_Normalized])
			    )
			VAR LicensedActive4W =
			    CALCULATE(
			        [NoOfActiveChatUsers (Licensed)],
			        REMOVEFILTERS('Calendar'),
			        REMOVEFILTERS('Chat + Agent Interactions (Audit Logs)'[WeekStart]),
			        'Chat + Agent Interactions (Audit Logs)'[WeekStart] >= WindowStart,
			        'Chat + Agent Interactions (Audit Logs)'[WeekStart] <= CurrentWeek
			    )
			RETURN MAX(LicensedInScope - LicensedActive4W, 0)
		formatString: #,##0
		displayFolder: AI Fluency\User Stages
		lineageTag: ff020001-0001-0001-0001-000000000305

	/// =============================================================================
	/// (Latest) FAMILY — Each user is classified using THEIR OWN latest week of
	/// activity within the current filter context, then their personal 4-week
	/// look-back ending at that week is used to derive their stage.
	/// 
	/// Use this when you want to ask "where is each user RIGHT NOW?" while still
	/// measuring something across a wider time period.
	/// 
	/// Example: filter to the past year, then [Power Users (Latest)] counts users
	/// who are CURRENTLY in the Power stage (based on their last 4 weeks of
	/// activity within that year) — even if they were Beginners 10 months ago.
	/// =============================================================================
	measure 'Beginner Users (Latest)' =
			VAR Classified =
			    ADDCOLUMNS(
			        VALUES('Chat + Agent Interactions (Audit Logs)'[Audit_UserId]),
			        "Stage",
			            VAR LatestWk    = CALCULATE(MAX('Chat + Agent Interactions (Audit Logs)'[WeekStart]))
			            VAR WindowStart = LatestWk - 21
			            VAR Days        = CALCULATE(DISTINCTCOUNT('Chat + Agent Interactions (Audit Logs)'[InteractionDate]),         'Chat + Agent Interactions (Audit Logs)'[WeekStart] >= WindowStart, 'Chat + Agent Interactions (Audit Logs)'[WeekStart] <= LatestWk)
			            VAR Behaviors   = CALCULATE(DISTINCTCOUNT('Chat + Agent Interactions (Audit Logs)'[Behavior_Enriched_Full]), 'Chat + Agent Interactions (Audit Logs)'[WeekStart] >= WindowStart, 'Chat + Agent Interactions (Audit Logs)'[WeekStart] <= LatestWk)
			            VAR ValueShare  = DIVIDE(
			                CALCULATE(COUNTROWS('Chat + Agent Interactions (Audit Logs)'), 'Chat + Agent Interactions (Audit Logs)'[Usage_Mode] IN {"4 - Producing","5 - Delegating"}, 'Chat + Agent Interactions (Audit Logs)'[WeekStart] >= WindowStart, 'Chat + Agent Interactions (Audit Logs)'[WeekStart] <= LatestWk),
			                CALCULATE(COUNTROWS('Chat + Agent Interactions (Audit Logs)'),                                                                                          'Chat + Agent Interactions (Audit Logs)'[WeekStart] >= WindowStart, 'Chat + Agent Interactions (Audit Logs)'[WeekStart] <= LatestWk),
			                0
			            )
			            VAR HasAgentFlag = CALCULATE(COUNTROWS(FILTER('Chat + Agent Interactions (Audit Logs)', NOT(ISBLANK('Chat + Agent Interactions (Audit Logs)'[AgentName])) && 'Chat + Agent Interactions (Audit Logs)'[AgentName] <> "")), 'Chat + Agent Interactions (Audit Logs)'[WeekStart] >= WindowStart, 'Chat + Agent Interactions (Audit Logs)'[WeekStart] <= LatestWk) > 0
			            RETURN
			                SWITCH(TRUE(),
			                    Days >= 15 || (Days >= 10 && ValueShare >= 0.30 && HasAgentFlag), "4 - Power",
			                    Days >= 8  && Behaviors >= 5, "3 - Habitual",
			                    Days >= 3  && Behaviors >= 3, "2 - Developing",
			                    Days >= 1, "1 - Beginner",
			                    BLANK()
			                )
			    )
			RETURN COUNTROWS(FILTER(Classified, [Stage] = "1 - Beginner"))
		formatString: #,##0
		displayFolder: AI Fluency\User Stages (Latest)
		lineageTag: ff020001-0001-0001-0001-000000000601

	measure 'Developing Users (Latest)' =
			VAR Classified =
			    ADDCOLUMNS(
			        VALUES('Chat + Agent Interactions (Audit Logs)'[Audit_UserId]),
			        "Stage",
			            VAR LatestWk    = CALCULATE(MAX('Chat + Agent Interactions (Audit Logs)'[WeekStart]))
			            VAR WindowStart = LatestWk - 21
			            VAR Days        = CALCULATE(DISTINCTCOUNT('Chat + Agent Interactions (Audit Logs)'[InteractionDate]),         'Chat + Agent Interactions (Audit Logs)'[WeekStart] >= WindowStart, 'Chat + Agent Interactions (Audit Logs)'[WeekStart] <= LatestWk)
			            VAR Behaviors   = CALCULATE(DISTINCTCOUNT('Chat + Agent Interactions (Audit Logs)'[Behavior_Enriched_Full]), 'Chat + Agent Interactions (Audit Logs)'[WeekStart] >= WindowStart, 'Chat + Agent Interactions (Audit Logs)'[WeekStart] <= LatestWk)
			            VAR ValueShare  = DIVIDE(
			                CALCULATE(COUNTROWS('Chat + Agent Interactions (Audit Logs)'), 'Chat + Agent Interactions (Audit Logs)'[Usage_Mode] IN {"4 - Producing","5 - Delegating"}, 'Chat + Agent Interactions (Audit Logs)'[WeekStart] >= WindowStart, 'Chat + Agent Interactions (Audit Logs)'[WeekStart] <= LatestWk),
			                CALCULATE(COUNTROWS('Chat + Agent Interactions (Audit Logs)'),                                                                                          'Chat + Agent Interactions (Audit Logs)'[WeekStart] >= WindowStart, 'Chat + Agent Interactions (Audit Logs)'[WeekStart] <= LatestWk),
			                0
			            )
			            VAR HasAgentFlag = CALCULATE(COUNTROWS(FILTER('Chat + Agent Interactions (Audit Logs)', NOT(ISBLANK('Chat + Agent Interactions (Audit Logs)'[AgentName])) && 'Chat + Agent Interactions (Audit Logs)'[AgentName] <> "")), 'Chat + Agent Interactions (Audit Logs)'[WeekStart] >= WindowStart, 'Chat + Agent Interactions (Audit Logs)'[WeekStart] <= LatestWk) > 0
			            RETURN
			                SWITCH(TRUE(),
			                    Days >= 15 || (Days >= 10 && ValueShare >= 0.30 && HasAgentFlag), "4 - Power",
			                    Days >= 8  && Behaviors >= 5, "3 - Habitual",
			                    Days >= 3  && Behaviors >= 3, "2 - Developing",
			                    Days >= 1, "1 - Beginner",
			                    BLANK()
			                )
			    )
			RETURN COUNTROWS(FILTER(Classified, [Stage] = "2 - Developing"))
		formatString: #,##0
		displayFolder: AI Fluency\User Stages (Latest)
		lineageTag: ff020001-0001-0001-0001-000000000603

	measure 'Habitual Users (Latest)' =
			VAR Classified =
			    ADDCOLUMNS(
			        VALUES('Chat + Agent Interactions (Audit Logs)'[Audit_UserId]),
			        "Stage",
			            VAR LatestWk    = CALCULATE(MAX('Chat + Agent Interactions (Audit Logs)'[WeekStart]))
			            VAR WindowStart = LatestWk - 21
			            VAR Days        = CALCULATE(DISTINCTCOUNT('Chat + Agent Interactions (Audit Logs)'[InteractionDate]),         'Chat + Agent Interactions (Audit Logs)'[WeekStart] >= WindowStart, 'Chat + Agent Interactions (Audit Logs)'[WeekStart] <= LatestWk)
			            VAR Behaviors   = CALCULATE(DISTINCTCOUNT('Chat + Agent Interactions (Audit Logs)'[Behavior_Enriched_Full]), 'Chat + Agent Interactions (Audit Logs)'[WeekStart] >= WindowStart, 'Chat + Agent Interactions (Audit Logs)'[WeekStart] <= LatestWk)
			            VAR ValueShare  = DIVIDE(
			                CALCULATE(COUNTROWS('Chat + Agent Interactions (Audit Logs)'), 'Chat + Agent Interactions (Audit Logs)'[Usage_Mode] IN {"4 - Producing","5 - Delegating"}, 'Chat + Agent Interactions (Audit Logs)'[WeekStart] >= WindowStart, 'Chat + Agent Interactions (Audit Logs)'[WeekStart] <= LatestWk),
			                CALCULATE(COUNTROWS('Chat + Agent Interactions (Audit Logs)'),                                                                                          'Chat + Agent Interactions (Audit Logs)'[WeekStart] >= WindowStart, 'Chat + Agent Interactions (Audit Logs)'[WeekStart] <= LatestWk),
			                0
			            )
			            VAR HasAgentFlag = CALCULATE(COUNTROWS(FILTER('Chat + Agent Interactions (Audit Logs)', NOT(ISBLANK('Chat + Agent Interactions (Audit Logs)'[AgentName])) && 'Chat + Agent Interactions (Audit Logs)'[AgentName] <> "")), 'Chat + Agent Interactions (Audit Logs)'[WeekStart] >= WindowStart, 'Chat + Agent Interactions (Audit Logs)'[WeekStart] <= LatestWk) > 0
			            RETURN
			                SWITCH(TRUE(),
			                    Days >= 15 || (Days >= 10 && ValueShare >= 0.30 && HasAgentFlag), "4 - Power",
			                    Days >= 8  && Behaviors >= 5, "3 - Habitual",
			                    Days >= 3  && Behaviors >= 3, "2 - Developing",
			                    Days >= 1, "1 - Beginner",
			                    BLANK()
			                )
			    )
			RETURN COUNTROWS(FILTER(Classified, [Stage] = "3 - Habitual"))
		formatString: #,##0
