	/// Average days per week users are active (any AI — chat + agents)
	/// ✅ >10 days = engaged users
	/// ⚠️ <5 days = low engagement
	/// 💡 Focus on habit formation
	/// 16 May 2026 — was chat-only. Now counts any AI activity (chat + agents).
	measure 'Average Chat Active Days Per User' =
			
			AVERAGEX(
			    VALUES('Chat + Agent Interactions (Audit Logs)'[Audit_UserId]),
			    CALCULATE(
			        DISTINCTCOUNT('Chat + Agent Interactions (Audit Logs)'[InteractionDate]),
			        'Chat + Agent Interactions (Audit Logs)'[Message_isPrompt] = "TRUE"
			    )
			)
		lineageTag: 1871c47e-310d-4eb5-aa25-4b3ef8b060ca

		changedProperty = IsHidden

		annotation PBI_FormatHint = {"isGeneralNumber":true}

