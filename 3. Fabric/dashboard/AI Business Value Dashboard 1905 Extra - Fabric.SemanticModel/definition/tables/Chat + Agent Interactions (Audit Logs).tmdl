	/// AI Usage Mode (5-stage maturity model)
	/// 1-Asking → 2-Finding → 3-Consuming → 4-Producing → 5-Delegating
	/// Asking      : general Q&A, no document grounding (entry point).
	/// Finding     : retrieving info from systems (search, lookup).
	/// Consuming   : digesting existing content (summarising, reviewing).
	/// Producing   : creating output or specialist agent work.
	/// Delegating  : handing tasks to autonomous agents or workflow systems
	/// (env=Cowork, appHost=autonomous, Running a Workflow rows, or the agent
	/// is registered as Autonomous/Workflow/Triggered in Agents 365).
	/// 16 May 2026 — renamed Automating → Delegating. Tightened rule to drop Copilot Studio
	/// authoring + DCA chats. Moved Note Taking, Teams Messaging, Meeting
	/// Scheduling, Task Management to Producing. Added Sensitive Content
	/// Interaction to Consuming.
	/// 29 May 2026 — Tightened workflow signal: dropped bare appHost="logic app"
	/// (was sweeping in tenant plumbing / scheduled syncs). Logic App rows now
	/// only count when Behavior_Category classifies them as "Running a Workflow"
	/// (i.e. they carry AgentName/AgentId). Bare connector/http rows now require
	/// an action verb. A365 enrichment (agentTypeA365) remains optional and
	/// additive — graceful when Agents 365 is not connected.
	column Usage_Mode =
			VAR behavior      = 'Chat + Agent Interactions (Audit Logs)'[Behavior_Enriched_Full]
			VAR env           = 'Chat + Agent Interactions (Audit Logs)'[Environment]
			VAR appHost       = LOWER('Chat + Agent Interactions (Audit Logs)'[AppHost])
			-- Agents 365 enrichment (optional — degrades gracefully when A365 not connected)
			VAR agentTypeA365 = IFERROR(RELATED('Agents 365'[Agent type (A365)]), BLANK())
			VAR isDelegating =
			       env = "Cowork"
			    || appHost = "autonomous"
			    || behavior = "Running a Workflow"
			    || agentTypeA365 IN {"Autonomous", "Workflow", "Triggered"}
			RETURN
			    IF(isDelegating, "5 - Delegating",
			    IF(behavior IN {"Email Drafting","Document Drafting","Presentation Creation","Image Generation","Code Writing","Code Analysis","Code Analysis (URL)","Data Querying","Spreadsheet Analysis","Excel Assistance","Agent: Content Generation","Agent: Ideation & Creative","Agent: Research & Analysis","Agent: Data & Reporting","Agent: Sales & Customer","Agent: HR & People","Agent: IT & Service Desk","Agent: Compliance & Policy","Agent: Coaching","Agent: Coaching (URL)","Domain-Specific Agent","Cross-Org Agent","Form / Survey Work","Real-time Collaboration","Note Taking","Teams Messaging","Meeting Scheduling","Task Management"}, "4 - Producing",
			    IF(behavior IN {"Document Summarising","Email Summarising","Email Thread Summary","Email Triage","Presentation Summarising","Video Summarising","Meeting Prep","Image / Media Analysis","Image/Media Analysis","Sensitive Content Interaction"}, "3 - Consuming",
			    IF(behavior IN {"Web Searching","Enterprise Searching","PDF Analysis","SharePoint Access","File Retrieval","People Lookup","Agent: Knowledge Base","Spreadsheet Review"}, "2 - Finding",
			    "1 - Asking"))))
		dataType: string
		lineageTag: ff030001-0001-0001-0001-000000000020
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	/// Skill role AI is augmenting — broader than the original specialist-only definition.
	/// Covers comms, content, presentations, design, meetings, research, data, collaboration
	/// in addition to the strict specialist roles. 20 distinct roles total.
	/// Generic Q&A / chat catch-alls remain BLANK by design (no clear skill being augmented).
	/// 16 May 2026 — Communications Specialist split: kept Email Drafting only.
	/// Email Triage + Meeting Scheduling → Executive Assistant (new).
	/// Email Summarising + Email Thread Summary → Researcher (synthesis joins doc summarising).
	/// Teams Messaging → Collaboration Lead (coordination chat).
	/// 17 May 2026 — Researcher split (was a 9-behaviour catch-all):
	/// • Researcher (true synthesis) → Web Searching, PDF Analysis, Agent: Knowledge Base only
	/// • Knowledge Navigator (NEW) → Enterprise Searching, SharePoint Access, File Retrieval, People Lookup
	/// • Email Summarising + Email Thread Summary → Executive Assistant (inbox synthesis, joins triage + scheduling)
	column Expertise_Role =
			VAR behavior = 'Chat + Agent Interactions (Audit Logs)'[Behavior_Enriched_Full]
			RETURN
			    -- Specialist roles (strict — kept from original definition)
			    IF(behavior IN {"Data Querying","Agent: Data & Reporting","Spreadsheet Analysis"}, "Data Analyst",
			    IF(behavior IN {"Code Writing","Code Analysis","Code Analysis (URL)"}, "Software Engineer",
			    IF(behavior IN {"Agent: Research & Analysis"}, "Business Analyst",
			    IF(behavior IN {"Agent: Compliance & Policy","Sensitive Content Interaction"}, "Compliance Specialist",
			    IF(behavior IN {"Agent: Sales & Customer"}, "Sales Consultant",
			    IF(behavior IN {"Agent: IT & Service Desk"}, "IT Specialist",
			    IF(behavior IN {"Agent: HR & People"}, "HR Specialist",
			    IF(behavior IN {"Agent: Coaching","Agent: Coaching (URL)"}, "Coach",
			    IF(behavior IN {"Running a Workflow","Task Management"}, "Automation Engineer",
			    IF(behavior IN {"Domain-Specific Agent","Cross-Org Agent"}, "Domain Expert",
			    -- Communications Specialist now narrow: drafting only (was a 5-behaviour catch-all)
			    IF(behavior IN {"Email Drafting"}, "Communications Specialist",
			    -- Executive Assistant (NEW): inbox triage + calendar admin + inbox synthesis (Email Summarising / Thread Summary moved here 17 May)
			    IF(behavior IN {"Email Triage","Meeting Scheduling","Email Summarising","Email Thread Summary"}, "Executive Assistant",
			    -- Content Writer
			    IF(behavior IN {"Document Drafting","Agent: Content Generation","Note Taking","Document Summarising"}, "Content Writer",
			    IF(behavior IN {"Presentation Creation","Presentation Summarising"}, "Presentation Designer",
			    IF(behavior IN {"Image Generation","Image/Media Analysis","Image / Media Analysis","Agent: Ideation & Creative"}, "Visual Designer",
			    -- Meeting Coordinator (Scheduling moved to Executive Assistant)
			    IF(behavior IN {"Meeting Prep","Video Summarising"}, "Meeting Coordinator",
			    -- Researcher (TIGHTENED 17 May): true synthesis / external research / curated KB only
			    IF(behavior IN {"Web Searching","PDF Analysis","Agent: Knowledge Base"}, "Researcher",
			    -- Knowledge Navigator (NEW 17 May): internal information retrieval — finding what / who / where
			    IF(behavior IN {"Enterprise Searching","SharePoint Access","File Retrieval","People Lookup"}, "Knowledge Navigator",
			    IF(behavior IN {"Spreadsheet Review","Excel Assistance"}, "Spreadsheet Specialist",
			    -- Collaboration Lead (now includes Teams Messaging — coordination chat)
			    IF(behavior IN {"Real-time Collaboration","Form / Survey Work","Form/Survey Work","Teams Messaging"}, "Collaboration Lead",
			    BLANK()))))))))))))))))))))
		dataType: string
		lineageTag: ff030001-0001-0001-0001-000000000095
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	/// Efficiency breakdown: where is time being saved?
	/// Revised Efficiency Breakdown: 12 categories validated across 4 datasets
	column Efficiency_Breakdown =
			VAR behavior = 'Chat + Agent Interactions (Audit Logs)'[Behavior_Enriched_Full]
			VAR cat = 'Chat + Agent Interactions (Audit Logs)'[Behavior_Category]
			RETURN
			    IF(behavior IN {"Email Summarising","Email Triage","Email Thread Summary","Email Drafting"}, "Email",
			    IF(behavior IN {"Document Summarising","Note Taking","Document Drafting","Agent: Content Generation"}, "Document Assistance",
			    IF(behavior IN {"Presentation Summarising","Presentation Creation"}, "Presentations",
			    IF(behavior IN {"Meeting Prep","Video Summarising","Meeting Scheduling"}, "Meetings",
			    IF(behavior IN {"Web Searching","Enterprise Searching","PDF Analysis","SharePoint Access","File Retrieval","People Lookup","Agent: Knowledge Base","Agent: Research & Analysis"}, "Search & Research",
			    IF(behavior IN {"Spreadsheet Review","Excel Assistance","Spreadsheet Analysis","Data Querying","Agent: Data & Reporting"}, "Data & Spreadsheets",
			    IF(behavior IN {"Image Generation","Image / Media Analysis","Image/Media Analysis","Agent: Ideation & Creative","Code Writing","Code Analysis","Code Analysis (URL)"}, "Creative & Technical",
			    IF(behavior IN {"Teams Messaging","Real-time Collaboration","Form / Survey Work","Task Management","Running a Workflow"}, "Collaboration & Workflows",
			    IF(behavior IN {"Agent: Sales & Customer","Agent: IT & Service Desk","Agent: HR & People","Agent: Compliance & Policy","Agent: Coaching","Agent: Coaching (URL)","Domain-Specific Agent","Cross-Org Agent"}, "Specialist Agents",
			    IF(cat = "Teams Q&A", "Teams Chat",
			    IF(cat = "M365 Chat Q&A", "BizChat Q&A",
			    IF(cat = "Browser Q&A", "BizChat Q&A",
			    "General Q&A"))))))))))))
		dataType: string
		lineageTag: ff030001-0001-0001-0001-000000000096
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

