	/// Actionable source label: Behavior + where it happened (app/agent/plugin)
	column Behavior_Source =
			VAR Behavior = 'Chat + Agent Interactions (Audit Logs)'[Behavior_Category]
			VAR Env = 'Chat + Agent Interactions (Audit Logs)'[Environment]
			VAR Agent = 'Chat + Agent Interactions (Audit Logs)'[AgentName]
			VAR Plugin = 'Chat + Agent Interactions (Audit Logs)'[AISystemPlugin_Name]
			VAR App = 'Chat + Agent Interactions (Audit Logs)'[AppHost]
			VAR Enriched = 'Chat + Agent Interactions (Audit Logs)'[Behavior_Enriched]
			VAR Source =
			    IF(Env = "Cowork", "Cowork" & IF(NOT(ISBLANK(Agent)) && Agent <> "", ": " & Agent, ""),
			    IF(Env = "Agents" && NOT(ISBLANK(Agent)) && Agent <> "", "Agent: " & Agent,
			    IF(NOT(ISBLANK(Plugin)) && Plugin <> "", App & " (" & Plugin & ")",
			    IF(NOT(ISBLANK(App)) && App <> "", App,
			    "Copilot Chat"))))
			RETURN
			    Behavior & " → " & Source
		dataType: string
		lineageTag: ff030001-0001-0001-0001-000000000016
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	/// Enhanced enrichment using Agent Description + Capabilities from Agents 365 (via RELATED)
	column Behavior_Enriched_Full =
			VAR BaseEnriched = 'Chat + Agent Interactions (Audit Logs)'[Behavior_Enriched]
			VAR Env = 'Chat + Agent Interactions (Audit Logs)'[Environment]
			VAR NeedsEnhancement = Env = "Agents" && BaseEnriched = "Agent: General Purpose"
			VAR AgentDesc = IF(NeedsEnhancement, LOWER(RELATED('Agents 365'[Agent description])), "")
			VAR AgentActions = IF(NeedsEnhancement, LOWER(RELATED('Agents 365'[Custom actions])), "")
			VAR HasCode = IF(NeedsEnhancement, RELATED('Agents 365'[Can use code interpreter]) = "Yes", FALSE())
			VAR HasImages = IF(NeedsEnhancement, RELATED('Agents 365'[Can generate images using user prompt]) = "Yes", FALSE())
			VAR HasSP = IF(NeedsEnhancement, RELATED('Agents 365'[Can read Sharepoint sites and files]) = "Yes", FALSE())
			VAR SearchText = AgentDesc & " " & AgentActions
			VAR IsCoaching = CONTAINSSTRING(SearchText, "coach") || CONTAINSSTRING(SearchText, "mentor") || CONTAINSSTRING(SearchText, "learning") || CONTAINSSTRING(SearchText, "training") || CONTAINSSTRING(SearchText, "skill")
			VAR IsResearch = CONTAINSSTRING(SearchText, "research") || CONTAINSSTRING(SearchText, "analyst") || CONTAINSSTRING(SearchText, "analy") || CONTAINSSTRING(SearchText, "insight") || CONTAINSSTRING(SearchText, "intelligence")
			VAR IsSales = CONTAINSSTRING(SearchText, "sales") || CONTAINSSTRING(SearchText, "commercial") || CONTAINSSTRING(SearchText, "customer") || CONTAINSSTRING(SearchText, "crm") || CONTAINSSTRING(SearchText, "pipeline") || CONTAINSSTRING(SearchText, "prospect") || CONTAINSSTRING(SearchText, "deal")
			VAR IsHR = CONTAINSSTRING(SearchText, "recruit") || CONTAINSSTRING(SearchText, "talent") || CONTAINSSTRING(SearchText, "onboard") || CONTAINSSTRING(SearchText, "hiring") || CONTAINSSTRING(SearchText, "employee") || CONTAINSSTRING(SearchText, "human resource") || CONTAINSSTRING(SearchText, "job description")
			VAR IsCompliance = CONTAINSSTRING(SearchText, "policy") || CONTAINSSTRING(SearchText, "compliance") || CONTAINSSTRING(SearchText, "legal") || CONTAINSSTRING(SearchText, "audit") || CONTAINSSTRING(SearchText, "risk") || CONTAINSSTRING(SearchText, "governance")
			VAR IsIT = CONTAINSSTRING(SearchText, "support") || CONTAINSSTRING(SearchText, "helpdesk") || CONTAINSSTRING(SearchText, "troubleshoot") || CONTAINSSTRING(SearchText, "ticket") || CONTAINSSTRING(SearchText, "incident") || CONTAINSSTRING(SearchText, "service desk")
			VAR IsContent = CONTAINSSTRING(SearchText, "summar") || CONTAINSSTRING(SearchText, "draft") || CONTAINSSTRING(SearchText, "translat") || CONTAINSSTRING(SearchText, "content") || CONTAINSSTRING(SearchText, "communications")
			VAR IsData = CONTAINSSTRING(SearchText, "data") || CONTAINSSTRING(SearchText, "report") || CONTAINSSTRING(SearchText, "dashboard") || CONTAINSSTRING(SearchText, "analytics") || CONTAINSSTRING(SearchText, "metric")
			VAR IsKnowledge = CONTAINSSTRING(SearchText, "knowledge") || CONTAINSSTRING(SearchText, "faq") || CONTAINSSTRING(SearchText, "wiki") || CONTAINSSTRING(SearchText, "guide") || CONTAINSSTRING(SearchText, "handbook") || CONTAINSSTRING(SearchText, "documentation")
			VAR IsCreative = CONTAINSSTRING(SearchText, "brainstorm") || CONTAINSSTRING(SearchText, "creative") || CONTAINSSTRING(SearchText, "design") || CONTAINSSTRING(SearchText, "innovat")
			RETURN
			    IF(NOT(NeedsEnhancement), BaseEnriched,
			    IF(IsCoaching, "Agent: Coaching",
			    IF(IsResearch, "Agent: Research & Analysis",
			    IF(IsSales, "Agent: Sales & Customer",
			    IF(IsHR, "Agent: HR & People",
			    IF(IsCompliance, "Agent: Compliance & Policy",
			    IF(IsIT, "Agent: IT & Service Desk",
			    IF(IsContent, "Agent: Content Generation",
			    IF(IsData, "Agent: Data & Reporting",
			    IF(IsKnowledge, "Agent: Knowledge Base",
			    IF(IsCreative, "Agent: Ideation & Creative",
			    IF(HasCode, "Agent: Data & Reporting",
			    IF(HasImages, "Agent: Ideation & Creative",
			    IF(HasSP, "Agent: Knowledge Base",
			    "Agent: General Purpose"))))))))))))))
		dataType: string
		lineageTag: ff030001-0001-0001-0001-000000000018
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column AccessedResource_SiteUrl
		dataType: string
		lineageTag: b67ef0d0-01d8-4bc2-a2ef-0ea215119fd5
		summarizeBy: none
		sourceColumn: AccessedResource_SiteUrl

		annotation SummarizationSetBy = Automatic

	/// Behavior classification: resource-level signals first (accurate per expanded row),
	/// then context/appHost fallback (shared across event — only for rows with no resource info)
	column Behavior_Category =
			VAR appHost = LOWER('Chat + Agent Interactions (Audit Logs)'[AppHost])
			VAR ctxType = LOWER('Chat + Agent Interactions (Audit Logs)'[Context_Type])
			VAR resType = LOWER('Chat + Agent Interactions (Audit Logs)'[AccessedResource_Type])
			VAR resAction = LOWER('Chat + Agent Interactions (Audit Logs)'[AccessedResource_Action])
			VAR siteUrl = LOWER('Chat + Agent Interactions (Audit Logs)'[AccessedResource_SiteUrl])
			VAR pluginId = LOWER('Chat + Agent Interactions (Audit Logs)'[AISystemPlugin_Id])
			VAR isActive = CONTAINSSTRING(resAction, "send") || CONTAINSSTRING(resAction, "draft") || CONTAINSSTRING(resAction, "create") || CONTAINSSTRING(resAction, "post") || CONTAINSSTRING(resAction, "invoke") || CONTAINSSTRING(resAction, "write") || CONTAINSSTRING(resAction, "patch") || CONTAINSSTRING(resAction, "execute")
			VAR FromResource =
			    IF(resAction IN {"sendemailv2","draftemail","senddraftemail","updatedraftemail"}, "Email Drafting",
			    IF(resType = "emailmessage" && isActive, "Email Drafting",
			    IF(resType = "emailmessage", "Email Summarising",
			    IF(resAction = "mcp_meetingmanagement", "Meeting Scheduling",
			    IF(resType IN {"event","teamsmeeting"}, "Meeting Prep",
			    IF(resAction IN {"postmessagetoconversation","createchat"}, "Teams Messaging",
			    IF(resType IN {"teamsmessage","teamschat","teamschannel"}, "Teams Messaging",
			    -- 29 May 2026 — tightened: bare connector/http rows without an action verb are
			    -- background sync chatter, not user-value workflow steps. Only count as
			    -- "Running a Workflow" when (a) it's an explicit Flow row, OR (b) connector/http
			    -- carries a recognisable active verb (send/draft/create/post/invoke/write/patch/execute).
			    IF(resType = "flow", "Running a Workflow",
			    IF(resType IN {"connector","http"} && isActive, "Running a Workflow",
			    IF(resAction IN {"executedatasetquery","getitems","getalltables","gettableviews"}, "Data Querying",
			    IF(resType IN {"xlsx","csv","xlsm","xlsb","xls"}, IF(isActive, "Excel Assistance", "Spreadsheet Review"),
			    IF(resType = "peopleinferenceanswer", "People Lookup",
			    IF(resType = "listitem" || resType = "aspx", "Enterprise Searching",
			    IF(resType = "websearchquery", "Web Searching",
			    IF(resType = "pdf", "PDF Analysis",
			    IF(resType IN {"py","js","java","tsx","jsx","css","php","sh"} && isActive, "Code Writing",
			    IF(resType IN {"py","sql","js","java","json","xml","html","yaml","yml","txt"}, "Code Analysis",
			    IF(resType IN {"png","jpg","jpeg","svg","gif"} && isActive, "Image Generation",
			    IF(resType IN {"png","jpg","jpeg","gif"}, "Image / Media Analysis",
			    IF(resType IN {"streamvideo","mp4","mov","webm","mkv"}, "Video Summarising",
			    IF(resType IN {"planid","taskids"}, "Task Management",
			    IF(resType = "looppage", "Real-time Collaboration",
			    IF(resType = "http://schema.skype.com/hyperlink" && (CONTAINSSTRING(siteUrl, "github.com") || CONTAINSSTRING(siteUrl, "stackoverflow.com") || CONTAINSSTRING(siteUrl, "npmjs.com") || CONTAINSSTRING(siteUrl, "pypi.org") || CONTAINSSTRING(siteUrl, "docker.com") || CONTAINSSTRING(siteUrl, "kubernetes.io") || CONTAINSSTRING(siteUrl, "leetcode.com")), "Code Analysis",
			    IF(resType = "http://schema.skype.com/hyperlink" && (CONTAINSSTRING(siteUrl, "learning.cloud.microsoft") || CONTAINSSTRING(siteUrl, "coursera.org") || CONTAINSSTRING(siteUrl, "udemy.com")), "Agent: Coaching",
			    IF(resType = "http://schema.skype.com/hyperlink" && CONTAINSSTRING(siteUrl, "sharepoint.com"), "Enterprise Searching",
			    IF(resType IN {"external","http"} || resType = "http://schema.skype.com/hyperlink", "Web Searching",
			    IF(resType IN {"docx","doc","rtf"} && isActive, "Document Drafting",
			    IF(resType IN {"docx","doc","rtf"} && resAction = "read", "File Retrieval",
			    IF(resType IN {"docx","doc","rtf"}, "Document Summarising",
			    IF(resType IN {"pptx","ppt","potx"} && isActive, "Presentation Creation",
			    IF(resType IN {"pptx","ppt","potx"} && resAction = "read", "File Retrieval",
			    IF(resType IN {"pptx","ppt","potx"}, "Presentation Summarising",
			    IF(CONTAINSSTRING(siteUrl, "service-now.com") || CONTAINSSTRING(siteUrl, "servicenow.com"), "Agent: IT & Service Desk",
			    IF(CONTAINSSTRING(siteUrl, "dynamics.com"), "Agent: Sales & Customer",
			    BLANK()))))))))))))))))))))))))))))))))))
			VAR FromPlugin =
			    IF(pluginId = "enterprisesearch", "Enterprise Searching", BLANK())
			VAR FromContext =
			    IF(ctxType = "teamsmeeting", "Meeting Prep",
			    IF(ctxType = "streamvideo", "Video Summarising",
			    IF(ctxType = "docx", IF(appHost = "word" && isActive, "Document Drafting", "Document Summarising"),
			    IF(ctxType IN {"xlsx","xlsm","xlsb","xls","csv"}, "Spreadsheet Review",
			    IF(ctxType IN {"pptx","pptm"}, IF(appHost = "powerpoint" && isActive, "Presentation Creation", "Presentation Summarising"),
			    IF(ctxType IN {"teamschat","teamschannel"}, "Teams Messaging",
			    IF(ctxType = "aspx", "Enterprise Searching",
			    IF((appHost = "outlook" || appHost = "outlooksidepane") && isActive, "Email Drafting",
			    IF(appHost = "outlook" || appHost = "outlooksidepane", "Email Summarising",
			    IF(appHost = "excel", "Excel Assistance",
			    IF(appHost = "word" && isActive, "Document Drafting",
			    IF(appHost = "word", "Document Summarising",
			    IF(appHost = "powerpoint" && isActive, "Presentation Creation",
			    IF(appHost = "powerpoint", "Presentation Summarising",
			    IF(appHost = "stream", "Video Summarising",
			    IF(appHost = "sharepoint", "SharePoint Access",
			    IF(appHost = "designer", "Image Generation",
			    IF(appHost = "onenote", "Note Taking",
			    IF(appHost = "forms", "Form / Survey Work",
			    IF(appHost = "planner", "Task Management",
			    IF(appHost IN {"loop","whiteboard","vivaengage"}, "Real-time Collaboration",
			    IF(appHost = "copilot studio", "Domain-Specific Agent",
			    -- 29 May 2026 — tightened: bare "logic app" appHost is tenant plumbing
			    -- (sync, refresh, scheduled jobs). Only count as a workflow when the row
			    -- carries an agent context (AgentName or AgentId present). "autonomous"
			    -- always counts (it's an explicit agent runtime signal).
			    IF(appHost = "autonomous", "Running a Workflow",
			    IF(appHost = "logic app" && (NOT(ISBLANK('Chat + Agent Interactions (Audit Logs)'[AgentName])) || NOT(ISBLANK('Chat + Agent Interactions (Audit Logs)'[AgentId]))), "Running a Workflow",
			    IF(appHost IN {"datawarehousing core","power bi"}, "Data Querying",
			    "General Chat")))))))))))))))))))))))))
			RETURN
			    IF(NOT(ISBLANK(FromResource)), FromResource,
			    IF(NOT(ISBLANK(FromPlugin)), FromPlugin,
			    FromContext))
		dataType: string
		lineageTag: ff030001-0001-0001-0001-000000000003
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column Value_Outcome =
			VAR behavior = 'Chat + Agent Interactions (Audit Logs)'[Behavior_Enriched]
			VAR env = 'Chat + Agent Interactions (Audit Logs)'[Environment]
			VAR isSensitive = 'Chat + Agent Interactions (Audit Logs)'[Is_Sensitive]
			RETURN
			    IF(behavior IN {"Email Summarising","Email Triage","Email Thread Summary"}, "Time Saved (Email)",
			    IF(behavior IN {"Meeting Prep","Video Summarising"}, "Time Saved (Meetings)",
			    IF(behavior IN {"Document Summarising","Presentation Summarising","Note Taking"}, "Time Saved (Documents)",
			    IF(behavior IN {"Web Searching","Enterprise Searching","File Retrieval","PDF Analysis","SharePoint Access","People Lookup","Agent: Knowledge Base"}, "Search Time Saved",
			    IF(behavior IN {"Teams Messaging","Meeting Scheduling"}, "Communication Time Saved",
			    IF(behavior IN {"Spreadsheet Review","Spreadsheet Analysis","Excel Assistance"}, "Spreadsheet Time Saved",
			    IF(behavior IN {"Email Drafting","Document Drafting","Presentation Creation","Image Generation","Image / Media Analysis","Image/Media Analysis","Agent: Content Generation","Agent: Ideation & Creative"}, "Content Output",
			    IF(behavior IN {"Real-time Collaboration","Form / Survey Work"}, "Team Collaboration",
			    IF(behavior = "Running a Workflow" || env = "Cowork", "Workflow Automation",
			    IF(behavior = "Task Management", "Task Coordination",
			    IF(isSensitive && env <> "Agents" && env <> "Cowork", "Compliance & Risk",
			    IF(behavior IN {"Data Querying","Agent: Data & Reporting","Agent: Research & Analysis"}, "Data-Driven Decisions",
			    IF(behavior IN {"Code Writing","Code Analysis","Code Analysis (URL)"}, "Coding Capability",
			    IF(behavior IN {"Agent: Coaching","Agent: Coaching (URL)"}, "Skills Development",
			    IF(behavior = "Agent: Sales & Customer", "Revenue Enablement",
			    IF(behavior = "Agent: IT & Service Desk", "Service Desk Deflection",
			    IF(behavior = "Agent: Compliance & Policy", "Compliance & Risk",
			    IF(behavior = "Agent: HR & People", "HR Expertise",
			    IF(behavior IN {"Domain-Specific Agent","Cross-Org Agent"}, "Specialist Expertise",
			    "General AI Productivity")))))))))))))))))))
		dataType: string
		lineageTag: ff030001-0001-0001-0001-000000000008
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	/// Agent-name-based reclassification of generic Q&A into a specific agent category (needed for downstream logic)
	column Behavior_Enriched =
			VAR behavior = 'Chat + Agent Interactions (Audit Logs)'[Behavior_Category]
			VAR agentName = LOWER('Chat + Agent Interactions (Audit Logs)'[AgentName])
			VAR env = 'Chat + Agent Interactions (Audit Logs)'[Environment]
			RETURN
			    IF(env <> "Agents" && env <> "Cowork", behavior,
			    IF(NOT(behavior IN {"General Q&A","M365 Chat Q&A","Teams Q&A","Browser Q&A","General Chat"}), behavior,
			    IF(CONTAINSSTRING(agentName, "coach") || CONTAINSSTRING(agentName, "mentor") || CONTAINSSTRING(agentName, "learning") || CONTAINSSTRING(agentName, "career"), "Agent: Coaching",
			    IF(CONTAINSSTRING(agentName, "research") || CONTAINSSTRING(agentName, "analyst") || CONTAINSSTRING(agentName, "analy"), "Agent: Research & Analysis",
			    IF(CONTAINSSTRING(agentName, "sales") || CONTAINSSTRING(agentName, "commercial") || CONTAINSSTRING(agentName, "customer") || CONTAINSSTRING(agentName, "crm") || CONTAINSSTRING(agentName, "revenue"), "Agent: Sales & Customer",
			    IF(CONTAINSSTRING(agentName, "hr") || CONTAINSSTRING(agentName, "recruit") || CONTAINSSTRING(agentName, "talent") || CONTAINSSTRING(agentName, "onboard") || CONTAINSSTRING(agentName, "people"), "Agent: HR & People",
			    IF(CONTAINSSTRING(agentName, "policy") || CONTAINSSTRING(agentName, "compliance") || CONTAINSSTRING(agentName, "legal") || CONTAINSSTRING(agentName, "audit") || CONTAINSSTRING(agentName, "risk"), "Agent: Compliance & Policy",
			    IF(CONTAINSSTRING(agentName, "service") || CONTAINSSTRING(agentName, "support") || CONTAINSSTRING(agentName, "help") || CONTAINSSTRING(agentName, "ticket") || CONTAINSSTRING(agentName, "incident"), "Agent: IT & Service Desk",
			    IF(CONTAINSSTRING(agentName, "summar") || CONTAINSSTRING(agentName, "draft") || CONTAINSSTRING(agentName, "translat") || CONTAINSSTRING(agentName, "editor"), "Agent: Content Generation",
			    IF(CONTAINSSTRING(agentName, "data") || CONTAINSSTRING(agentName, "report") || CONTAINSSTRING(agentName, "dashboard") || CONTAINSSTRING(agentName, "metric"), "Agent: Data & Reporting",
			    IF(CONTAINSSTRING(agentName, "knowledge") || CONTAINSSTRING(agentName, "faq") || CONTAINSSTRING(agentName, "wiki") || CONTAINSSTRING(agentName, "buddy") || CONTAINSSTRING(agentName, "guide"), "Agent: Knowledge Base",
			    IF(CONTAINSSTRING(agentName, "idea") || CONTAINSSTRING(agentName, "brainstorm") || CONTAINSSTRING(agentName, "creative") || CONTAINSSTRING(agentName, "design"), "Agent: Ideation & Creative",
			    "Agent: General Purpose"))))))))))))
		dataType: string
		isHidden
		lineageTag: ff030001-0001-0001-0001-000000000012
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	/// Alias of User_Stage_Maturity. Points to the other column to avoid duplicate computation.
	column User_Stage = 'Chat + Agent Interactions (Audit Logs)'[User_Stage_Maturity]
