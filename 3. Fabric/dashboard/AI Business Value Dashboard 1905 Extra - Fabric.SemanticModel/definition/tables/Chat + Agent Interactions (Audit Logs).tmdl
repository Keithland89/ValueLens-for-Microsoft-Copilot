	measure 'Tasks per Active User (by Behavior)' =
			
			VAR TaskCount =
			    CALCULATE(
			        DISTINCTCOUNT('Chat + Agent Interactions (Audit Logs)'[ThreadId]),
			        'Chat + Agent Interactions (Audit Logs)'[Message_isPrompt] = "TRUE"
			    )
			VAR ActiveUsers =
			    CALCULATE(
			        DISTINCTCOUNT('Chat + Agent Interactions (Audit Logs)'[Audit_UserId]),
			        'Chat + Agent Interactions (Audit Logs)'[Message_isPrompt] = "TRUE",
			        REMOVEFILTERS('Chat + Agent Interactions (Audit Logs)'[Behavior_Enriched_Full])
			    )
			RETURN
			    DIVIDE(TaskCount, ActiveUsers, 0)
