	/// Environment — licence-first 3-way bucketing of every audit row.
	/// Cowork     : Microsoft Copilot Cowork feature only (literal "cowork" in AgentName).
	/// Tiny niche cohort, kept separate so it can appear in the autonomy mix.
	/// Licensed   : ANY activity by a licensed Copilot user (chat OR agent OR workflow).
	/// Unlicensed : ANY activity by a user without a Copilot license (chat OR agent OR workflow).
	/// 
	/// Agent / workflow / autonomous activity is now captured by the companion
	/// `Is_Agent_Activity` boolean column so it can overlap with Licensed / Unlicensed
	/// (a licensed user running a workflow is BOTH Licensed AND an Agent row).
	/// 
	/// 17 May 2026 — switched from 4-way mutually-exclusive to licence-first 3-way.
	/// Previously a licensed user's workflow row was forced into "Agents" and disappeared
	/// from the "Licensed" slicer; Activity Breakdown treemap visibly lost the entire
	/// "Running a Workflow" block when clicking Licensed. Use [Is_Agent_Activity] for any
	/// measure / slicer / visual that needs to filter agent rows.
	column Environment = ```
			
			    VAR agentName  = LOWER(TRIM('Chat + Agent Interactions (Audit Logs)'[AgentName]))
			    VAR license    = UPPER(TRIM('Chat + Agent Interactions (Audit Logs)'[Has license]))
			    VAR isLicensed = license IN {"YES","TRUE","Y","1"}
			    RETURN
			        IF(CONTAINSSTRING(agentName, "cowork"),  "Cowork",
			        IF(isLicensed,                            "Licensed",
			                                                  "Unlicensed"))
			
			```
		dataType: string
		lineageTag: ff030001-0001-0001-0001-000000000004
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column Is_Sensitive =
			(NOT(ISBLANK('Chat + Agent Interactions (Audit Logs)'[SensitivityLabelId])) && 'Chat + Agent Interactions (Audit Logs)'[SensitivityLabelId] <> "")
