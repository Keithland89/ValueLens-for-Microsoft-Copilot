	/// Median weekly AI Tasks per unlicensed user — count of prompt rows submitted
	/// per user, averaged across weeks they were active, then taken at the median.
	/// Powers the volume signal in License Priority Score (User) v2. Uses the same
	/// "Tasks Performed" definition (Message_isPrompt = TRUE) as the rest of the
	/// report — consistent with the Activity & Value page and Executive Headline.
	measure 'Median Unlicensed AI Tasks Per User Per Week' = ```
			
			MEDIANX(
			    FILTER(
			        VALUES('Chat + Agent Interactions (Audit Logs)'[Audit_UserId]),
			        CALCULATE(
			            COUNTROWS('Chat + Agent Interactions (Audit Logs)'),
			            'Chat + Agent Interactions (Audit Logs)'[Message_isPrompt] = "TRUE",
			            'Chat + Agent Interactions (Audit Logs)'[License Status] = "Unlicensed"
			        ) > 0
			    ),
			    VAR TotalTasks =
			        CALCULATE(
			            COUNTROWS('Chat + Agent Interactions (Audit Logs)'),
			            'Chat + Agent Interactions (Audit Logs)'[Message_isPrompt] = "TRUE",
			            'Chat + Agent Interactions (Audit Logs)'[License Status] = "Unlicensed",
			            REMOVEFILTERS('Chat + Agent Interactions (Audit Logs)'[WeekStart])
			        )
			    VAR TotalWeeks =
			        CALCULATE(
			            DISTINCTCOUNT('Chat + Agent Interactions (Audit Logs)'[WeekStart]),
			            'Chat + Agent Interactions (Audit Logs)'[Message_isPrompt] = "TRUE",
			            'Chat + Agent Interactions (Audit Logs)'[License Status] = "Unlicensed",
			            REMOVEFILTERS('Chat + Agent Interactions (Audit Logs)'[WeekStart])
			        )
			    RETURN
			        DIVIDE(TotalTasks, TotalWeeks, 0)
			)
			
			```
		formatString: 0.0
		displayFolder: License Readiness
		lineageTag: ce411199-5b7e-4555-bdaf-dd5d6c00ab04

	measure 'Agent Review Status' =
			
			VAR _A365HasData = COUNTROWS('Agents 365') > 0
			
			// Resolve agent name from whichever table is in filter context
			VAR _AgentFromA365  = IF(_A365HasData, SELECTEDVALUE('Agents 365'[Agent name]), BLANK())
			VAR _AgentFromAudit = SELECTEDVALUE('Chat + Agent Interactions (Audit Logs)'[AgentName])
			VAR _Agent          = COALESCE(_AgentFromA365, _AgentFromAudit)
			VAR _NotASingleAgent = ISBLANK(_Agent)
			
			// === Activity inputs (always computable from audit) ===
			VAR _LastUsedDate =
			    CALCULATE(
			        MAX('Chat + Agent Interactions (Audit Logs)'[CreationDate]),
			        'Chat + Agent Interactions (Audit Logs)'[AgentName] = _Agent
			    )
			VAR _MaxDateInData =
			    CALCULATE(
			        MAX('Chat + Agent Interactions (Audit Logs)'[CreationDate]),
			        ALL('Chat + Agent Interactions (Audit Logs)')
			    )
			VAR _DaysSinceUsed =
			    IF(NOT(ISBLANK(_LastUsedDate)),
			       DATEDIFF(_LastUsedDate, _MaxDateInData, DAY),
			       BLANK()
			    )
			
			// === A365 enrichments (used only if A365 has data) ===
			VAR _AgentCreatedDate =
			    IF(_A365HasData,
			       CALCULATE(MAX('Agents 365'[Date created]), 'Agents 365'[Agent name] = _Agent),
			       BLANK()
			    )
			VAR _DaysSinceCreated =
			    IF(NOT(ISBLANK(_AgentCreatedDate)),
			       DATEDIFF(_AgentCreatedDate, _MaxDateInData, DAY),
			       BLANK()
			    )
			
			// === Agent type: prefer A365, default to "Unknown" ===
			VAR _AgentTypeFromA365 =
			    IF(_A365HasData,
			       CALCULATE(MAX('Agents 365'[Agent Type Combined]), 'Agents 365'[Agent name] = _Agent),
			       BLANK()
			    )
			VAR _AgentType = COALESCE(_AgentTypeFromA365, "Unknown")
			
			// === Total Users (distinct audit users for this agent) ===
			VAR _TotalUsers =
			    CALCULATE(
			        DISTINCTCOUNT('Chat + Agent Interactions (Audit Logs)'[Audit_UserId]),
			        'Chat + Agent Interactions (Audit Logs)'[AgentName] = _Agent
			    )
			
			// === Org Count (distinct organizations across those users) ===
			VAR _AgentUsers =
			    CALCULATETABLE(
			        VALUES('Chat + Agent Interactions (Audit Logs)'[Audit_UserId]),
			        'Chat + Agent Interactions (Audit Logs)'[AgentName] = _Agent
			    )
			VAR _OrgCount =
			    CALCULATE(
			        DISTINCTCOUNT('Chat + Agent Org Data'[Organization]),
			        FILTER(
			            ALL('Chat + Agent Org Data'),
			            'Chat + Agent Org Data'[PersonId] IN _AgentUsers
			        )
			    )
			
			// === Activity bucket (mirrors Agents 365[Agent Last Activity Date]) ===
			VAR _InactivityStatus =
			    SWITCH(
			        TRUE(),
			        NOT(ISBLANK(_DaysSinceUsed)) && _DaysSinceUsed <= 7,  "1. Active (Last 7 days)",
			        NOT(ISBLANK(_DaysSinceUsed)) && _DaysSinceUsed <= 30, "2. Recent (Last 30 days)",
			        NOT(ISBLANK(_DaysSinceUsed)) && _DaysSinceUsed <= 60, "3. Inactive (30-60 days)",
			        NOT(ISBLANK(_DaysSinceUsed)) && _DaysSinceUsed <= 90, "4. Dormant (60-90 days)",
			        NOT(ISBLANK(_DaysSinceUsed)), "5. Redundant (90+ days)",
			        ISBLANK(_LastUsedDate) && NOT(ISBLANK(_DaysSinceCreated)) && _DaysSinceCreated <= 14, "6. New (Not Yet Used)",
			        ISBLANK(_LastUsedDate) && NOT(ISBLANK(_DaysSinceCreated)) && _DaysSinceCreated <= 90, "7. Never Used (Recent)",
			        ISBLANK(_LastUsedDate), "8. Never Used (Stale)",
			        "Unknown"
			    )
			
			// === Type-specific thresholds (defaults 10/5/50/5 for Unknown) ===
			VAR LowUserThreshold = SWITCH(_AgentType, "FirstParty", 20, "Agent Builder", 5,  10)
			VAR MinUserThreshold = SWITCH(_AgentType, "FirstParty", 10, "Agent Builder", 2,  5)
			VAR HighImpactUsers  = SWITCH(_AgentType, "FirstParty", 100,"Agent Builder", 30, 50)
			VAR HighImpactOrgs   = SWITCH(_AgentType, "FirstParty", 10, "Agent Builder", 3,  5)
			
			// === Verdict ===
			RETURN
			    IF(_NotASingleAgent, BLANK(),
			       SWITCH(
			           TRUE(),
			           _InactivityStatus = "6. New (Not Yet Used)",
			               "🆕 New",
			           _InactivityStatus IN {"7. Never Used (Recent)", "8. Never Used (Stale)"},
			               "❌ Never Used",
			           _InactivityStatus IN {"1. Active (Last 7 days)", "2. Recent (Last 30 days)"},
			               IF(_TotalUsers >= HighImpactUsers && _OrgCount >= HighImpactOrgs,
			                  "🔥 High Impact",
			                  "✅ Keep"
			               ),
			           _InactivityStatus = "3. Inactive (30-60 days)" && _TotalUsers < LowUserThreshold,
			               "⚠️ Review",
			           _InactivityStatus = "4. Dormant (60-90 days)",
			               SWITCH(TRUE(),
			                   _TotalUsers < MinUserThreshold, "💤 Dormant",
			                   _TotalUsers < LowUserThreshold, "⚠️ Review",
			                   "✅ Keep"
			               ),
			           _InactivityStatus = "5. Redundant (90+ days)",
			               IF(_TotalUsers < LowUserThreshold, "💤 Dormant", "⚠️ Review"),
			           "✅ Keep"
			       )
			    )
		lineageTag: ecf48715-d1ac-46d7-8c43-e9478f08dc6a

	measure '% Power Users (Latest)' = ```
			DIVIDE([Power Users (Latest)],    [All Active Users], 0)
			
			```
