			        RawMetrics,
			        "0", UNICHAR(120812)),
			        "1", UNICHAR(120813)),
			        "2", UNICHAR(120814)),
			        "3", UNICHAR(120815)),
			        "4", UNICHAR(120816)),
			        "5", UNICHAR(120817)),
			        "6", UNICHAR(120818)),
			        "7", UNICHAR(120819)),
			        "8", UNICHAR(120820)),
			        "9", UNICHAR(120821))
			RETURN Insight & LF & Metrics
		lineageTag: 379b329c-a2fe-4612-976c-bbc08eb5cd90

