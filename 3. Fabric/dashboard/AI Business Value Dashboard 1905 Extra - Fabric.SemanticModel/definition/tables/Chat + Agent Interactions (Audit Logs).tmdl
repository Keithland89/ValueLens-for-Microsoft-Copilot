	/// Delegating AI Rate: % of interactions in Usage_Mode "5 - Delegating"
	/// (Cowork autonomous runs, Logic Apps, Running a Workflow rows, or Agents 365-registered
	/// autonomous/workflow/triggered agents). The user has handed work to a system.
	measure 'Delegating AI Rate' =
			VAR DelegatingCount =
			    CALCULATE(
			        COUNTROWS('Chat + Agent Interactions (Audit Logs)'),
			        'Chat + Agent Interactions (Audit Logs)'[Message_isPrompt] = "TRUE",
			        'Chat + Agent Interactions (Audit Logs)'[Usage_Mode] IN {"5 - Delegating"}
			    )
			VAR TotalCount =
			    CALCULATE(
			        COUNTROWS('Chat + Agent Interactions (Audit Logs)'),
			        'Chat + Agent Interactions (Audit Logs)'[Message_isPrompt] = "TRUE"
			    )
			RETURN DIVIDE(DelegatingCount, TotalCount, 0)
		formatString: 0%;-0%;0%
		displayFolder: AI Fluency\Usage Modes
		lineageTag: ff030001-0001-0001-0001-000000000023

	/// Exec-grade Pattern-C headline. Line 1: plain-English insight. Line 2: supporting metrics with bold Unicode digits.
	measure 'Activation Overall Headline' =
			VAR Tot      = [Total Users (Filter-Aware)]
			VAR Act      = [Active Users (Filter-Aware)]
			VAR ActPct   = [% Active Users (of Total)]
			VAR Lic      = [Active Licensed Users]
			VAR Unl      = [Active Unlicensed Users]
			VAR Gap      = DIVIDE(Unl - Lic, Lic, 0)
			VAR LF       = UNICHAR(10)
			VAR Insight  =
			    SWITCH(
			        TRUE(),
			        ActPct = 0,                  "Copilot is not yet being used in this view",
			        Unl > Lic && Gap >= 0.2,     "More people use Copilot without a licence than with one — a clear chance to expand paid adoption",
			        Unl > Lic,                   "Slightly more people use Copilot without a licence than with one",
			        Lic >= Unl * 1.2,            "Most active Copilot users have a licence — paid adoption is leading",
			        Lic > Unl,                   "Licensed users are just ahead of unlicensed users",
			        "Licensed and unlicensed use is evenly matched"
			    )
			VAR RawMetrics =
			    FORMAT(Act, "#,##0") & " of " & FORMAT(Tot, "#,##0") &
			    " employees use Copilot (" & FORMAT(ActPct, "0.0%") & ")  ·  " &
			    FORMAT(Unl, "#,##0") & " unlicensed, " & FORMAT(Lic, "#,##0") & " licensed"
			VAR Metrics =
			    SUBSTITUTE(SUBSTITUTE(SUBSTITUTE(SUBSTITUTE(SUBSTITUTE(SUBSTITUTE(SUBSTITUTE(SUBSTITUTE(SUBSTITUTE(SUBSTITUTE(
			        RawMetrics,
			        "0", UNICHAR(120812)),
			        "1", UNICHAR(120813)),
			        "2", UNICHAR(120814)),
			        "3", UNICHAR(120815)),
			        "4", UNICHAR(120816)),
			        "5", UNICHAR(120817)),
			        "6", UNICHAR(120818)),
			        "7", UNICHAR(120819)),
			        "8", UNICHAR(120820)),
			        "9", UNICHAR(120821))
			RETURN Insight & LF & Metrics
		lineageTag: 6e6e8ed5-f2cf-4aea-b6e9-f55166eb485d

	/// Exec-grade Pattern-C headline. Line 1: plain-English insight. Line 2: supporting metrics with bold Unicode digits.
	measure 'Activation Licensed Headline' =
			VAR Act      = [Active Licensed Users]
			VAR Tot      = [Total Licensed Users]
			VAR ActPct   = [% Active Licensed Users]
			VAR LF       = UNICHAR(10)
			VAR Insight  =
			    SWITCH(
			        TRUE(),
			        ActPct = 0,         "No licensed users are active in this view",
			        ActPct >= 0.5,      "Most licensed users are actively using Copilot",
			        ActPct >= 0.25,     "About a quarter of licensed users are active — room to grow",
			        ActPct >= 0.10,     "Only a small share of licensed users are active — most paid licences sit unused",
			        "Licensed Copilot is barely being used — most paid licences are inactive"
			    )
			VAR RawMetrics =
			    FORMAT(Act, "#,##0") & " of " & FORMAT(Tot, "#,##0") &
			    " licensed users active (" & FORMAT(ActPct, "0.0%") & ")  ·  most adoption sits in a few divisions"
			VAR Metrics =
			    SUBSTITUTE(SUBSTITUTE(SUBSTITUTE(SUBSTITUTE(SUBSTITUTE(SUBSTITUTE(SUBSTITUTE(SUBSTITUTE(SUBSTITUTE(SUBSTITUTE(
			        RawMetrics,
			        "0", UNICHAR(120812)),
			        "1", UNICHAR(120813)),
			        "2", UNICHAR(120814)),
			        "3", UNICHAR(120815)),
			        "4", UNICHAR(120816)),
			        "5", UNICHAR(120817)),
			        "6", UNICHAR(120818)),
			        "7", UNICHAR(120819)),
			        "8", UNICHAR(120820)),
			        "9", UNICHAR(120821))
			RETURN Insight & LF & Metrics
		lineageTag: f02132e8-6d82-4d8e-9c9d-0bceb2a88d42

	/// Exec-grade Pattern-C headline. Line 1: plain-English insight. Line 2: supporting metrics with bold Unicode digits.
	measure 'Activation Unlicensed Headline' =
			VAR Unl      = [Active Unlicensed Users]
			VAR Lic      = [Active Licensed Users]
			VAR UnlPct   = [% Active Unlicensed Users]
			VAR Diff     = DIVIDE(Unl - Lic, Lic, 0)
			VAR LF       = UNICHAR(10)
			VAR Insight  =
			    SWITCH(
			        TRUE(),
			        Unl = 0,            "No unlicensed AI use in this view",
			        Diff >= 0.4,        "Far more people use Copilot or agents without a licence than with one — strong list of upgrade candidates",
			        Diff >= 0,          "Slightly more people use Copilot or agents without a licence than with one",
			        Diff > -0.2,        "Unlicensed Copilot & agent use sits just below licensed usage",
			        "Unlicensed Copilot & agent use is well below licensed usage"
			    )
			VAR RawMetrics =
			    FORMAT(Unl, "#,##0") & " employees use Copilot or agents without a licence (" & FORMAT(UnlPct, "0.0%") & " of org)  ·  " &
			    FORMAT(Diff, "+0%;-0%;0%") & " vs paid — ready-to-convert M365 Copilot candidates"
			VAR Metrics =
			    SUBSTITUTE(SUBSTITUTE(SUBSTITUTE(SUBSTITUTE(SUBSTITUTE(SUBSTITUTE(SUBSTITUTE(SUBSTITUTE(SUBSTITUTE(SUBSTITUTE(
			        RawMetrics,
			        "0", UNICHAR(120812)),
			        "1", UNICHAR(120813)),
			        "2", UNICHAR(120814)),
			        "3", UNICHAR(120815)),
			        "4", UNICHAR(120816)),
			        "5", UNICHAR(120817)),
			        "6", UNICHAR(120818)),
			        "7", UNICHAR(120819)),
			        "8", UNICHAR(120820)),
			        "9", UNICHAR(120821))
			RETURN Insight & LF & Metrics
		lineageTag: b055f7f7-74ba-403f-8e0b-eba03c113e69

	/// Exec-grade Pattern-C headline. Line 1: plain-English insight. Line 2: supporting metrics with bold Unicode digits.
	measure 'Activation Agents Headline' =
			VAR Agt      = [Active Agent Users]
			VAR AgtPct   = [% Active Users Using Agents]
