	/// 29 May 2026 — Behavioural delegation count.
	/// DISTINCTCOUNT of [Delegation_Event_Key] filtered to Usage_Mode = "5 - Delegating".
	/// Use this for "real" delegation volume (collapses repeated workflow triggers
	/// per user per day to one event). Compare against raw delegation row count
	/// to surface tenant-plumbing noise.
	measure 'Delegation Events' =
			CALCULATE(
			    DISTINCTCOUNT('Chat + Agent Interactions (Audit Logs)'[Delegation_Event_Key]),
			    'Chat + Agent Interactions (Audit Logs)'[Usage_Mode] = "5 - Delegating"
			)
