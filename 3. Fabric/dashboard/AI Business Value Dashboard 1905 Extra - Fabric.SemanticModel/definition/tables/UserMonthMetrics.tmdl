table UserMonthMetrics
	lineageTag: ff090001-0001-0001-0001-000000000010

	column Audit_UserId
		dataType: string
		isHidden
		lineageTag: ff090001-0001-0001-0001-000000000011
		summarizeBy: none
		isNameInferred
		sourceColumn: Chat + Agent Interactions (Audit Logs)[Audit_UserId]

		annotation SummarizationSetBy = Automatic

	column MonthStart
		dataType: dateTime
		isHidden
		formatString: General Date
		lineageTag: ff090001-0001-0001-0001-000000000012
		summarizeBy: none
		isNameInferred
		sourceColumn: Chat + Agent Interactions (Audit Logs)[MonthStart]

		annotation SummarizationSetBy = Automatic

	column BehaviorCount
		dataType: int64
		isHidden
		formatString: 0
		lineageTag: ff090001-0001-0001-0001-000000000013
		summarizeBy: sum
		sourceColumn: [BehaviorCount]

		annotation SummarizationSetBy = Automatic

	column HasAgent
		dataType: boolean
		isHidden
		formatString: &quot;TRUE&quot;;&quot;TRUE&quot;;&quot;FALSE&quot;
		lineageTag: ff090001-0001-0001-0001-000000000014
		summarizeBy: none
		sourceColumn: [HasAgent]

		annotation SummarizationSetBy = Automatic

	column ActiveDays
		dataType: int64
		isHidden
		formatString: 0
		lineageTag: ff090001-0001-0001-0001-000000000015
		summarizeBy: sum
		sourceColumn: [ActiveDays]

		annotation SummarizationSetBy = Automatic

	/// Composite key for joining to the fact table (avoids per-row CALCULATETABLE)
	column UserMonthKey
		dataType: string
		isHidden
		lineageTag: ff090001-0001-0001-0001-000000000016
		summarizeBy: none
		sourceColumn: [UserMonthKey]

		annotation SummarizationSetBy = Automatic

	/// Pre-computed user maturity stage (5-stage ladder).
	/// 16 May 2026 — Upgraded from 3-stage to 5-stage:
	/// 1 - Beginner   : 1-2 active days (just trying it out)
	/// 2 - Developing : 3-7 active days AND ≥3 enriched behaviours (multi-workflow learner)
	/// 3 - Habitual   : 8-14 active days AND ≥5 enriched behaviours (embedded across week)
	/// 4 - Power      : ≥15 active days, OR (≥10 days AND ≥30% Producing+Delegating AND uses an Agent)
	/// Inactive (licensed but inactive) is handled by a separate measure since
	/// inactive users have no rows in the fact table.
	/// Breadth now uses Behavior_Enriched_Full (~40 categories) for sharper signal
	/// than the old Behavior_Category (~20 categories).
	column UserStage
		dataType: string
		lineageTag: ff090001-0001-0001-0001-000000000017
		summarizeBy: none
		sourceColumn: [UserStage]

		annotation SummarizationSetBy = Automatic

	/// Producing + Delegating share — % of this user's monthly activity in the
	/// two highest-value Usage Modes. Used by Power-stage gate.
	column ValueFocusShare
		dataType: double
		isHidden
		formatString: 0.0%;-0.0%;0.0%
		lineageTag: ff090001-0001-0001-0001-000000000018
		summarizeBy: none
		sourceColumn: [ValueFocusShare]

		annotation SummarizationSetBy = Automatic

	partition UserMonthMetrics = calculated
		mode: import
		source =
				VAR Base =
				    SUMMARIZE(
					'Chat + Agent Interactions (Audit Logs)',
					'Chat + Agent Interactions (Audit Logs)'[Audit_UserId],
					'Chat + Agent Interactions (Audit Logs)'[MonthStart]
				    )
				VAR WithMetrics =
				    ADDCOLUMNS(
					Base,
					"BehaviorCount", CALCULATE(
					    DISTINCTCOUNT('Chat + Agent Interactions (Audit Logs)'[Behavior_Enriched_Full])
					),
					"HasAgent", CALCULATE(
					    COUNTROWS(
						FILTER(
						    'Chat + Agent Interactions (Audit Logs)',
						    NOT(ISBLANK('Chat + Agent Interactions (Audit Logs)'[AgentName]))
							&& 'Chat + Agent Interactions (Audit Logs)'[AgentName] <> ""
						)
					    )
					) > 0,
					"ActiveDays", CALCULATE(
					    DISTINCTCOUNT('Chat + Agent Interactions (Audit Logs)'[InteractionDate])
					),
					"ValueFocusShare",
					    DIVIDE(
						CALCULATE(
						    COUNTROWS('Chat + Agent Interactions (Audit Logs)'),
						    'Chat + Agent Interactions (Audit Logs)'[Usage_Mode] IN {"4 - Producing","5 - Delegating"}
						),
						CALCULATE(COUNTROWS('Chat + Agent Interactions (Audit Logs)')),
						0
					    ),
					"UserMonthKey",
					    'Chat + Agent Interactions (Audit Logs)'[Audit_UserId] & "|" &
					    FORMAT('Chat + Agent Interactions (Audit Logs)'[MonthStart], "yyyy-MM")
				    )
				RETURN
				    ADDCOLUMNS(
					WithMetrics,
					"UserStage",
					    IF(
						[ActiveDays] >= 15
						    || ([ActiveDays] >= 10 && [ValueFocusShare] >= 0.30 && [HasAgent]),
						"4 - Power",
					    IF([ActiveDays] >= 8 && [BehaviorCount] >= 5, "3 - Habitual",
					    IF([ActiveDays] >= 3 && [BehaviorCount] >= 3, "2 - Developing",
					    "1 - Beginner")))
				    )

